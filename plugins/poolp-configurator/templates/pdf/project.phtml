  <?php if (($finition['prix_supplement_ttc'] ?? 0) > 0): ?>
    · supplément <?= $esc($money($finition['prix_supplement_ttc'])) ?>
  <?php endif; ?>
</div>
<?php endif; ?>

<?php if ($livraison): ?>
<h2>Livraison</h2>
<div class="grid">
  <div><div class="label">Zone</div><div class="value"><?= $esc($livraison['zone_label'] ?? '?') ?></div></div>
  <div><div class="label">Mode</div><div class="value"><?= $esc(($livraison['mode'] ?? 'kit') === 'montee' ? 'Box montée' : 'Box en kit') ?></div></div>
  <div><div class="label">Délai</div><div class="value"><?= $esc($livraison['delay_label'] ?? '—') ?></div></div>
  <div><div class="label">Frais TTC</div><div class="value"><?= $esc($money($livraison['fee_ttc'] ?? 0)) ?></div></div>
