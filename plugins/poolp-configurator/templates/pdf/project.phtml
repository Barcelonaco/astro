$totaux = $computed['totaux'] ?? [];
$warnings = $computed['warnings'] ?? [];
$esc = fn($s) => htmlspecialchars((string)$s, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
$money = fn($n) => $n === null ? '—' : number_format((float)$n, 2, ',', ' ') . ' €';
?>
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>POOLP — Récapitulatif projet</title>
<style>
  @page { margin: 18mm 14mm; }
  body { font-family: 'Helvetica', sans-serif; color: #1a1a1a; font-size: 10pt; line-height: 1.4; }
