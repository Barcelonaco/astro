<table>
  <tbody>
    <tr><td>Total TTC</td><td style="text-align:right" class="total"><?= $esc($money($totaux['ttc'] ?? 0)) ?></td></tr>
    <?php if (!empty($totaux['pro_ht_remise'])): ?>
      <tr><td>Total pro HT (remise <?= $esc(round(($totaux['discount_rate'] ?? 0) * 100, 1)) ?>%)</td><td style="text-align:right" class="total"><?= $esc($money($totaux['pro_ht_remise'])) ?></td></tr>
    <?php endif; ?>
  </tbody>
</table>

<?php if (in_array('triphase', $warnings, true)): ?>
<div class="warn">⚠ Les équipements proposés sont adaptés à une <strong>alimentation monophasée</strong>. Pour une installation triphasée, une option supplémentaire peut être demandée sur devis en contactant directement l'équipe Scanzi.</div>
<?php endif; ?>

<?php if (in_array('erp', $warnings, true)): ?>
<div class="warn">⚠ Installation classée <strong>ERP</strong> (recevant du public). Contactez directement l'équipe pour adapter le devis aux contraintes réglementaires.</div>
<?php endif; ?>

</body>
</html>
