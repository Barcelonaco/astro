  <div><div class="label">Débit requis</div><div class="value"><?= $esc(number_format($h['debit'] ?? 0, 1, ',', ' ')) ?> m³/h</div></div>
  <div><div class="label">Skimmers / refoulements / bondes</div><div class="value"><?= (int)($h['nb_skimmers'] ?? 0) ?> / <?= (int)($h['nb_refoulements'] ?? 0) ?> / <?= (int)($h['nb_bondes'] ?? 0) ?></div></div>
</div>
<div class="grid" style="margin-top: 2mm;">
  <div><div class="label">Volet immergé</div><div><?= !empty($state['volet_immerge']) ? 'Oui' : 'Non' ?></div></div>
