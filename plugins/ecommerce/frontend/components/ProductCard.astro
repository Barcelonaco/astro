---
import PriceDisplay from './PriceDisplay.astro';
import type { ProductSummary } from '@plugins/ecommerce/frontend/lib/shop-api';
import { optimizedImageUrl } from '@frontend/lib/module-helpers';

interface Props { product: ProductSummary & { stock_tracked?: boolean; is_configured?: boolean }; }
const { product } = Astro.props;

const imageUrl = (() => {
  const fi = product.featured_image;
  if (!fi) return null;
  if (typeof fi === 'string') return fi;
  if (typeof fi === 'object') return fi.sizes?.half || fi.url || null;
  return null;
})();

const primaryCategory = product.categories?.find(c => c.level === Math.max(...product.categories.map(c => c.level))) || product.categories?.[0];

// Afficher "Rupture" uniquement si le stock est suivi ET le produit est configuré (prix > 0 ou variants).
// Évite d'afficher "Rupture" sur des produits tout juste créés via le CPT admin générique.
const showOutOfStock = product.stock_tracked && !product.in_stock && product.is_configured;
const showOnSale = product.compare_at_price_cents && product.compare_at_price_cents > 0 && product.compare_at_price_cents < product.price_cents_min;
const showUnconfigured = !product.is_configured;
---
<article class="shop-product-card">
  <a href={`/produits/${product.slug}`} class="shop-product-card__link" aria-label={product.title}>
    <div class="shop-product-card__image-wrapper">
      {imageUrl ? (
        <img
          src={optimizedImageUrl(imageUrl, 600, 80)}
          alt={product.title}
          class="shop-product-card__image"
          loading="lazy"
          width="600"
          height="600"
        />
      ) : (
        <div class="shop-product-card__image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
        </div>
      )}
      {showOutOfStock && <span class="shop-product-card__badge shop-product-card__badge--out">Rupture</span>}
      {showOnSale && <span class="shop-product-card__badge shop-product-card__badge--sale">Promo</span>}
      {showUnconfigured && <span class="shop-product-card__badge shop-product-card__badge--draft" title="Ce produit n'a pas encore de prix. Complétez la fiche dans l'admin.">À configurer</span>}
    </div>
    <div class="shop-product-card__body">
      {primaryCategory && <p class="shop-product-card__category">{primaryCategory.name}</p>}
      <h3 class="shop-product-card__title">{product.title}</h3>
      {product.excerpt && <p class="shop-product-card__excerpt">{product.excerpt}</p>}
      <div class="shop-product-card__price">
        {product.is_configured ? (
          <PriceDisplay
            priceCents={product.price_cents_min}
            priceCentsMax={product.has_variants ? product.price_cents_max : undefined}
            priceHtCents={product.price_ht_cents_min}
            priceHtCentsMax={product.has_variants ? product.price_ht_cents_max : undefined}
            compareAtCents={product.compare_at_price_cents}
            taxRate={product.tax_rate}
            currency={product.currency}
          />
        ) : (
          <span class="shop-product-card__price-pending">Prix à venir</span>
        )}
      </div>
    </div>
  </a>
</article>

<style is:global>
  .shop-product-card {
    display: block;
    background: #fff;
    border: 1px solid var(--gray-200, #e5e7eb);
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow .2s, transform .2s;
  }
  .shop-product-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); transform: translateY(-2px); }
  .shop-product-card__link { display: block; color: inherit; text-decoration: none; }
  .shop-product-card__link:focus-visible {
    outline: 3px solid var(--color-primary, #0f62fe);
    outline-offset: 2px;
    border-radius: 10px;
  }
  .shop-product-card__image-wrapper {
    position: relative; width: 100%; padding-top: 100%; overflow: hidden;
    background: var(--gray-100, #f3f4f6);
  }
  .shop-product-card__image {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center; transition: transform .4s ease;
  }
  .shop-product-card:hover .shop-product-card__image { transform: scale(1.05); }
  .shop-product-card__image-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--gray-100, #f3f4f6), var(--gray-200, #e5e7eb));
    color: var(--gray-400, #9ca3af);
  }
  .shop-product-card__image-placeholder svg { width: 40%; height: 40%; }
  .shop-product-card__badge {
    position: absolute; top: 10px; left: 10px;
    padding: 4px 10px; border-radius: 4px;
    font-size: 12px; font-weight: 600; color: #fff;
  }
  .shop-product-card__badge--out { background: var(--gray-700, #374151); }
  .shop-product-card__badge--sale { background: var(--danger, #dc2626); }
  .shop-product-card__badge--draft { background: var(--warning, #d97706); }
  .shop-product-card__body { padding: 14px 16px 16px; }
  .shop-product-card__category {
    margin: 0 0 4px; font-size: 12px; color: var(--gray-500, #6b7280);
    text-transform: uppercase; letter-spacing: .04em;
  }
  .shop-product-card__title { margin: 0 0 6px; font-size: 1.05rem; line-height: 1.25; font-weight: 600; }
  .shop-product-card__excerpt {
    margin: 0 0 10px; font-size: 13px; color: var(--gray-600, #4b5563);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .shop-product-card__price { margin-top: 8px; }
  .shop-product-card__price-pending {
    font-size: 13px; font-style: italic; color: var(--gray-500, #6b7280);
  }
</style>
