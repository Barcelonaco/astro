---
import { formatPrice } from '@plugins/ecommerce/frontend/lib/shop-api';

interface Props {
  priceCents: number;
  priceCentsMax?: number;
  priceHtCents?: number;
  priceHtCentsMax?: number;
  compareAtCents?: number | null;
  taxRate?: number;
  currency?: string;
  showCompare?: boolean;
}

const {
  priceCents, priceCentsMax,
  priceHtCents, priceHtCentsMax,
  compareAtCents, taxRate,
  currency = 'EUR', showCompare = true
} = Astro.props;

const hasRange = priceCentsMax !== undefined && priceCentsMax !== priceCents;
const onSale = showCompare && compareAtCents && compareAtCents > priceCents;
const discountPct = onSale ? Math.round(((compareAtCents! - priceCents) / compareAtCents!) * 100) : 0;
---
<div class="price-display"
  data-ht-min={priceHtCents ?? ''}
  data-ht-max={priceHtCentsMax ?? ''}
  data-tax-rate={taxRate ?? ''}
  data-currency={currency}
>
  {onSale && compareAtCents && (
    <span class="price-compare" aria-label={`Prix avant reduction ${formatPrice(compareAtCents, currency)}`}>{formatPrice(compareAtCents, currency)}</span>
  )}
  {/* HT pro line — hidden by default, shown as primary price client-side if pro approved */}
  {priceHtCents !== undefined && priceHtCents > 0 && (
    <span class="price-ht" style="display:none">
      {hasRange ? (
        <>A partir de <strong class="price-ht-value">{formatPrice(priceHtCents, currency)}</strong> HT</>
      ) : (
        <><strong class="price-ht-value">{formatPrice(priceHtCents, currency)}</strong> HT</>
      )}
      <span class="price-ht-discount" style="display:none"></span>
    </span>
  )}
  <span class="price-current">
    {hasRange ? (
      <>A partir de <strong>{formatPrice(priceCents, currency)}</strong></>
    ) : (
      <strong>{formatPrice(priceCents, currency)}</strong>
    )}
    <span class="price-label-ttc">TTC</span>
  </span>
  {onSale && <span class="price-discount-badge">-{discountPct}%</span>}
</div>

<style is:global>
  .price-display {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .price-current {
    font-size: 1.1em;
    color: var(--color-default, #224f5a);
  }
  .price-current strong {
    font-weight: 700;
  }
  .price-label-ttc {
    font-size: 0.7em;
    color: var(--gray-500, #6b7280);
    font-weight: 400;
    margin-left: 2px;
  }
  .price-compare {
    color: var(--gray-500, #6b7280);
    text-decoration: line-through;
    font-size: 0.9em;
  }
  .price-discount-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--danger, #dc2626);
    color: white;
    font-size: 0.75em;
    font-weight: 600;
    align-self: flex-start;
  }
  /* HT line — hidden by default */
  .price-ht {
    font-size: 0.85em;
    color: var(--gray-500, #6b7280);
    font-weight: 500;
  }
  .price-ht strong {
    font-weight: 700;
  }
  .price-ht-discount {
    font-size: 0.85em;
    margin-left: 4px;
    color: var(--gray-500, #6b7280);
  }
  /* Pro mode: HT becomes primary, TTC becomes strikethrough secondary */
  .price-display.is-pro .price-ht {
    font-size: 1.1em;
    color: var(--color-default, #224f5a);
    order: -1;
  }
  .price-display.is-pro .price-current {
    font-size: 0.85em;
    color: var(--gray-500, #6b7280);
    text-decoration: line-through;
  }
  .price-display.is-pro .price-current strong {
    font-weight: 500;
  }
  .price-display.is-pro .price-label-ttc {
    text-decoration: none;
  }
  .pro-tier-badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 3px;
    background: var(--color-primary, #1a5276);
    color: #fff;
    font-size: 0.75em;
    font-weight: 600;
    letter-spacing: 0.3px;
    margin-right: 4px;
    vertical-align: middle;
  }
  .price-ht-discount {
    font-size: 0.85em;
    color: var(--color-primary, #1a5276);
    font-weight: 600;
  }
</style>
