---
import BaseHead from '@frontend/components/BaseHead.astro';
import Header from '@frontend/components/Header.astro';
import Footer from '@frontend/components/Footer.astro';
import DeferredLoader from '@frontend/components/DeferredLoader.astro';
import SiteOverlays from '@frontend/components/SiteOverlays.astro';
import ModuleStyles from '@frontend/components/ModuleStyles.astro';
import BlockRenderer from '@frontend/components/BlockRenderer.astro';
import PriceDisplay from '@plugins/ecommerce/frontend/components/PriceDisplay.astro';
import VariantSelector from '@plugins/ecommerce/frontend/components/VariantSelector.astro';
import AddToCartButton from '@plugins/ecommerce/frontend/components/AddToCartButton.astro';
import Breadcrumb from '@plugins/ecommerce/frontend/components/Breadcrumb.astro';
import ProductCard from '@plugins/ecommerce/frontend/components/ProductCard.astro';
import { getFrontendBootstrap } from '@frontend/lib/api';
import { getProduct, listProducts } from '@plugins/ecommerce/frontend/lib/shop-api';
import { optimizedImageUrl } from '@frontend/lib/module-helpers';
import { SITE_TITLE, SITE_DESCRIPTION } from '@frontend/consts';
import '@plugins/ecommerce/frontend/styles/shop-buttons.css';

// Génération statique d'une page par produit publié.
export async function getStaticPaths() {
  const res = await listProducts({ per_page: 500 });
  return res.data.map((p) => ({ params: { slug: p.slug }, props: { slug: p.slug } }));
}

const { slug } = Astro.props as { slug: string };

const bootstrap = await getFrontendBootstrap();
const siteSettings = bootstrap.siteSettings;

const product = await getProduct(slug);
if (!product) {
  return new Response(null, { status: 404 });
}

const { siteInfo, styleSettings, navigation, secondaryNavigation } = bootstrap;
const siteName = siteInfo.siteName || SITE_TITLE;

const seoTitle = (product.seo_meta?.meta_title) || `${product.title} | ${siteName}`;
const seoDesc = (product.seo_meta?.meta_description) || product.excerpt || SITE_DESCRIPTION;

// Galerie : image featured + gallery
const images: Array<{ url: string; alt: string }> = [];
if (product.featured_image) {
  const fi: any = product.featured_image;
  const url = typeof fi === 'string' ? fi : (fi.sizes?.full || fi.url);
  if (url) images.push({ url, alt: product.title });
}
for (const img of (product.gallery || [])) {
  if (img.url && !images.find(i => i.url === img.url)) images.push({ url: img.url, alt: img.alt || product.title });
}
if (product.custom_fields?.gallery) {
  try {
    const gal = typeof product.custom_fields.gallery === 'string' ? JSON.parse(product.custom_fields.gallery) : product.custom_fields.gallery;
    if (Array.isArray(gal)) {
      for (const g of gal) {
        const url = typeof g === 'string' ? g : (g.url || g.sizes?.full);
        if (url && !images.find(i => i.url === url)) images.push({ url, alt: (typeof g === 'object' ? g.alt : '') || product.title });
      }
    }
  } catch {}
}

const schemaOrg: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.excerpt || '',
  sku: product.variants[0]?.sku,
  image: images.map(i => i.url),
  offers: {
    '@type': product.has_variants ? 'AggregateOffer' : 'Offer',
    priceCurrency: product.currency,
    ...(product.has_variants
      ? { lowPrice: (product.price_cents_min / 100).toFixed(2), highPrice: (product.price_cents_max / 100).toFixed(2), offerCount: product.variants.length }
      : { price: (product.price_cents_min / 100).toFixed(2) }),
    availability: product.in_stock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
};

const crumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Boutique', href: '/boutique' },
  ...(product.breadcrumb || []).map((c: any) => ({ label: c.name, href: `/boutique/categorie/${c.path}` })),
  { label: product.title },
];

let contentBlocks: any[] = [];
try {
  if (product.content) {
    const parsed = typeof product.content === 'string' ? JSON.parse(product.content) : product.content;
    if (Array.isArray(parsed)) contentBlocks = parsed;
  }
} catch {}

// Build hero/banner block from header_config (stored in custom_fields by admin).
const headerConfig = product.custom_fields?.header_config;
let headerBlock: any = null;
if (headerConfig && headerConfig.type && headerConfig.type !== 'none' && headerConfig.fields) {
  headerBlock = { type: headerConfig.type, data: { ...headerConfig.fields } };
}

const hasTopBanner = !!headerBlock;
const topBlock = headerBlock;
const restBlocks = contentBlocks;
const showBreadcrumb = product.custom_fields?.layout_config?.show_breadcrumb !== false;

---
<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={seoTitle} description={seoDesc} styleSettings={styleSettings} siteSettings={siteSettings} />
    <ModuleStyles blocks={[...(headerBlock ? [headerBlock] : []), ...contentBlocks]} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg).replace(/</g, '\\u003c')}></script>
  </head>
  <body data-pro-pricing={siteSettings.poolp_configurator_enabled === '1' ? '1' : undefined}>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} transparent={hasTopBanner} />

    <main id="main" class={`main-page shop-product${hasTopBanner ? ' has-top-banner' : ''}`} role="main">
      {topBlock && <BlockRenderer blocks={[topBlock]} />}
      <section>
        <div class="container-large" style="padding-top: 40px;">

        
          {showBreadcrumb && <Breadcrumb items={crumbs} />}

          <div class="shop-product__layout">
            <!-- Galerie -->
            <div class="shop-product__gallery">
              {images.length > 0 && (
                <>
                  <div class="shop-product__gallery-main" id="shopGalleryMainWrap" style="cursor:zoom-in">
                    <img src={optimizedImageUrl(images[0].url, 1200, 85)} alt={images[0].alt} id="shopGalleryMain" />
                  </div>
                  {images.length > 1 && (
                    <div class="shop-product__gallery-thumbs">
                      {images.map((img, i) => (
                        <button type="button" class={`shop-product__thumb ${i === 0 ? 'active' : ''}`} data-full-url={img.url}>
                          <img src={optimizedImageUrl(img.url, 200, 80)} alt={img.alt} />
                        </button>
                      ))}
                    </div>
                  )}
                </>
              )}
            </div>

            <!-- Infos -->
            <div class="shop-product__info">
              <h1 class="shop-product__title title-section-1">{product.title}</h1>
              {product.excerpt && <p class="shop-product__excerpt">{product.excerpt}</p>}

              <div class="shop-product__price" id="shopCurrentVariantPrice">
                <PriceDisplay
                  priceCents={product.price_cents_min}
                  priceCentsMax={product.has_variants ? product.price_cents_max : undefined}
                  priceHtCents={product.price_ht_cents_min}
                  priceHtCentsMax={product.has_variants ? product.price_ht_cents_max : undefined}
                  compareAtCents={product.compare_at_price_cents}
                  taxRate={product.tax_rate}
                />
              </div>

              <p class="shop-product__stock" id="shopCurrentVariantStock">
                {product.in_stock ? 'En stock' : 'Rupture de stock'}
              </p>

              <form id="shopProductForm" onsubmit="event.preventDefault()">
                <VariantSelector
                  variants={product.variants}
                  variantAttributes={(product.custom_fields?.attributes || [])
                    .filter((a: any) => a.used_for_variations)
                    .map((a: any) => ({ name: a.name, options: a.values || a.options || [] }))}
                  taxRate={product.tax_rate}
                />
                <AddToCartButton productSlug={product.slug} disabled={!product.in_stock} />
              </form>

              {(() => {
                let feats: any = product.short_features;
                if (typeof feats === 'string') {
                  try { feats = JSON.parse(feats); } catch { feats = []; }
                }
                if (!Array.isArray(feats) || feats.length === 0) return null;
                return (
                  <dl class="shop-product__features">
                    {feats.map((f: any) => (
                      <div class="shop-product__feature">
                        <dt>{f.label}</dt>
                        <dd>{f.value}</dd>
                      </div>
                    ))}
                  </dl>
                );
              })()}

              {(() => {
                const cf = product.custom_fields || {};
                const sku = product.variants?.[0]?.sku || cf.sku || null;
                const typeLabels = {
                  physical: 'Physique',
                  digital: 'Digital (téléchargement)',
                  service: 'Service / prestation',
                };
                const taxLabels = {
                  FR_STANDARD: 'TVA standard (20%)',
                  FR_REDUCED: 'TVA réduite (5,5%)',
                  FR_INTERMEDIATE: 'TVA intermédiaire (10%)',
                  FR_SUPER_REDUCED: 'TVA super-réduite (2,1%)',
                  FR_ZERO: 'Exonéré de TVA',
                };
                const weight = cf.weight_grams ? Number(cf.weight_grams) : null;
                const L = cf.dimensions_length ? Number(cf.dimensions_length) : null;
                const W = cf.dimensions_width ? Number(cf.dimensions_width) : null;
                const H = cf.dimensions_height ? Number(cf.dimensions_height) : null;
                const hasDims = L || W || H;
                const dimsStr = hasDims ? [L, W, H].map(v => v ? `${v}` : '—').join(' × ') + ' cm' : null;
                const weightStr = weight ? (weight >= 1000 ? `${(weight / 1000).toFixed(2)} kg` : `${weight} g`) : null;
                const rows: any[] = [];
                if (sku) rows.push({ label: 'Référence', value: sku });
                if (cf.type) rows.push({ label: 'Type', value: typeLabels[cf.type] || cf.type });
                if (cf.tax_code) rows.push({ label: 'TVA', value: taxLabels[cf.tax_code] || cf.tax_code });
                if (weightStr) rows.push({ label: 'Poids', value: weightStr });
                if (dimsStr) rows.push({ label: 'Dimensions (L × l × H)', value: dimsStr });
                if (cf.requires_shipping !== undefined && cf.type === 'physical') {
                  rows.push({ label: 'Livraison', value: cf.requires_shipping ? 'Requise' : 'Aucune (retrait)' });
                }
                if (cf.download_limit && cf.type === 'digital') {
                  rows.push({ label: 'Téléchargements max', value: cf.download_limit });
                }
                if (cf.debit_min || cf.debit_max) {
                  const dMin = cf.debit_min ? `${cf.debit_min}` : '—';
                  const dMax = cf.debit_max ? `${cf.debit_max}` : '—';
                  rows.push({ label: 'Débit', value: `${dMin} – ${dMax} m³/h` });
                }
                if (cf.volume_min || cf.volume_max) {
                  const vMin = cf.volume_min ? `${cf.volume_min}` : '—';
                  const vMax = cf.volume_max ? `${cf.volume_max}` : '—';
                  rows.push({ label: 'Volume bassin', value: `${vMin} – ${vMax} m³` });
                }
                if (cf.reference_constructeur) {
                  rows.push({ label: 'Réf. constructeur', value: cf.reference_constructeur });
                }
                if (rows.length === 0) return null;
                return (
                  <dl class="shop-product__specs">
                    {rows.map((r) => (
                      <div class="shop-product__feature">
                        <dt>{r.label}</dt>
                        <dd>{r.value}</dd>
                      </div>
                    ))}
                  </dl>
                );
              })()}
            </div>
          </div>

          {product.related && product.related.length > 0 && (
            <section class="shop-product__related">
              <h2 class="title title-section-2">Produits similaires</h2>
              <div class="shop-product__related-grid">
                {product.related.map((p) => <ProductCard product={p} />)}
              </div>
            </section>
          )}
        </div>
      </section>

      {restBlocks.length > 0 && (
        <section class="shop-product__description">
          <div class="container">
            <h2 class="title title-section-2">Description</h2>
          </div>
          <BlockRenderer blocks={restBlocks} />
        </section>
      )}
    </main>

    <!-- Lightbox fullscreen gallery -->
    <div id="shopLightbox" class="shop-lightbox" aria-hidden="true">
      <button type="button" class="shop-lightbox__close" aria-label="Fermer">&times;</button>
      {images.length > 1 && (
        <>
          <button type="button" class="shop-lightbox__nav shop-lightbox__prev" aria-label="Precedent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="shop-lightbox__nav shop-lightbox__next" aria-label="Suivant">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 6 15 12 9 18"/></svg>
          </button>
        </>
      )}
      <div class="shop-lightbox__stage">
        <img id="shopLightboxImg" src="" alt="" />
      </div>
      {images.length > 1 && (
        <div class="shop-lightbox__counter">
          <span id="shopLightboxCurrent">1</span> / {images.length}
        </div>
      )}
    </div>
    <script is:inline define:vars={{ lightboxImages: images }}>
      (function () {
        const lb = document.getElementById('shopLightbox');
        if (!lb) return;
        const img = document.getElementById('shopLightboxImg');
        const counter = document.getElementById('shopLightboxCurrent');
        const imgs = lightboxImages;
        let idx = 0;

        function optimizeUrl(url) {
          const m = url.match(/\/uploads\/media\/([^/?#]+)$/);
          return m ? '/uploads/media/_optimized/' + m[1] + '?w=1600&q=90&f=webp' : url;
        }

        function show(i) {
          idx = (i + imgs.length) % imgs.length;
          img.src = optimizeUrl(imgs[idx].url);
          img.alt = imgs[idx].alt || '';
          if (counter) counter.textContent = idx + 1;
        }

        function open(i) {
          show(i);
          lb.classList.add('is-open');
          lb.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        function close() {
          lb.classList.remove('is-open');
          lb.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }

        // Open on main image click
        var mainWrap = document.getElementById('shopGalleryMainWrap');
        if (mainWrap) {
          mainWrap.addEventListener('click', function () {
            var activeThumb = document.querySelector('.shop-product__thumb.active');
            var startIdx = 0;
            if (activeThumb) {
              var url = activeThumb.getAttribute('data-full-url');
              startIdx = imgs.findIndex(function (im) { return im.url === url; });
              if (startIdx < 0) startIdx = 0;
            }
            open(startIdx);
          });
        }

        // Nav
        var prev = lb.querySelector('.shop-lightbox__prev');
        var next = lb.querySelector('.shop-lightbox__next');
        if (prev) prev.addEventListener('click', function () { show(idx - 1); });
        if (next) next.addEventListener('click', function () { show(idx + 1); });

        // Close
        lb.querySelector('.shop-lightbox__close').addEventListener('click', close);
        lb.addEventListener('click', function (e) { if (e.target === lb || e.target.classList.contains('shop-lightbox__stage')) close(); });

        // Keyboard
        document.addEventListener('keydown', function (e) {
          if (!lb.classList.contains('is-open')) return;
          if (e.key === 'Escape') close();
          if (e.key === 'ArrowLeft') show(idx - 1);
          if (e.key === 'ArrowRight') show(idx + 1);
        });

        // Touch swipe
        var touchStartX = 0;
        lb.addEventListener('touchstart', function (e) { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
        lb.addEventListener('touchend', function (e) {
          var dx = e.changedTouches[0].clientX - touchStartX;
          if (Math.abs(dx) > 50) { dx > 0 ? show(idx - 1) : show(idx + 1); }
        });
      })();
    </script>

    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script is:inline>
      (function () {
        const main = document.getElementById('shopGalleryMain');
        if (!main) return;
        document.querySelectorAll('.shop-product__thumb').forEach(btn => {
          btn.addEventListener('click', () => {
            const url = btn.getAttribute('data-full-url');
            if (!url) return;
            const m = url.match(/\/uploads\/media\/([^/?#]+)$/);
            main.src = m ? `/uploads/media/_optimized/${m[1]}?w=1200&q=85&f=webp` : url;
            document.querySelectorAll('.shop-product__thumb').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
          });
        });
      })();
    </script>

    <style>
      .shop-product { padding: 40px 0 60px; }
      .shop-product.has-top-banner { padding-top: 0; }
      .shop-product.has-top-banner > .module-hero,
      .shop-product.has-top-banner > .module-banner-page { margin-bottom: 40px; }
      .shop-product__layout {
        display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 3rem;
      }
      .shop-product__gallery-main {
        position: relative; width: 100%; padding-top: 100%;
        background: var(--gray-100, #f3f4f6); border-radius: 10px; overflow: hidden;
      }
      .shop-product__gallery-main img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .shop-product__gallery-thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 12px; }
      .shop-product__thumb {
        width: 100%; padding: 0; border: 2px solid transparent; border-radius: 6px;
        overflow: hidden; background: none; cursor: pointer; aspect-ratio: 1;
      }
      .shop-product__thumb img { width: 100%; height: 100%; object-fit: cover; }
      .shop-product__thumb.active { border-color: var(--color-primary, #0f62fe); }
      .shop-product__title { margin: 0 0 10px; }
      .shop-product__excerpt { color: var(--gray-600, #4b5563); margin: 0 0 16px; }
      .shop-product__price { font-size: 1.4rem; margin: 16px 0 8px; }
      .shop-product__stock { font-size: 14px; color: var(--success, #059669); font-weight: 500; }
      .shop-product__stock.out { color: var(--danger, #dc2626); }
      .shop-product__features,
      .shop-product__specs {
        margin: 24px 0 0; padding: 16px; background: var(--gray-50, #f9fafb); border-radius: 8px;
      }
      .shop-product__specs { margin-top: 12px; }
      .shop-product__feature {
        display: flex; gap: 16px; padding: 6px 0; font-size: 14px;
        border-bottom: 1px solid var(--gray-200, #e5e7eb);
      }
      .shop-product__feature:last-child { border-bottom: 0; }
      .shop-product__feature dt { flex: 0 0 40%; font-weight: 600; color: var(--gray-700, #374151); margin: 0; }
      .shop-product__feature dd { margin: 0; color: var(--gray-600, #4b5563); }
      .shop-product__description { padding: 2rem 0; border-top: 1px solid var(--gray-200, #e5e7eb); }
      .shop-product__related { padding: 2rem 0; border-top: 1px solid var(--gray-200, #e5e7eb); }
      .shop-product__related-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 1rem;
      }
      @media (max-width: 800px) { .shop-product__layout { grid-template-columns: 1fr; } }

      /* Lightbox */
      .shop-lightbox {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.92); display: flex; align-items: center; justify-content: center;
        opacity: 0; visibility: hidden; transition: opacity .25s, visibility .25s;
      }
      .shop-lightbox.is-open { opacity: 1; visibility: visible; }
      .shop-lightbox__close {
        position: absolute; top: 16px; right: 20px; z-index: 2;
        background: none; border: none; color: #fff; font-size: 36px; cursor: pointer;
        line-height: 1; padding: 4px 10px;
      }
      .shop-lightbox__nav {
        position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
        background: rgba(255,255,255,.15); border: none; color: #fff; cursor: pointer;
        width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
        transition: background .2s;
      }
      .shop-lightbox__nav:hover { background: rgba(255,255,255,.3); }
      .shop-lightbox__nav svg { width: 24px; height: 24px; }
      .shop-lightbox__prev { left: 20px; }
      .shop-lightbox__next { right: 20px; }
      .shop-lightbox__stage {
        max-width: 90vw; max-height: 85vh; display: flex; align-items: center; justify-content: center;
      }
      .shop-lightbox__stage img {
        max-width: 90vw; max-height: 85vh; object-fit: contain; border-radius: 4px;
        user-select: none; -webkit-user-drag: none;
      }
      .shop-lightbox__counter {
        position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
        color: rgba(255,255,255,.7); font-size: 14px; font-weight: 500;
      }
    </style>
    <script is:inline define:vars={{ apiBase: import.meta.env.PUBLIC_API_URL || '/api' }}>
      (function() {
        if (document.body.dataset.proPricing !== '1') return;
        var token = localStorage.getItem('customer_token');
        if (!token) return;

        function revealHtPrices(rate) {
          document.querySelectorAll('.price-display').forEach(function(el) {
            var htEl = el.querySelector('.price-ht');
            if (!htEl) return;
            var htMin = parseInt(el.dataset.htMin || '0', 10);
            var currency = el.dataset.currency || 'EUR';
            if (htMin <= 0) return;
            var discounted = rate > 0 ? Math.round(htMin * (1 - rate / 100)) : htMin;
            var valueEl = htEl.querySelector('.price-ht-value');
            if (valueEl) valueEl.textContent = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: currency }).format(discounted / 100);
            if (rate > 0) {
              var dEl = htEl.querySelector('.price-ht-discount');
              if (dEl) { dEl.textContent = '(-' + rate + '%)'; dEl.style.display = ''; }
            }
            htEl.style.display = '';
            el.classList.add('is-pro');
          });
        }

        fetch(apiBase + '/customer/auth/me', { headers: { Authorization: 'Bearer ' + token } })
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(c) {
            if (!c || !c.is_pro || c.pro_status !== 'approved') return;
            var rate = c.discount_rate ? parseFloat(c.discount_rate) : 0;
            revealHtPrices(rate);
            // Re-run when variant selector updates price
            document.addEventListener('variant-price-updated', function() { revealHtPrices(rate); });
          })
          .catch(function() {});
      })();
    </script>
  </body>
</html>
