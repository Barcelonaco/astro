---
/**
 * /compte — customer dashboard (WooCommerce-style layout).
 */
import BaseHead from '@frontend/components/BaseHead.astro'
import Header from '@frontend/components/Header.astro'
import Footer from '@frontend/components/Footer.astro'
import SiteOverlays from '@frontend/components/SiteOverlays.astro'
import DeferredLoader from '@frontend/components/DeferredLoader.astro'
import AccountNav from '@plugins/ecommerce/frontend/components/AccountNav.astro'
import { SITE_TITLE } from '@frontend/consts'
import { getFrontendBootstrap } from '@frontend/lib/api'
import { setDefaultImageUrl } from '@frontend/lib/module-helpers'
import '@plugins/ecommerce/frontend/styles/account.css'

const { siteInfo, styleSettings, siteSettings, navigation, secondaryNavigation } = await getFrontendBootstrap()
const siteName = siteInfo.siteName || SITE_TITLE
setDefaultImageUrl(siteSettings.replacement_image || '')

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ')
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title={`Mon compte — ${siteName}`} description="Tableau de bord de votre compte" styleSettings={styleSettings} siteSettings={siteSettings} />
  </head>
  <body class={bodyClasses || undefined}>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />

    <main class="main-page account-wrap">
      <div class="account-container">
        <div class="account-layout">
          <AccountNav active="dashboard" />
          <div class="account-content">
            <div id="account-loading" class="account-loading">Chargement...</div>
            <div id="account-content-inner" style="display:none">
              <h1 class="account-greeting" id="greeting"></h1>
              <p class="account-desc">
                A partir du tableau de bord de votre compte, vous pouvez visualiser vos
                <a href="/compte/commandes">commandes recentes</a>, gerer vos
                <a href="/compte/adresses">adresses de livraison et de facturation</a>,
                et <a href="/compte/profil">changer votre mot de passe et les details de votre compte</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>

    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script>
      import { getMe, isLoggedIn } from '@plugins/ecommerce/frontend/lib/customer-api'

      if (!isLoggedIn()) window.location.href = '/compte/connexion'

      async function init() {
        try {
          const customer = await getMe()
          const name = (customer.first_name || customer.email?.split('@')[0] || '').trim()
          document.getElementById('greeting')!.textContent = `Bonjour ${name}`
          document.getElementById('account-loading')!.style.display = 'none'
          document.getElementById('account-content-inner')!.style.display = ''
        } catch (err: any) {
          if (err?.status === 401) { window.location.href = '/compte/connexion'; return }
          document.getElementById('account-loading')!.textContent = 'Erreur de chargement.'
        }
      }

      init()
    </script>
  </body>
</html>
