---
/**
 * /compte/connexion — login + register tabs.
 * Redirect to /compte if already logged in (client-side check).
 */
// Static page — auth + data fetched client-side
import BaseHead from "@frontend/components/BaseHead.astro";
import Header from "@frontend/components/Header.astro";
import Footer from "@frontend/components/Footer.astro";
import SiteOverlays from "@frontend/components/SiteOverlays.astro";
import DeferredLoader from "@frontend/components/DeferredLoader.astro";
import { SITE_TITLE } from "@frontend/consts";
import { getFrontendBootstrap } from "@frontend/lib/api";
import { setDefaultImageUrl } from "@frontend/lib/module-helpers";

const {
  siteInfo,
  styleSettings,
  siteSettings,
  navigation,
  secondaryNavigation,
} = await getFrontendBootstrap();
const siteName = siteInfo.siteName || SITE_TITLE;
setDefaultImageUrl(siteSettings.replacement_image || "");

const bodyClasses = [
  siteSettings.rounded === "1" ? "border-rounded" : "",
  siteSettings.uppercase === "1" ? "mode-uppercase" : "",
]
  .filter(Boolean)
  .join(" ");
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead
      title={`Connexion — ${siteName}`}
      description="Connectez-vous ou creez votre compte"
      styleSettings={styleSettings}
      siteSettings={siteSettings}
    />
    {siteSettings.recaptcha_site_key && <script is:inline src={`https://www.google.com/recaptcha/api.js?render=${siteSettings.recaptcha_site_key}`}></script>}
  </head>
  <body class={bodyClasses || undefined} data-recaptcha-key={siteSettings.recaptcha_site_key || ''}>
    <Header
      siteName={siteName}
      navigation={navigation}
      secondaryNavigation={secondaryNavigation}
      siteSettings={siteSettings}
      styleSettings={styleSettings}
    />

    <main class="main-page auth-wrap">
      <div class="auth-container">
        <!-- Tabs -->
        <div class="auth-tabs">
          <button class="auth-tab active" data-tab="login">Se connecter</button>
          <button class="auth-tab" data-tab="register">Créer un compte</button>
        </div>

        <!-- Login form -->
        <form id="login-form" class="auth-form" novalidate>
          <div class="auth-field">
            <label class="auth-label">Email</label>
            <input
              class="auth-input"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="votre@email.fr"
            />
          </div>
          <div class="auth-field">
            <label class="auth-label">Mot de passe</label>
            <div class="auth-pw-wrap">
              <input
                class="auth-input"
                type="password"
                name="password"
                required
                autocomplete="current-password"
                placeholder="••••••••"
              />
              <button
                type="button"
                class="auth-pw-toggle"
                aria-label="Afficher le mot de passe"
                ><svg
                  class="eye-open"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                ><svg
                  class="eye-closed"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  style="display:none"
                  ><path
                    d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                  ></path><path
                    d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"
                  ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
                ></button
              >
            </div>
          </div>
          <div
            class="auth-status"
            id="login-status"
            role="status"
            aria-live="polite"
          >
          </div>
          <button class="auth-submit" type="submit">Se connecter</button>
          <button type="button" class="auth-link" id="forgot-password-btn" style="background:none;border:none;cursor:pointer;font:inherit;color:inherit;text-decoration:underline">Mot de passe oublié ?</button>
          <div class="auth-alt">
            Vous êtes professionnel ? <a href="/inscription-pro"
              >Créer un compte pro</a
            >
          </div>
        </form>

        <!-- Register form -->
        <form
          id="register-form"
          class="auth-form"
          style="display:none"
          novalidate
        >
          <div class="auth-row">
            <div class="auth-field">
              <label class="auth-label">Prenom <em>*</em></label>
              <input
                class="auth-input"
                type="text"
                name="first_name"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="auth-field">
              <label class="auth-label">Nom <em>*</em></label>
              <input
                class="auth-input"
                type="text"
                name="last_name"
                required
                autocomplete="family-name"
              />
            </div>
          </div>
          <div class="auth-field">
            <label class="auth-label">Email <em>*</em></label>
            <input
              class="auth-input"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="votre@email.fr"
            />
          </div>
          <div class="auth-field">
            <label class="auth-label">Telephone</label>
            <input
              class="auth-input"
              type="tel"
              name="phone"
              autocomplete="tel"
            />
          </div>
          <div class="auth-row">
            <div class="auth-field">
              <label class="auth-label">Mot de passe <em>*</em></label>
              <div class="auth-pw-wrap">
                <input
                  class="auth-input"
                  type="password"
                  name="password"
                  minlength="8"
                  required
                  autocomplete="new-password"
                />
                <button
                  type="button"
                  class="auth-pw-toggle"
                  aria-label="Afficher le mot de passe"
                  ><svg
                    class="eye-open"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                    ></path><circle cx="12" cy="12" r="3"></circle></svg
                  ><svg
                    class="eye-closed"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="display:none"
                    ><path
                      d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                    ></path><path
                      d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"
                    ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
                  ></button
                >
              </div>
              <span class="auth-hint">8 caracteres minimum</span>
            </div>
            <div class="auth-field">
              <label class="auth-label">Confirmer <em>*</em></label>
              <div class="auth-pw-wrap">
                <input
                  class="auth-input"
                  type="password"
                  name="password_confirm"
                  minlength="8"
                  required
                  autocomplete="new-password"
                />
                <button
                  type="button"
                  class="auth-pw-toggle"
                  aria-label="Afficher le mot de passe"
                  ><svg
                    class="eye-open"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                    ></path><circle cx="12" cy="12" r="3"></circle></svg
                  ><svg
                    class="eye-closed"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="display:none"
                    ><path
                      d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                    ></path><path
                      d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"
                    ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
                  ></button
                >
              </div>
            </div>
          </div>
          <label class="auth-check">
            <input type="checkbox" name="accepts_marketing" />
            <span>Recevoir les actualites et offres</span>
          </label>
          <div
            class="auth-status"
            id="register-status"
            role="status"
            aria-live="polite"
          >
          </div>
          <button class="auth-submit" type="submit">Creer mon compte</button>
          <div class="auth-alt">
            Vous êtes professionnel ? <a href="/inscription-pro"
              >Créer un compte pro</a
            >
          </div>
        </form>

        <!-- Separator -->
        <div class="auth-separator">
          <span>ou</span>
        </div>

        <!-- Order tracking (guest) -->
        <div class="auth-tracking">
          <h3 class="auth-tracking-title">Suivi de commande</h3>
          <p class="auth-tracking-desc">
            Vous avez passe une commande sans creer de compte ? Retrouvez-la
            ici.
          </p>
          <div id="tracking-result" style="display:none"></div>
          <form id="tracking-form" class="auth-form" novalidate>
            <div class="auth-row">
              <div class="auth-field">
                <label class="auth-label">N° de commande</label>
                <input
                  class="auth-input"
                  type="text"
                  name="number"
                  required
                  placeholder="CMD-250511-A1B2C3"
                />
              </div>
              <div class="auth-field">
                <label class="auth-label"
                  >Email utilisé lors de la commande</label
                >
                <input
                  class="auth-input"
                  type="email"
                  name="email"
                  required
                  placeholder="votre@email.fr"
                />
              </div>
            </div>
            <div
              class="auth-status"
              id="tracking-status"
              role="status"
              aria-live="polite"
            >
            </div>
            <button class="auth-submit auth-submit-outline" type="submit"
              >Rechercher ma commande</button
            >
          </form>
        </div>
      </div>
    </main>

    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script>
      import {
        login,
        register,
        forgotPassword,
        trackOrder,
        isLoggedIn,
        formatPrice,
        formatDate,
        formatDateTime,
        STATUS_LABELS,
        PAYMENT_STATUS_LABELS,
        type ApiError,
      } from "@plugins/ecommerce/frontend/lib/customer-api";

      // Redirect if already logged in
      if (isLoggedIn()) window.location.href = "/compte";

      // Tab switching
      const tabs = document.querySelectorAll<HTMLButtonElement>(".auth-tab");
      const loginForm = document.getElementById(
        "login-form",
      ) as HTMLFormElement;
      const registerForm = document.getElementById(
        "register-form",
      ) as HTMLFormElement;
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => t.classList.remove("active"));
          tab.classList.add("active");
          loginForm.style.display = tab.dataset.tab === "login" ? "" : "none";
          registerForm.style.display =
            tab.dataset.tab === "register" ? "" : "none";
        });
      });

      // Check URL params for tab
      const params = new URLSearchParams(window.location.search);
      if (params.get("tab") === "register") {
        tabs.forEach((t) =>
          t.classList.toggle("active", t.dataset.tab === "register"),
        );
        loginForm.style.display = "none";
        registerForm.style.display = "";
      }

      // Password visibility toggle
      document
        .querySelectorAll<HTMLButtonElement>(".auth-pw-toggle")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            const wrap = btn.closest(".auth-pw-wrap")!;
            const input = wrap.querySelector("input")!;
            const isVisible = input.type === "text";
            input.type = isVisible ? "password" : "text";
            btn.querySelector<SVGElement>(".eye-open")!.style.display =
              isVisible ? "" : "none";
            btn.querySelector<SVGElement>(".eye-closed")!.style.display =
              isVisible ? "none" : "";
          });
        });

      function setStatus(
        id: string,
        msg: string,
        kind: "error" | "success" | "" = "",
      ) {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = msg;
        el.dataset.kind = kind;
      }

      // Login
      loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(loginForm);
        const btn = loginForm.querySelector(
          "button[type=submit]",
        ) as HTMLButtonElement;
        btn.disabled = true;
        setStatus("login-status", "");
        try {
          await login(String(fd.get("email")), String(fd.get("password")));
          setStatus(
            "login-status",
            "Connexion reussie. Redirection...",
            "success",
          );
          const redirect = params.get("redirect") || "/compte";
          setTimeout(() => {
            window.location.href = redirect;
          }, 500);
        } catch (err: any) {
          setStatus(
            "login-status",
            err?.message || "Erreur de connexion",
            "error",
          );
          btn.disabled = false;
        }
      });

      // Forgot password modal
      document.getElementById("forgot-password-btn")?.addEventListener("click", () => {
        const overlay = document.createElement("div");
        overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center";
        overlay.innerHTML = `
          <div style="background:#fff;border-radius:12px;padding:28px 32px;max-width:420px;width:90%;font-family:inherit">
            <h3 style="margin:0 0 8px;font-size:16px;font-weight:700">Mot de passe oublié ?</h3>
            <p style="font-size:13px;color:#6b6b67;margin:0 0 20px;line-height:1.5">Merci de renseigner votre adresse e-mail. Vous recevrez un e-mail contenant les instructions vous permettant de réinitialiser votre mot de passe.</p>
            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;color:#6b6b67;margin-bottom:5px">Adresse e-mail</label>
              <input type="email" id="forgot-email" class="auth-input" placeholder="votre@email.fr" style="width:100%" required>
            </div>
            <div id="forgot-status" style="font-size:12px;min-height:1.2em;margin-bottom:12px"></div>
            <div style="display:flex;gap:10px">
              <button type="button" id="forgot-submit" class="auth-submit" style="flex:1">Réinitialiser mon mot de passe</button>
              <button type="button" id="forgot-cancel" style="flex:0;padding:10px 16px;border:1px solid rgba(0,0,0,0.18);border-radius:8px;background:#fff;font-size:13px;cursor:pointer;font-family:inherit">Annuler</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);

        const emailInput = overlay.querySelector<HTMLInputElement>("#forgot-email")!;
        const statusEl = overlay.querySelector<HTMLElement>("#forgot-status")!;
        const submitBtn = overlay.querySelector<HTMLButtonElement>("#forgot-submit")!;

        const close = () => overlay.remove();
        overlay.querySelector("#forgot-cancel")!.addEventListener("click", close);
        overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
        emailInput.focus();

        submitBtn.addEventListener("click", async () => {
          const email = emailInput.value.trim();
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            statusEl.textContent = "Veuillez saisir une adresse e-mail valide.";
            statusEl.style.color = "#d32f2f";
            emailInput.style.borderColor = "#d32f2f";
            return;
          }
          submitBtn.disabled = true;
          statusEl.textContent = "Envoi en cours…";
          statusEl.style.color = "#6b6b67";
          try {
            await forgotPassword(email);
            statusEl.textContent = "Si un compte existe avec cette adresse, un e-mail de réinitialisation a été envoyé.";
            statusEl.style.color = "#276022";
            submitBtn.textContent = "Envoyé";
            setTimeout(close, 3000);
          } catch (err: any) {
            statusEl.textContent = err?.message || "Erreur lors de l'envoi.";
            statusEl.style.color = "#d32f2f";
            submitBtn.disabled = false;
          }
        });
      });

      // Register
      registerForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(registerForm);
        const pw = String(fd.get("password"));
        if (pw !== String(fd.get("password_confirm"))) {
          setStatus(
            "register-status",
            "Les mots de passe ne correspondent pas.",
            "error",
          );
          return;
        }
        if (pw.length < 8) {
          setStatus(
            "register-status",
            "Le mot de passe doit contenir au moins 8 caracteres.",
            "error",
          );
          return;
        }
        const btn = registerForm.querySelector(
          "button[type=submit]",
        ) as HTMLButtonElement;
        btn.disabled = true;
        setStatus("register-status", "");
        try {
          await register({
            email: String(fd.get("email")).trim(),
            password: pw,
            first_name: String(fd.get("first_name")).trim(),
            last_name: String(fd.get("last_name")).trim(),
            phone: String(fd.get("phone")).trim(),
            accepts_marketing: !!fd.get("accepts_marketing"),
          });
          setStatus(
            "register-status",
            "Compte cree. Redirection...",
            "success",
          );
          const redirect = params.get("redirect") || "/compte";
          setTimeout(() => {
            window.location.href = redirect;
          }, 500);
        } catch (err: any) {
          if (err?.status === 409) {
            setStatus("register-status", "");
            const statusEl = document.getElementById("register-status")!;
            statusEl.innerHTML =
              'Un compte existe deja avec cet email. <a href="#" id="switch-to-login" style="color:inherit;font-weight:600;text-decoration:underline">Se connecter</a>';
            statusEl.dataset.kind = "error";
            document
              .getElementById("switch-to-login")
              ?.addEventListener("click", (e) => {
                e.preventDefault();
                // Switch to login tab and prefill email
                tabs.forEach((t) =>
                  t.classList.toggle("active", t.dataset.tab === "login"),
                );
                loginForm.style.display = "";
                registerForm.style.display = "none";
                const loginEmail = loginForm.querySelector(
                  'input[name="email"]',
                ) as HTMLInputElement;
                if (loginEmail)
                  loginEmail.value = String(fd.get("email") || "");
                loginEmail?.focus();
              });
          } else {
            setStatus(
              "register-status",
              err?.message || "Erreur lors de la creation",
              "error",
            );
          }
          btn.disabled = false;
        }
      });

      // Order tracking
      const trackingForm = document.getElementById(
        "tracking-form",
      ) as HTMLFormElement;
      trackingForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(trackingForm);
        const number = String(fd.get("number") || "").trim();
        const email = String(fd.get("email") || "").trim();
        if (!number || !email) {
          setStatus(
            "tracking-status",
            "Veuillez remplir les deux champs.",
            "error",
          );
          return;
        }
        const btn = trackingForm.querySelector(
          "button[type=submit]",
        ) as HTMLButtonElement;
        btn.disabled = true;
        setStatus("tracking-status", "");
        try {
          const o = await trackOrder(number, email);
          setStatus("tracking-status", "", "");
          // Render order detail inline
          const payLabels: Record<string, string> = {
            stripe: "Carte bancaire",
            bank_transfer: "Virement",
            on_invoice: "Sur facture",
            paypal: "PayPal",
          };
          function fmtAddr(a: any): string {
            if (!a) return "-";
            return [
              `${a.first_name || ""} ${a.last_name || ""}`.trim(),
              a.company,
              a.address_line1,
              a.address_line2,
              `${a.postcode || ""} ${a.city || ""}`.trim(),
              a.country_code,
            ]
              .filter(Boolean)
              .join(", ");
          }
          const trackResult = document.getElementById("tracking-result")!;
          trackResult.style.display = "";
          trackResult.innerHTML = `
            <div class="track-order">
              <div class="track-header">
                <strong style="font-family:monospace;font-size:16px">${o.order_number}</strong>
                <span class="badge badge-${o.status}">${STATUS_LABELS[o.status] || o.status}</span>
                <span class="badge badge-${o.payment_status}">${PAYMENT_STATUS_LABELS[o.payment_status] || o.payment_status}</span>
                <span style="color:var(--color-text-muted,#6b6b67);font-size:12px;margin-left:auto">${formatDateTime(o.placed_at)}</span>
              </div>
              <table class="track-table">
                <thead><tr><th>Article</th><th>Qte</th><th>Total</th></tr></thead>
                <tbody>${(o.items || []).map((i: any) => `<tr><td>${i.product_title}</td><td>${i.quantity}</td><td>${formatPrice(i.line_total_cents)}</td></tr>`).join("")}</tbody>
              </table>
              <div class="track-totals">
                <div><span>Sous-total</span><span>${formatPrice(o.subtotal_cents)}</span></div>
                <div><span>Livraison</span><span>${formatPrice(o.shipping_cents)}</span></div>
                <div><span>TVA</span><span>${formatPrice(o.tax_cents)}</span></div>
                <div class="track-total-main"><span>Total TTC</span><span>${formatPrice(o.total_cents, o.currency)}</span></div>
              </div>
              <div style="font-size:13px;margin-top:12px;color:var(--color-text-muted,#6b6b67)">
                <div><strong>Paiement :</strong> ${payLabels[o.payment_method] || o.payment_method}</div>
                <div><strong>Livraison :</strong> ${fmtAddr(o.shipping_address)}</div>
              </div>
            </div>
          `;
          trackingForm.style.display = "none";
        } catch (err: any) {
          setStatus(
            "tracking-status",
            err?.message || "Aucune commande trouvee avec ces informations.",
            "error",
          );
          btn.disabled = false;
        }
      });
    </script>

    <style is:global>
      .auth-wrap {
        width: 100%;
        padding: 40px 0 60px;
      }
      .auth-container {
        max-width: 520px;
        margin: 0 auto;
        padding: 0 20px;
      }

      .auth-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 28px;
        border-bottom: 2px solid rgba(0, 0, 0, 0.1);
      }
      .auth-tab {
        flex: 1;
        padding: 12px 0;
        background: none;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        color: var(--color-text-muted, #6b6b67);
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        font-family: inherit;
      }
      .auth-tab.active {
        color: inherit;
        border-bottom-color: var(--accent, #1a1a18);
      }

      .auth-form {
      }
      .auth-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 500px) {
        .auth-row {
          grid-template-columns: 1fr;
        }
      }

      .auth-field {
