---
/**
 * /compte/reset-password — reset password form.
 * Token is read from URL path: /compte/reset-password/TOKEN
 * The PHP router serves this page for all /compte/reset-password/* paths.
 */
import BaseHead from '@frontend/components/BaseHead.astro'
import Header from '@frontend/components/Header.astro'
import Footer from '@frontend/components/Footer.astro'
import SiteOverlays from '@frontend/components/SiteOverlays.astro'
import DeferredLoader from '@frontend/components/DeferredLoader.astro'
import { SITE_TITLE } from '@frontend/consts'
import { getFrontendBootstrap } from '@frontend/lib/api'
import { setDefaultImageUrl } from '@frontend/lib/module-helpers'
import '@plugins/ecommerce/frontend/styles/account.css'

const { siteInfo, styleSettings, siteSettings, navigation, secondaryNavigation } = await getFrontendBootstrap()
const siteName = siteInfo.siteName || SITE_TITLE
setDefaultImageUrl(siteSettings.replacement_image || '')

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ')
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title={`Réinitialiser le mot de passe — ${siteName}`} description="Choisissez un nouveau mot de passe" styleSettings={styleSettings} siteSettings={siteSettings} />
  </head>
  <body class={bodyClasses || undefined}>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />

    <main class="main-page account-wrap">
      <div class="account-container" style="max-width:440px;margin:0 auto;padding:60px 24px 80px">
        <h1 style="font-size:22px;font-weight:700;margin:0 0 8px">Nouveau mot de passe</h1>
        <p style="font-size:13px;color:var(--color-text-muted,#6b6b67);margin:0 0 28px">Choisissez un nouveau mot de passe pour votre compte.</p>

        <form id="reset-form" novalidate>
          <div class="account-form-field">
            <label class="account-form-label">Nouveau mot de passe</label>
            <div class="auth-pw-wrap">
              <input class="account-form-input" type="password" name="password" minlength="8" required autocomplete="new-password" placeholder="8 caracteres minimum" />
              <button type="button" class="auth-pw-toggle" aria-label="Afficher le mot de passe"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button>
            </div>
          </div>
          <div class="account-form-field" style="margin-top:16px">
            <label class="account-form-label">Confirmer le mot de passe</label>
            <div class="auth-pw-wrap">
              <input class="account-form-input" type="password" name="password_confirm" minlength="8" required autocomplete="new-password" />
              <button type="button" class="auth-pw-toggle" aria-label="Afficher le mot de passe"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button>
            </div>
          </div>
          <div class="account-form-status" id="reset-status" role="status" style="margin-top:12px"></div>
          <button class="account-btn" type="submit" style="margin-top:16px;width:100%">Reinitialiser le mot de passe</button>
        </form>

        <p style="margin-top:24px;font-size:13px;text-align:center">
          <a href="/compte/connexion" style="color:inherit">Retour a la connexion</a>
        </p>
      </div>
    </main>

    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script>
      import { resetPassword } from '@plugins/ecommerce/frontend/lib/customer-api'

      const form = document.getElementById('reset-form') as HTMLFormElement
      const statusEl = document.getElementById('reset-status')!
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement

      // Extract token from URL path: /compte/reset-password/TOKEN
      const pathParts = window.location.pathname.split('/')
      const token = pathParts[pathParts.length - 1] || pathParts[pathParts.length - 2] || ''

      if (!token || !/^[a-f0-9]{64}$/.test(token)) {
        statusEl.textContent = 'Lien invalide ou expire.'
        statusEl.dataset.kind = 'error'
        btn.disabled = true
      }

      // Password toggle
      document.querySelectorAll<HTMLButtonElement>('.auth-pw-toggle').forEach(b => {
        b.addEventListener('click', () => {
          const wrap = b.closest('.auth-pw-wrap')!
          const input = wrap.querySelector('input')!
          const vis = input.type === 'text'
          input.type = vis ? 'password' : 'text'
          b.querySelector<SVGElement>('.eye-open')!.style.display = vis ? '' : 'none'
          b.querySelector<SVGElement>('.eye-closed')!.style.display = vis ? 'none' : ''
        })
      })

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        const fd = new FormData(form)
        const pw = String(fd.get('password') || '')
        const confirm = String(fd.get('password_confirm') || '')

        if (pw.length < 8) {
          statusEl.textContent = 'Le mot de passe doit contenir au moins 8 caracteres.'
          statusEl.dataset.kind = 'error'
          return
        }
        if (pw !== confirm) {
          statusEl.textContent = 'Les mots de passe ne correspondent pas.'
          statusEl.dataset.kind = 'error'
          return
        }

        btn.disabled = true
        statusEl.textContent = ''

        try {
          await resetPassword(token, pw)
          statusEl.textContent = 'Mot de passe reinitialise. Redirection...'
          statusEl.dataset.kind = 'success'
          setTimeout(() => { window.location.href = '/compte/connexion' }, 1500)
        } catch (err: any) {
          statusEl.textContent = err?.message || 'Erreur lors de la reinitialisation.'
          statusEl.dataset.kind = 'error'
          btn.disabled = false
        }
      })
    </script>
  </body>
</html>
