---
/**
 * /compte/commandes — order history list.
 */
import BaseHead from '@frontend/components/BaseHead.astro'
import Header from '@frontend/components/Header.astro'
import Footer from '@frontend/components/Footer.astro'
import SiteOverlays from '@frontend/components/SiteOverlays.astro'
import DeferredLoader from '@frontend/components/DeferredLoader.astro'
import AccountNav from '@plugins/ecommerce/frontend/components/AccountNav.astro'
import { SITE_TITLE } from '@frontend/consts'
import { getFrontendBootstrap } from '@frontend/lib/api'
import { setDefaultImageUrl } from '@frontend/lib/module-helpers'
import '@plugins/ecommerce/frontend/styles/account.css'

const { siteInfo, styleSettings, siteSettings, navigation, secondaryNavigation } = await getFrontendBootstrap()
const siteName = siteInfo.siteName || SITE_TITLE
setDefaultImageUrl(siteSettings.replacement_image || '')

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ')
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title={`Mes commandes — ${siteName}`} description="Historique de vos commandes" styleSettings={styleSettings} siteSettings={siteSettings} />
  </head>
  <body class={bodyClasses || undefined}>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />

    <main class="main-page account-wrap">
      <div class="account-container">
        <div class="account-layout">
          <AccountNav active="orders" />
          <div class="account-content">
            <h1 class="account-section-title">Commandes</h1>
            <div id="orders-loading" class="account-loading">Chargement...</div>
            <div id="orders-empty" style="display:none" class="account-empty">
              <p>Vous n'avez pas encore passe de commande.</p>
              <a href="/boutique" class="account-btn" style="margin-top:12px">Decouvrir la boutique</a>
            </div>
            <div id="orders-list" style="display:none"></div>
          </div>
        </div>
      </div>
    </main>

    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script>
      import { getMyOrders, isLoggedIn, formatPrice, formatDate, STATUS_LABELS, PAYMENT_STATUS_LABELS } from '@plugins/ecommerce/frontend/lib/customer-api'

      if (!isLoggedIn()) window.location.href = '/compte/connexion?redirect=/compte/commandes'

      async function init() {
        try {
          const data = await getMyOrders()
          const orders = data.orders || []
          document.getElementById('orders-loading')!.style.display = 'none'

          if (orders.length === 0) {
            document.getElementById('orders-empty')!.style.display = ''
            return
          }

          const list = document.getElementById('orders-list')!
          list.style.display = ''
          list.innerHTML = `
            <table class="account-table">
              <thead>
                <tr>
                  <th>Commande</th>
                  <th>Date</th>
                  <th>Statut</th>
                  <th>Total</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                ${orders.map(o => `
                  <tr>
                    <td style="font-family:monospace;font-weight:600;font-size:13px">${o.order_number}</td>
                    <td>${formatDate(o.placed_at)}</td>
                    <td>
                      <span class="badge badge-${o.status}">${STATUS_LABELS[o.status] || o.status}</span>
                      ${o.tracking_url ? `<a href="${o.tracking_url}" target="_blank" rel="noopener" style="display:inline-block;margin-left:6px;font-size:11px;color:var(--color-primary,#2563eb)">Suivi</a>` : ''}
                    </td>
                    <td style="font-weight:600">${formatPrice(o.total_cents, o.currency)}</td>
                    <td><a href="/compte/commandes/detail?n=${encodeURIComponent(o.order_number)}">Voir</a></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          `
        } catch (err: any) {
          if (err?.status === 401) { window.location.href = '/compte/connexion'; return }
          document.getElementById('orders-loading')!.textContent = 'Erreur de chargement.'
        }
      }

      init()
    </script>
  </body>
</html>
