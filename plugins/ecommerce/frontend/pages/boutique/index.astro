---
import BaseHead from '@frontend/components/BaseHead.astro';
import Header from '@frontend/components/Header.astro';
import Footer from '@frontend/components/Footer.astro';
import DeferredLoader from '@frontend/components/DeferredLoader.astro';
import SiteOverlays from '@frontend/components/SiteOverlays.astro';
import ModuleStyles from '@frontend/components/ModuleStyles.astro';
import ProductGrid from '@plugins/ecommerce/frontend/components/ProductGrid.astro';
import FilterSidebar from '@plugins/ecommerce/frontend/components/FilterSidebar.astro';
import SortDropdown from '@plugins/ecommerce/frontend/components/SortDropdown.astro';
import Pagination from '@plugins/ecommerce/frontend/components/Pagination.astro';
import Breadcrumb from '@plugins/ecommerce/frontend/components/Breadcrumb.astro';
import { getFrontendBootstrap } from '@frontend/lib/api';
import { listProducts, getShopFacets, getCategoryTree } from '@plugins/ecommerce/frontend/lib/shop-api';
import { SITE_TITLE, SITE_DESCRIPTION } from '@frontend/consts';
import '@plugins/ecommerce/frontend/styles/shop-buttons.css';

// SSG : page 1 sans filtre. Les filtres s'appliquent en client-side via query params
// (JS hydraté dans FilterSidebar/SortDropdown rechargent la page avec ?search=...&sort=...).

const bootstrap = await getFrontendBootstrap();
const siteSettings = bootstrap.siteSettings;

const [result, facets, tree] = await Promise.all([
  listProducts({ page: 1, per_page: 24, sort: 'newest' }),
  getShopFacets({}),
  getCategoryTree(true),
]);

const { siteInfo, styleSettings, navigation, secondaryNavigation } = bootstrap;
const siteName = siteInfo.siteName || SITE_TITLE;
const siteDescription = siteInfo.siteDescription || SITE_DESCRIPTION;
---
<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`Boutique | ${siteName}`} description={siteDescription} styleSettings={styleSettings} siteSettings={siteSettings} />
    <ModuleStyles blocks={null} />
  </head>
  <body data-pro-pricing={siteSettings.poolp_configurator_enabled === '1' ? '1' : undefined}>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
    <main id="main" class="main-page shop-archive" role="main">
      <section>
        <div class="container-large">
          <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Boutique' }]} />

          <header class="shop-archive__header">
            <h1 class="shop-archive__title">Boutique</h1>
          </header>

          <div class="shop-archive__layout">
            <FilterSidebar categories={tree} facets={facets} baseUrl="/boutique" />

            <div class="shop-archive__content">
              <div class="shop-archive__toolbar">
                <p class="shop-archive__count" data-shop-count>
                  <strong>{result.total}</strong> produit{result.total > 1 ? 's' : ''}
                </p>
                <SortDropdown active="newest" />
              </div>

              <div data-shop-grid>
                <ProductGrid products={result.data} />
              </div>

              <div data-shop-pagination>
                <Pagination currentPage={result.page} totalPages={result.pages} />
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script is:inline>
      (function () {
        const API_URL = (window.__SHOP_API__ = window.location.origin.replace(/:4321$/, ':3000') + '/api');
        const root = document.querySelector('main.shop-archive');
        if (!root) return;
        const gridEl = root.querySelector('[data-shop-grid]');
        const pagEl = root.querySelector('[data-shop-pagination]');
        const countEl = root.querySelector('[data-shop-count]');
        const categorySlug = root.getAttribute('data-category-slug') || null;

        // Ne rien faire si pas de params → SSG page 1 déjà correct
        const url = new URL(window.location.href);
        if (!url.search) return;

        const params = new URLSearchParams();
        if (categorySlug) params.set('category', categorySlug);
        if (categorySlug) params.set('include_subcategories', '1');
        for (const [k, v] of url.searchParams.entries()) {
          if (v) params.set(k, v);
        }
        if (!params.has('per_page')) params.set('per_page', '24');
        if (!params.has('page')) params.set('page', '1');

        fetch(`${API_URL}/shop/products?${params.toString()}`)
          .then(r => r.json())
          .then(result => {
            if (countEl) countEl.textContent = `${result.total} produit${result.total > 1 ? 's' : ''}`;
            if (gridEl) gridEl.innerHTML = renderGrid(result.data);
            if (pagEl) pagEl.innerHTML = renderPagination(result.page, result.pages, url);
          })
          .catch(err => console.error('Shop filter error:', err));

        function renderGrid(items) {
          if (!items || !items.length) return '<div class="shop-product-grid__empty"><p>Aucun produit ne correspond à votre recherche.</p></div>';
          return '<div class="shop-product-grid">' + items.map(renderCard).join('') + '</div>';
        }
        function renderCard(p) {
          const img = p.featured_image && (typeof p.featured_image === 'string' ? p.featured_image : (p.featured_image.sizes?.half || p.featured_image.url || ''));
          const imgTag = img
            ? `<img src="${optImg(img)}" alt="${esc(p.title)}" class="shop-product-card__image" loading="lazy" />`
            : '<div class="shop-product-card__image-placeholder"></div>';
          const fmt = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' });
          const priceHtml = p.has_variants
            ? `À partir de <strong>${fmt.format(p.price_cents_min / 100)}</strong>`
            : `<strong>${fmt.format(p.price_cents_min / 100)}</strong>`;
          const comparable = p.compare_at_price_cents && p.compare_at_price_cents > p.price_cents_min;
          const comparable_html = comparable ? `<span class="price-compare">${fmt.format(p.compare_at_price_cents / 100)}</span> ` : '';
          const cat = (p.categories && p.categories[0]) ? p.categories[0].name : '';
          return `
            <article class="shop-product-card">
              <a href="/produits/${p.slug}" class="shop-product-card__link">
                <div class="shop-product-card__image-wrapper">${imgTag}${!p.in_stock ? '<span class="shop-product-card__badge shop-product-card__badge--out">Rupture</span>' : ''}</div>
                <div class="shop-product-card__body">
                  ${cat ? `<p class="shop-product-card__category">${esc(cat)}</p>` : ''}
                  <h3 class="shop-product-card__title">${esc(p.title)}</h3>
                  ${p.excerpt ? `<p class="shop-product-card__excerpt">${esc(p.excerpt)}</p>` : ''}
                  <div class="shop-product-card__price"><div class="price-display">${comparable_html}<span class="price-current">${priceHtml}</span></div></div>
                </div>
              </a>
            </article>`;
        }
        function renderPagination(current, total, baseUrl) {
          if (total <= 1) return '';
          function link(page) {
            const p = new URLSearchParams(baseUrl.search);
            if (page === 1) p.delete('page'); else p.set('page', String(page));
            return baseUrl.pathname + (p.toString() ? '?' + p.toString() : '');
          }
          let html = '<nav class="shop-pagination">';
          if (current > 1) html += `<a href="${link(current - 1)}" class="shop-pagination__btn">‹ Précédent</a>`;
          for (let p = 1; p <= total; p++) {
            html += `<a href="${link(p)}" class="shop-pagination__btn ${p === current ? 'active' : ''}">${p}</a>`;
          }
          if (current < total) html += `<a href="${link(current + 1)}" class="shop-pagination__btn">Suivant ›</a>`;
          html += '</nav>';
          return html;
        }
        function optImg(u) {
          const m = u.match(/\/uploads\/media\/([^/?#]+)$/);
          return m ? `/uploads/media/_optimized/${m[1]}?w=600&q=80&f=webp` : u;
        }
        function esc(s) {
          return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
      })();
    </script>

    <style>
      .shop-archive { padding: 30px 0 60px; }
      .shop-archive__header { margin-bottom: 1.25rem; }
      .shop-archive__title {
        margin: 0;
        font-size: clamp(1.75rem, 3vw, 2.25rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--color-default, #224f5a);
      }
      .shop-archive__count { margin: 0; font-size: 14px; color: var(--gray-600, #4b5563); }
      .shop-archive__count strong { color: var(--color-default, #224f5a); }
      .shop-archive__layout { display: grid; grid-template-columns: 260px 1fr; gap: 30px; align-items: start; }
      .shop-archive__content { min-width: 0; }
      .shop-archive__toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        background: #fff;
        border: 1px solid var(--gray-200, #e5e7eb);
        border-radius: 10px;
        margin-bottom: 1rem;
      }
      @media (max-width: 900px) {
        .shop-archive__layout { grid-template-columns: 1fr; }
        .shop-archive__toolbar { flex-wrap: wrap; }
      }
      /* Grille + carte : dupliqué ici car le JS client (tri/filtre) injecte du HTML
         brut via innerHTML et les styles scoped Astro ne s'appliquent pas. */
      .shop-product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 260px));
        justify-content: start;
        gap: 20px;
      }
      .shop-product-grid__empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 60px 20px; text-align: center; color: var(--gray-500, #6b7280);
        background: var(--gray-50, #f9fafb); border: 1px dashed var(--gray-200, #e5e7eb); border-radius: 12px;
      }
    </style>
    <script is:inline define:vars={{ apiBase: import.meta.env.PUBLIC_API_URL || '/api' }}>
      (function() {
        if (document.body.dataset.proPricing !== '1') return;
        var token = localStorage.getItem('customer_token');
        if (!token) return;
        fetch(apiBase + '/customer/auth/me', { headers: { Authorization: 'Bearer ' + token } })
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(c) {
            if (!c || !c.is_pro || c.pro_status !== 'approved') return;
            var rate = c.discount_rate ? parseFloat(c.discount_rate) : 0;
            document.querySelectorAll('.price-display').forEach(function(el) {
              var htEl = el.querySelector('.price-ht');
              if (!htEl) return;
              var htMin = parseInt(el.dataset.htMin || '0', 10);
              var currency = el.dataset.currency || 'EUR';
              if (htMin <= 0) return;
              var discounted = rate > 0 ? Math.round(htMin * (1 - rate / 100)) : htMin;
              var valueEl = htEl.querySelector('.price-ht-value');
              if (valueEl) valueEl.textContent = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: currency }).format(discounted / 100);
              if (rate > 0) {
                var dEl = htEl.querySelector('.price-ht-discount');
                if (dEl) { dEl.textContent = '(-' + rate + '%)'; dEl.style.display = ''; }
              }
              htEl.style.display = '';
              el.classList.add('is-pro');
            });
          })
          .catch(function() {});
      })();
    </script>
  </body>
</html>
