<script is:inline>
(function() {
  var btn = document.getElementById('addToCal');
  var dropdown = document.getElementById('atcDropdown');
  if (!btn || !dropdown) return;

  var start = btn.getAttribute('data-atc-start') || '';
  var end = btn.getAttribute('data-atc-end') || '';
  var title = btn.getAttribute('data-atc-title') || '';
  var desc = btn.getAttribute('data-atc-description') || '';
  var loc = btn.getAttribute('data-atc-location') || '';

  // Toggle dropdown
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    dropdown.classList.toggle('open');
  });
  document.addEventListener('click', function() {
    dropdown.classList.remove('open');
  });
  dropdown.addEventListener('click', function(e) { e.stopPropagation(); });

  // Format helpers
  function formatICS(dateStr) {
    if (!dateStr) return '';
    var d = dateStr.replace(/[\/\-]/g, '').replace(/\s+/, 'T').replace(/:/g, '');
    if (d.indexOf('T') === -1) return d;
    return d.substring(0, 8) + 'T' + d.substring(9).padEnd(4, '0') + '00';
  }
  function formatGoogle(dateStr) {
    return formatICS(dateStr);
  }
  function formatYahoo(dateStr) {
    return formatICS(dateStr);
  }

  // Download .ics (Apple / Outlook)
  function downloadICS() {
    var icsStart = formatICS(start);
    var icsEnd = formatICS(end) || icsStart;
    var ics = [
      'BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//Event//FR', 'BEGIN:VEVENT',
      'DTSTART:' + icsStart, 'DTEND:' + icsEnd,
      'SUMMARY:' + title, 'DESCRIPTION:' + desc.replace(/\n/g, '\\n'),
      'LOCATION:' + loc, 'END:VEVENT', 'END:VCALENDAR'
    ].join('\r\n');
    var blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = 'event.ics'; a.click();
    URL.revokeObjectURL(url);
  }

  // Calendar option handlers
  dropdown.querySelectorAll('.atc-option').forEach(function(opt) {
    opt.addEventListener('click', function() {
      var cal = opt.getAttribute('data-cal');
      var gs = formatGoogle(start);
      var ge = formatGoogle(end) || gs;

      if (cal === 'apple') {
        downloadICS();
      } else if (cal === 'google') {
        var url = 'https://calendar.google.com/calendar/render?action=TEMPLATE'
          + '&text=' + encodeURIComponent(title)
          + '&dates=' + gs + '/' + ge
          + '&details=' + encodeURIComponent(desc)
          + '&location=' + encodeURIComponent(loc);
        window.open(url, '_blank');
      } else if (cal === 'yahoo') {
        var url = 'https://calendar.yahoo.com/?v=60'
          + '&title=' + encodeURIComponent(title)
          + '&st=' + gs + '&et=' + ge
          + '&desc=' + encodeURIComponent(desc)
          + '&in_loc=' + encodeURIComponent(loc);
        window.open(url, '_blank');
      } else if (cal === 'outlook') {
        var url = 'https://outlook.live.com/calendar/0/deeplink/compose?path=/calendar/action/compose&rru=addevent'
          + '&subject=' + encodeURIComponent(title)
          + '&startdt=' + gs + '&enddt=' + ge
          + '&body=' + encodeURIComponent(desc)
          + '&location=' + encodeURIComponent(loc);
        window.open(url, '_blank');
      }
      dropdown.classList.remove('open');
    });
  });

  // Mapbox map
  var mapEl = document.getElementById('eventMap');
  if (mapEl) {
    var lat = parseFloat(mapEl.dataset.lat);
    var lng = parseFloat(mapEl.dataset.lng);
    if (lat && lng) {
      var script = document.createElement('script');
      script.src = 'https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js';
      script.onload = function() {
        mapboxgl.accessToken = 'pk.eyJ1IjoiYmFyY2Vsb25hLWNvIiwiYSI6ImNsbm9mZmN3bzBpM2Yya29kcWYxbnZpcGkifQ.gsHaJQAk_Ua4vBbt3DxNGQ';
        var map = new mapboxgl.Map({
          container: mapEl,
          style: 'mapbox://styles/mapbox/streets-v12',
          center: [lng, lat],
          zoom: 15,
          pitch: 50
        });
        map.addControl(new mapboxgl.NavigationControl());
        new mapboxgl.Marker().setLngLat([lng, lat]).addTo(map);
      };
      document.head.appendChild(script);
    }
  }
})();
</script>
