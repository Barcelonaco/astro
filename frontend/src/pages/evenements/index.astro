<script is:inline>
(function() {
  var container = document.querySelector('.js_event-container');
  if (!container) return;
  var listView = container.querySelector('.js_list-events');
  var gridView = container.querySelector('.js_grid-events');
  var toggle = document.getElementById('js_event-toggle');
  var toggleText = document.getElementById('toggle-text');
  var selectList = document.getElementById('js_select-list');
  var selectGrid = document.getElementById('js_select-grid');

  // View toggle
  if (toggle) {
    toggle.addEventListener('click', function(e) {
      e.stopPropagation();
      toggle.classList.toggle('active');
    });
    document.addEventListener('click', function() { toggle.classList.remove('active'); });
  }
  if (selectList) {
    selectList.addEventListener('click', function() {
      listView.style.display = '';
      gridView.style.display = 'none';
      toggleText.textContent = 'Vue liste';
      selectList.classList.add('selected');
      selectGrid.classList.remove('selected');
    });
  }
  if (selectGrid) {
    selectGrid.addEventListener('click', function() {
      listView.style.display = 'none';
      gridView.style.display = '';
      toggleText.textContent = 'Vue photo';
      selectGrid.classList.add('selected');
      selectList.classList.remove('selected');
    });
  }

  // Tab click: filter by category (both views)
  container.querySelectorAll('.js_change-term').forEach(function(btn) {
    btn.addEventListener('click', function() {
      container.querySelectorAll('.js_change-term').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var term = btn.getAttribute('data-value');

      // Filter list view
      var items = container.querySelectorAll('.list-events .item');
      var months = container.querySelectorAll('.list-events .month-header');
      items.forEach(function(item) {
        if (term === 'all') { item.style.display = ''; }
        else {
          var cats = (item.getAttribute('data-categories') || '').split(',');
          item.style.display = cats.indexOf(term) !== -1 ? '' : 'none';
        }
      });
      months.forEach(function(mh) {
        var next = mh.nextElementSibling;
        var hasVisible = false;
        while (next && !next.classList.contains('month-header')) {
          if (next.classList.contains('item') && next.style.display !== 'none') { hasVisible = true; break; }
          next = next.nextElementSibling;
        }
        mh.style.display = hasVisible ? '' : 'none';
      });

      // Filter grid view
      var gridItems = container.querySelectorAll('.grid-events .item:not(.date-month)');
      var gridMonths = container.querySelectorAll('.grid-events .month-list');
      gridItems.forEach(function(item) {
        if (term === 'all') { item.style.display = ''; }
        else {
          var cats = (item.getAttribute('data-categories') || '').split(',');
          item.style.display = cats.indexOf(term) !== -1 ? '' : 'none';
        }
      });
      gridMonths.forEach(function(ml) {
        var hasVisible = false;
        ml.querySelectorAll('.item:not(.date-month)').forEach(function(item) {
          if (item.style.display !== 'none') hasVisible = true;
        });
        ml.style.display = hasVisible ? '' : 'none';
      });
    });
  });
})();
</script>
