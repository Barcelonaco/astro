---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteOverlays from '../components/SiteOverlays.astro';
import DeferredLoader from '../components/DeferredLoader.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getFrontendBootstrap } from '../lib/api';
import { setDefaultImageUrl } from '../lib/module-helpers';
import '../styles/search-page.css';

const { siteInfo, styleSettings, siteSettings, navigation: navigationData, secondaryNavigation } = await getFrontendBootstrap();
const siteName = siteInfo.siteName || SITE_TITLE;
setDefaultImageUrl(siteSettings.replacement_image || '');

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`Recherche | ${siteName}`} description={SITE_DESCRIPTION} styleSettings={styleSettings} siteSettings={siteSettings} />
  </head>
  <body class={bodyClasses || undefined}>
    <Header siteName={siteName} navigation={navigationData} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
    <main id="main" class="main-page page-search" role="main">
      <section>
        <div class="container">

          <h1 class="title-page title-section-2">Votre recherche</h1>

          <!-- Initial state: prompt to search -->
          <div id="search-initial" class="no-results">
            <div class="txt editor">
              <p><b>Veuillez saisir un terme de recherche.</b></p>
            </div>
            <div class="btn-wrapper">
              <button type="button" class="btn btn-primary js_btn-toggle-search">Effectuer une recherche</button>
            </div>
          </div>

          <!-- Loading state -->
          <div id="search-loading" class="no-results" style="display:none">
            <div class="txt editor">
              <p>Recherche en cours...</p>
            </div>
          </div>

          <!-- Results count -->
          <p id="search-count" class="nbr-results" style="display:none"></p>

          <!-- No results state -->
          <div id="search-empty" class="no-results" style="display:none">
            <div class="txt editor">
              <p><b>Aucun résultat ne correspond à votre recherche.</b></p>
            </div>
            <div class="btn-wrapper">
              <button type="button" class="btn btn-primary js_btn-toggle-search">Effectuer une nouvelle recherche</button>
            </div>
          </div>

          <!-- Results list -->
          <ul id="search-results" class="list-results" style="display:none"></ul>

        </div>
      </section>
    </main>
    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />
  </body>
</html>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
  const apiOrigin = API_URL.replace(/\/api\/?$/, '');

  const typeLabels: Record<string, string> = {
    post: 'Article',
    page: 'Page',
    actualites: 'Actualité',
    references: 'Référence',
    evenements: 'Événement',
  };

  function formatDate(dateStr: string): string {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '';
    return d.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }

  function resolveImage(img: any): string {
    if (!img) return '';
    if (typeof img === 'string') {
      return img.startsWith('http') ? img : apiOrigin + img;
    }
    return img.sizes?.half || img.url || '';
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  async function performSearch(query: string) {
    const elInitial = document.getElementById('search-initial')!;
    const elLoading = document.getElementById('search-loading')!;
    const elCount = document.getElementById('search-count')!;
    const elEmpty = document.getElementById('search-empty')!;
    const elResults = document.getElementById('search-results')!;

    // Hide all states
    elInitial.style.display = 'none';
    elCount.style.display = 'none';
    elEmpty.style.display = 'none';
    elResults.style.display = 'none';

    if (!query || query.length < 2) {
      elInitial.style.display = '';
      return;
    }

    // Show loading
    elLoading.style.display = '';

    try {
      const res = await fetch(`${API_URL}/search?q=${encodeURIComponent(query)}&limit=50`);
      const data = await res.json();
      elLoading.style.display = 'none';

      const total = data.total || 0;
      const results = data.results || [];
      const resultWord = total > 1 ? 'résultats' : 'résultat';

      elCount.textContent = `${total} ${resultWord} pour "${query}"`;
      elCount.style.display = '';

      if (total === 0) {
        elEmpty.style.display = '';
        return;
      }

      // Build results HTML
      let html = '';
      for (const r of results) {
        const img = resolveImage(r.featured_image);
        const typeLabel = typeLabels[r.result_type] || r.result_type;
        const url = `${r.base_url}${r.slug}`;
        const excerpt = r.excerpt
          ? (r.excerpt.length > 200 ? r.excerpt.substring(0, 200) + '...' : r.excerpt)
          : '';
        const date = formatDate(r.published_date);

        html += `<li class="item" role="article">
          <a href="${escapeHtml(url)}" class="link">
            ${img ? `<div class="illus-wrapper"><img src="${escapeHtml(img)}" alt="${escapeHtml(r.title)}" class="illus" loading="lazy" /></div>` : ''}
            <div class="desc">
              <p class="category">${escapeHtml(typeLabel)}</p>
              <h2 class="title title-section-3">${r.title}</h2>
              ${excerpt ? `<div class="editor txt"><p>${escapeHtml(excerpt)}</p></div>` : ''}
              <div class="btn-wrapper">
                <span class="fake-link btn btn-tertiary">Voir plus</span>
              </div>
              ${date ? `<time class="date">${escapeHtml(date)}</time>` : ''}
            </div>
          </a>
        </li>`;
      }
      elResults.innerHTML = html;
      elResults.style.display = '';

    } catch (err) {
      console.error('Search error:', err);
      elLoading.style.display = 'none';
      elEmpty.style.display = '';
    }
  }

  // Run search from URL query param on load
  const params = new URLSearchParams(window.location.search);
  const q = params.get('q');
  if (q) {
    performSearch(q);
  }
</script>
