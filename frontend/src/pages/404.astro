---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteOverlays from '../components/SiteOverlays.astro';
import DeferredLoader from '../components/DeferredLoader.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getFrontendBootstrap } from '../lib/api';
import { optimizedImageUrl, setDefaultImageUrl } from '../lib/module-helpers';

const { siteInfo, styleSettings, siteSettings, navigation: navigationData, secondaryNavigation } = await getFrontendBootstrap();
const siteName = siteInfo.siteName || SITE_TITLE;
setDefaultImageUrl(siteSettings.replacement_image || '');

const bgImageRaw = siteSettings.replacement_image || '';
const bgImage = bgImageRaw ? optimizedImageUrl(bgImageRaw, 1920, 80) : '';

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`Erreur 404 | ${siteName}`} description={SITE_DESCRIPTION} styleSettings={styleSettings} siteSettings={siteSettings} />
  </head>
  <body class={bodyClasses || undefined}>
    <Header siteName={siteName} navigation={navigationData} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
    <main id="main" class="main-page page-error-404" role="main">
      <section class="content-404">
        {bgImage && (
          <div class="background">
            <img class="illus" src={bgImage} alt="" loading="eager" decoding="async" />
          </div>
        )}
        <div class="container">
          <h1 class="title-page">
            <span class="small">Erreur</span>
            <span class="large">404</span>
          </h1>
          <p class="subtitle">Sincèrement désolé !</p>
          <div class="txt editor">
            <p>
              La page que vous avez demandée n'existe pas.<br />
              L'adresse saisie est peut-être incorrecte ou la page peut avoir été déplacée.
            </p>
          </div>
          <div class="btn-wrapper">
            <a href="/" class="btn btn-primary">Retour à l'accueil</a>
          </div>
        </div>
      </section>
    </main>
    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />
  </body>
</html>

<style>
  .page-error-404 {
    margin-top: 0 !important;
  }
  .content-404 {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    text-align: center;
    color: #fff;
    overflow: hidden;
  }
  .background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.55) 100%);
  }
  .illus {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: none;
    margin: 0 auto;
    font-size: 85px;
  }
  .title-page {
    margin: 0;
    line-height: 1;
    font-weight: 800;
  }
  .title-page .small {
    display: block;
    font-size: clamp(2rem, 4.7vw, 2.8125rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 0.5em;
  }
  .title-page .large {
    display: block;
    font-size: clamp(14rem, 45vw, 31rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin: 0 0 0.05em;
  }
  .subtitle {
    font-size: clamp(2.5rem, 7vw, 5.625rem);
    font-weight: 800;
    line-height: 1.05;
    margin: 0.6em 0 0.5em;
  }
  .txt {
    max-width: 640px;
    margin: 0 auto 2rem;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.95;
  }
  .btn-wrapper {
    display: flex;
    justify-content: center;
  }
  .btn {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--color-primary, #006b9a);
    color: #fff;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  @media (max-width: 720px) {
    .content-404 {
      padding: 4rem 1rem 3rem;
    }
    .subtitle {
      margin-top: 0;
    }
  }
</style>
