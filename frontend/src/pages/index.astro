---
import BaseHead from '../components/BaseHead.astro';
import ModuleStyles from '../components/ModuleStyles.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import DeferredLoader from '../components/DeferredLoader.astro';
import SiteOverlays from '../components/SiteOverlays.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { formatContent, getFrontendBootstrap } from '../lib/api';
import { optimizedImageUrl } from '../lib/module-helpers';

function parseBlocks(content: string): unknown[] | null {
  if (!content || !content.trim()) return null;
  try {
    const parsed = JSON.parse(content);
    if (Array.isArray(parsed) && parsed.every((b: unknown) => b && typeof (b as { type?: string }).type === 'string')) return parsed;
  } catch {}
  return null;
}

function extractLcpImages(blocks: any[] | null): { desktop: string; mobile: string } {
  if (!blocks || blocks.length === 0) return { desktop: '', mobile: '' };
  const first = blocks[0];
  if (first.type === 'hero' && first.data?.hero_sliders?.[0]?.image?.url) {
    const slide = first.data.hero_sliders[0];
    const mobileUrl = slide.image_mobile?.url || slide.image.url;
    return {
      desktop: optimizedImageUrl(slide.image.url, 1440, 80),
      mobile: optimizedImageUrl(mobileUrl, 600, 70),
    };
  }
  if (first.type === 'banner' && first.data?.image?.url) {
    const url = optimizedImageUrl(first.data.image.url, 1440, 80);
    return { desktop: url, mobile: url };
  }
  return { desktop: '', mobile: '' };
}

// Single API call for all bootstrap data (site info + navigation + style settings + front page)
const { siteInfo, styleSettings, siteSettings, navigation: navigationData, secondaryNavigation, frontPage } = await getFrontendBootstrap();
const siteName = siteInfo.siteName || SITE_TITLE;
const siteDescription = siteInfo.siteDescription || SITE_DESCRIPTION;

const page = frontPage;
const hasPage = !!page;
const blocks = hasPage ? parseBlocks(page.content) : null;
const isBlockPage = blocks !== null;
const lcpImages = extractLcpImages(blocks as any[] | null);

// Parse color overrides for this page
let colorOverrideStyle = '';
try {
  const co = page?.color_overrides ? JSON.parse(page.color_overrides) : null;
  if (co?.enabled) {
    const vars: string[] = [];
    if (co.primary_color) { vars.push(`--color-primary:${co.primary_color}`); vars.push(`--color-primary-bis:${co.primary_color}`); }
    if (co.secondary_color) { vars.push(`--color-secondary:${co.secondary_color}`); vars.push(`--color-secondary-bis:${co.secondary_color}`); }
    if (co.tertiary_color) vars.push(`--color-tertiary:${co.tertiary_color}`);
    if (co.text_color) vars.push(`--color-default:${co.text_color}`);
    if (co.background_color) vars.push(`--color-background:${co.background_color}`);
    if (co.bg_form_field) vars.push(`--color-form:${co.bg_form_field}`);
    if (vars.length) colorOverrideStyle = vars.join(';');
  }
} catch {}
const hasColorOverrides = !!colorOverrideStyle;

// Parse SEO meta for front page
let seoTitle = siteName;
let seoDescription = siteDescription;
let schemaOrg = '';
try {
  const seo = page?.seo_meta ? JSON.parse(page.seo_meta) : null;
  if (seo?.enabled) {
    if (seo.meta_title) seoTitle = seo.meta_title;
    if (seo.meta_description) seoDescription = seo.meta_description;
    if (seo.schema_org) {
      const siteUrl = Astro.site ? Astro.site.origin : '';
      schemaOrg = seo.schema_org.replace(/\{\{site_url\}\}/g, siteUrl);
    }
  }
} catch {}

// Body classes from identity settings
const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={seoTitle} description={seoDescription} styleSettings={styleSettings} siteSettings={siteSettings} />
		{schemaOrg && <script type="application/ld+json" set:html={schemaOrg} />}
		{lcpImages.mobile && <link rel="preload" as="image" href={lcpImages.mobile} media="(max-width: 600px)" fetchpriority="high" />}
		{lcpImages.desktop && <link rel="preload" as="image" href={lcpImages.desktop} media="(min-width: 601px)" fetchpriority="high" />}
		<ModuleStyles blocks={blocks} />
	</head>
	<body class={bodyClasses || undefined}>
		<Header siteName={siteName} navigation={navigationData} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
		<main class={`${isBlockPage ? 'main-page' : ''} ${hasColorOverrides ? 'has-color-overrides' : ''}`.trim()} style={colorOverrideStyle || undefined}>
			{hasPage ? (
				<article>
					{!isBlockPage && (
						<div class="hero-image">
							<div class="page-header">
								<h1 class="title">{page.title}</h1>
							</div>
						</div>
					)}
					<div class={isBlockPage ? 'content content-blocks' : 'content'}>
						{isBlockPage ? (
							<BlockRenderer blocks={blocks} />
						) : (
							<div class="prose" set:html={formatContent(page.content)} />
						)}
					</div>
				</article>
			) : (
				<div class="fallback">
					<h1>{siteName}</h1>
					<p>{siteDescription}</p>
				</div>
			)}
		</main>
		<Footer siteSettings={siteSettings} />
		<SiteOverlays siteSettings={siteSettings} />
		<DeferredLoader />
	</body>
</html>

<style>
	article {
		width: 100%;
		max-width: 100%;
		margin: 0;
	}

	.hero-image {
		width: 100%;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
	}
	.page-header {
		padding: 3em 2em;
		max-width: 1200px;
		margin: 0 auto;
	}
	.title {
		color: white;
		font-size: 3em;
		margin-bottom: 0;
	}
	.content {
		margin: 0 auto;
		padding: 3em 2em;
		max-width: 900px;
	}
	.content-blocks {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}
	.prose {
		font-size: 1.1em;
		line-height: 1.8;
	}
	.fallback {
		max-width: 900px;
		margin: 0 auto;
		padding: 4em 2em;
		text-align: center;
	}
</style>
