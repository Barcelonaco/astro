---
import BaseHead from '../../components/BaseHead.astro';
import ModuleStyles from '../../components/ModuleStyles.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import DeferredLoader from '../../components/DeferredLoader.astro';
import SiteOverlays from '../../components/SiteOverlays.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getAllPages, getPageBySlug, formatContent, getFrontendBootstrap } from '../../lib/api';
import { optimizedImageUrl } from '../../lib/module-helpers';

export async function getStaticPaths() {
  const pages = await getAllPages();
  return pages
    .filter((p: any) => p.status === 'published')
    .map((p: any) => ({ params: { slug: p.slug } }));
}

function parseBlocks(content: string): unknown[] | null {
  if (!content || !content.trim()) return null;
  try {
    const parsed = JSON.parse(content);
    if (Array.isArray(parsed) && parsed.every((b: unknown) => b && typeof (b as { type?: string }).type === 'string')) return parsed;
  } catch {}
  return null;
}

function extractLcpImages(blocks: any[] | null): { desktop: string; mobile: string } {
  if (!blocks || blocks.length === 0) return { desktop: '', mobile: '' };
  const first = blocks[0];
  if (first.type === 'hero' && first.data?.hero_sliders?.[0]?.image?.url) {
    const slide = first.data.hero_sliders[0];
    const mobileUrl = slide.image_mobile?.url || slide.image.url;
    return {
      desktop: optimizedImageUrl(slide.image.url, 1440, 55),
      mobile: optimizedImageUrl(mobileUrl, 600, 50),
    };
  }
  if (first.type === 'banner' && first.data?.image?.url) {
    const url = optimizedImageUrl(first.data.image.url, 1440, 55);
    return { desktop: url, mobile: url };
  }
  return { desktop: '', mobile: '' };
}

const { slug } = Astro.params;
// Fetch page + bootstrap data in parallel (2 HTTP calls instead of 4+)
const [page, { siteInfo, styleSettings, siteSettings, navigation: navigationData, secondaryNavigation }] = await Promise.all([
  getPageBySlug(slug as string),
  getFrontendBootstrap(),
]);
const siteName = siteInfo.siteName || SITE_TITLE;
const siteDescription = siteInfo.siteDescription || SITE_DESCRIPTION;

if (!page) {
  throw new Error(`Page not found: ${slug}`);
}

const blocks = parseBlocks(page.content);
const isBlockPage = blocks !== null;
const lcpImages = extractLcpImages(blocks as any[] | null);

// Parse color overrides for this page
let colorOverrideStyle = '';
try {
  const co = page.color_overrides ? JSON.parse(page.color_overrides) : null;
  if (co?.enabled) {
    const vars: string[] = [];
    if (co.primary_color) { vars.push(`--color-primary:${co.primary_color}`); vars.push(`--color-primary-bis:${co.primary_color}`); }
    if (co.secondary_color) { vars.push(`--color-secondary:${co.secondary_color}`); vars.push(`--color-secondary-bis:${co.secondary_color}`); }
    if (co.tertiary_color) vars.push(`--color-tertiary:${co.tertiary_color}`);
    if (co.text_color) vars.push(`--color-default:${co.text_color}`);
    if (co.background_color) vars.push(`--color-background:${co.background_color}`);
    if (co.bg_form_field) vars.push(`--color-form:${co.bg_form_field}`);
    if (vars.length) colorOverrideStyle = vars.join(';');
  }
} catch {}
const hasColorOverrides = !!colorOverrideStyle;

// Parse SEO meta for this page
let seoTitle = `${page.title} | ${siteName}`;
let seoDescription = siteDescription;
let schemaOrg = '';
try {
  const seo = page.seo_meta ? JSON.parse(page.seo_meta) : null;
  if (seo?.enabled) {
    if (seo.meta_title) seoTitle = seo.meta_title;
    if (seo.meta_description) seoDescription = seo.meta_description;
    if (seo.schema_org) {
      // Replace {{site_url}} placeholder with actual site URL
      const siteUrl = Astro.site ? Astro.site.origin : '';
      schemaOrg = seo.schema_org.replace(/\{\{site_url\}\}/g, siteUrl);
    }
  }
} catch {}

// Body classes from identity settings
const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={seoTitle} description={seoDescription} styleSettings={styleSettings} siteSettings={siteSettings} />
		{schemaOrg && <script type="application/ld+json" set:html={schemaOrg} />}
		{lcpImages.mobile && <link rel="preload" as="image" href={lcpImages.mobile} media="(max-width: 600px)" fetchpriority="high" />}
		{lcpImages.desktop && <link rel="preload" as="image" href={lcpImages.desktop} media="(min-width: 601px)" fetchpriority="high" />}
		<ModuleStyles blocks={blocks} />
	</head>
	<body class={bodyClasses || undefined}>
		<Header siteName={siteName} navigation={navigationData} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
		<main class={`${isBlockPage ? 'main-page' : ''} ${hasColorOverrides ? 'has-color-overrides' : ''}`.trim()} style={colorOverrideStyle || undefined}>
			<article>
				{!isBlockPage && (
					<div class="hero-image">
						<div class="page-header">
							<h1 class="title">{page.title}</h1>
						</div>
					</div>
				)}
				<div class={isBlockPage ? 'content content-blocks' : 'content'}>
					{isBlockPage ? (
						<BlockRenderer blocks={blocks} />
					) : (
						<div class="prose" set:html={formatContent(page.content)} />
					)}
				</div>
			</article>
		</main>
		<Footer siteSettings={siteSettings} />
		<SiteOverlays siteSettings={siteSettings} />
		<DeferredLoader />
	</body>
</html>

<style>
	article {
		width: 100%;
		max-width: 100%;
		margin: 0;
	}

	.page-blocks {
		width: 100%;
		max-width: 100%;
		margin: 0;
	}
	.hero-image {
		width: 100%;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
	}
	.page-header {
		padding: 3em 2em;
		max-width: 1200px;
		margin: 0 auto;
	}
	.title {
		color: white;
		font-size: 3em;
		margin-bottom: 0;
	}
	.content {
		margin: 0 auto;
		padding: 3em 2em;
		max-width: 900px;
	}
	

	/* Pour les pages construites avec des blocs Nickl :
	   - le module doit prendre toute la largeur de l'écran
	   - seul le contenu interne gère son propre padding (via .container, etc.) */
	.content-blocks {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}
	.prose {
		font-size: 1.1em;
		line-height: 1.8;
	}
	.prose :global(h2) {
		margin-top: 2em;
		margin-bottom: 0.5em;
	}
	.prose :global(h3) {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.prose :global(p) {
		margin-bottom: 1em;
	}
	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1em;
		padding-left: 2em;
	}
	.prose :global(li) {
		margin-bottom: 0.5em;
	}
	.prose :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		margin: 1.5em 0;
	}
	.prose :global(blockquote) {
		border-left: 4px solid var(--accent);
		padding-left: 1.5em;
		margin: 1.5em 0;
		font-style: italic;
		color: #666;
	}
	.prose :global(code) {
		background: #f4f4f4;
		padding: 0.2em 0.4em;
		border-radius: 3px;
		font-family: monospace;
	}
	.prose :global(pre) {
		background: #f4f4f4;
		padding: 1em;
		border-radius: 8px;
		overflow-x: auto;
		margin: 1.5em 0;
	}
</style>

<style is:global>
	/* Surcharge des couleurs par page :
	   Les CSS custom properties cascadent, mais la propriété `color` héritée est la
	   valeur calculée du body (via :root), pas la variable. Il faut forcer les modules
	   à re-lire les variables depuis le <main> le plus proche. */
	main.has-color-overrides {
		background-color: var(--color-background);
	}
	main.has-color-overrides .module {
		color: var(--color-default);
	}
	main.has-color-overrides .module h1,
	main.has-color-overrides .module h2,
	main.has-color-overrides .module h3,
	main.has-color-overrides .module h4,
	main.has-color-overrides .module h5,
	main.has-color-overrides .module h6,
	main.has-color-overrides .module .title-module,
	main.has-color-overrides .module .title-section-4 {
		color: var(--color-default);
	}
	main.has-color-overrides .module.has-background-primary,
	main.has-color-overrides .module.has-background-secondary {
		color: #fff;
	}
	main.has-color-overrides .module.has-background-primary h1,
	main.has-color-overrides .module.has-background-primary h2,
	main.has-color-overrides .module.has-background-primary h3,
	main.has-color-overrides .module.has-background-primary h4,
	main.has-color-overrides .module.has-background-primary h5,
	main.has-color-overrides .module.has-background-primary h6,
	main.has-color-overrides .module.has-background-primary .title-module,
	main.has-color-overrides .module.has-background-primary .title-section-4,
	main.has-color-overrides .module.has-background-secondary h1,
	main.has-color-overrides .module.has-background-secondary h2,
	main.has-color-overrides .module.has-background-secondary h3,
	main.has-color-overrides .module.has-background-secondary h4,
	main.has-color-overrides .module.has-background-secondary h5,
	main.has-color-overrides .module.has-background-secondary h6,
	main.has-color-overrides .module.has-background-secondary .title-module,
	main.has-color-overrides .module.has-background-secondary .title-section-4 {
		color: #fff;
	}
	/* Modules sans fond coloré : appliquer la couleur de fond de la page */
	main.has-color-overrides .module:not(.has-background-primary):not(.has-background-secondary):not(.has-background-tertiary):not(.has-background-dark) {
		background-color: var(--color-background);
	}
	/* Champs de formulaire */
	main.has-color-overrides .module input:not([type="radio"]):not([type="checkbox"]):not([type="submit"]):not([type="color"]),
	main.has-color-overrides .module textarea,
	main.has-color-overrides .module select {
		background-color: var(--color-form);
	}
</style>
