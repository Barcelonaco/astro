---
export const prerender = false;

import BaseHead from '../../components/BaseHead.astro';
import ModuleStyles from '../../components/ModuleStyles.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import DeferredLoader from '../../components/DeferredLoader.astro';
import SiteOverlays from '../../components/SiteOverlays.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getPageBySlug, formatContent, getFrontendBootstrap } from '../../lib/api';
import { optimizedImageUrl } from '../../lib/module-helpers';

function parseBlocks(content: string): unknown[] | null {
  if (!content || !content.trim()) return null;
  try {
    const parsed = JSON.parse(content);
    if (Array.isArray(parsed) && parsed.every((b: unknown) => b && typeof (b as { type?: string }).type === 'string')) return parsed;
  } catch {}
  return null;
}

function extractLcpImages(blocks: any[] | null): { desktop: string; mobile: string } {
  if (!blocks || blocks.length === 0) return { desktop: '', mobile: '' };
  const first = blocks[0];
  if (first.type === 'hero' && first.data?.hero_sliders?.[0]?.image?.url) {
    const slide = first.data.hero_sliders[0];
    const mobileUrl = slide.image_mobile?.url || slide.image.url;
    return {
      desktop: optimizedImageUrl(slide.image.url, 1920, 70),
      mobile: optimizedImageUrl(mobileUrl, 600, 50),
    };
  }
  if (first.type === 'banner' && first.data?.image?.url) {
    const url = optimizedImageUrl(first.data.image.url, 1920, 70);
    return { desktop: url, mobile: url };
  }
  return { desktop: '', mobile: '' };
}

const { slug } = Astro.params;
// Fetch page + bootstrap data in parallel (2 HTTP calls instead of 4+)
const [page, { siteInfo, styleSettings, siteSettings, navigation: navigationData }] = await Promise.all([
  getPageBySlug(slug as string),
  getFrontendBootstrap(),
]);
const siteName = siteInfo.siteName || SITE_TITLE;
const siteDescription = siteInfo.siteDescription || SITE_DESCRIPTION;

if (!page || page.status !== 'published') {
  return Astro.redirect('/404');
}

const blocks = parseBlocks(page.content);
const isBlockPage = blocks !== null;
const lcpImages = extractLcpImages(blocks as any[] | null);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`${page.title} | ${siteName}`} description={siteDescription} styleSettings={styleSettings} siteSettings={siteSettings} />
		{lcpImages.mobile && <link rel="preload" as="image" href={lcpImages.mobile} media="(max-width: 600px)" fetchpriority="high" />}
		{lcpImages.desktop && <link rel="preload" as="image" href={lcpImages.desktop} media="(min-width: 601px)" fetchpriority="high" />}
		<ModuleStyles blocks={blocks} />
	</head>
	<body>
		<Header siteName={siteName} navigation={navigationData} siteSettings={siteSettings} />
		<main class={isBlockPage ? 'main-page' : ''}>
			<article>
				{!isBlockPage && (
					<div class="hero-image">
						<div class="page-header">
							<h1 class="title">{page.title}</h1>
						</div>
					</div>
				)}
				<div class={isBlockPage ? 'content content-blocks' : 'content'}>
					{isBlockPage ? (
						<BlockRenderer blocks={blocks} />
					) : (
						<div class="prose" set:html={formatContent(page.content)} />
					)}
				</div>
			</article>
		</main>
		<Footer siteSettings={siteSettings} />
		<SiteOverlays siteSettings={siteSettings} />
		<DeferredLoader />
	</body>
</html>

<style>
	article {
		width: 100%;
		max-width: 100%;
		margin: 0;
	}

	.page-blocks {
		width: 100%;
		max-width: 100%;
		margin: 0;
	}
	.hero-image {
		width: 100%;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
	}
	.page-header {
		padding: 3em 2em;
		max-width: 1200px;
		margin: 0 auto;
	}
	.title {
		color: white;
		font-size: 3em;
		margin-bottom: 0;
	}
	.content {
		margin: 0 auto;
		padding: 3em 2em;
		max-width: 900px;
	}
	

	/* Pour les pages construites avec des blocs Nickl :
	   - le module doit prendre toute la largeur de l'écran
	   - seul le contenu interne gère son propre padding (via .container, etc.) */
	.content-blocks {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}
	.prose {
		font-size: 1.1em;
		line-height: 1.8;
	}
	.prose :global(h2) {
		margin-top: 2em;
		margin-bottom: 0.5em;
	}
	.prose :global(h3) {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.prose :global(p) {
		margin-bottom: 1em;
	}
	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1em;
		padding-left: 2em;
	}
	.prose :global(li) {
		margin-bottom: 0.5em;
	}
	.prose :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		margin: 1.5em 0;
	}
	.prose :global(blockquote) {
		border-left: 4px solid var(--accent);
		padding-left: 1.5em;
		margin: 1.5em 0;
		font-style: italic;
		color: #666;
	}
	.prose :global(code) {
		background: #f4f4f4;
		padding: 0.2em 0.4em;
		border-radius: 3px;
		font-family: monospace;
	}
	.prose :global(pre) {
		background: #f4f4f4;
		padding: 1em;
		border-radius: 8px;
		overflow-x: auto;
		margin: 1.5em 0;
	}
</style>
