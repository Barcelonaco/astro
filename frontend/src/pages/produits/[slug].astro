---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DeferredLoader from '../../components/DeferredLoader.astro';
import SiteOverlays from '../../components/SiteOverlays.astro';
import ModuleStyles from '../../components/ModuleStyles.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import PriceDisplay from '../../components/shop/PriceDisplay.astro';
import VariantSelector from '../../components/shop/VariantSelector.astro';
import AddToCartButton from '../../components/shop/AddToCartButton.astro';
import Breadcrumb from '../../components/shop/Breadcrumb.astro';
import ProductCard from '../../components/shop/ProductCard.astro';
import { getFrontendBootstrap } from '../../lib/api';
import { getProduct, listProducts } from '../../lib/shop-api';
import { optimizedImageUrl } from '../../lib/module-helpers';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

// Génération statique d'une page par produit publié.
export async function getStaticPaths() {
  const res = await listProducts({ per_page: 500 });
  return res.data.map((p) => ({ params: { slug: p.slug }, props: { slug: p.slug } }));
}

const { slug } = Astro.props as { slug: string };

const bootstrap = await getFrontendBootstrap();
const siteSettings = bootstrap.siteSettings;

const product = await getProduct(slug);
if (!product) {
  return new Response(null, { status: 404 });
}

const { siteInfo, styleSettings, navigation, secondaryNavigation } = bootstrap;
const siteName = siteInfo.siteName || SITE_TITLE;

const seoTitle = (product.seo_meta?.meta_title) || `${product.title} | ${siteName}`;
const seoDesc = (product.seo_meta?.meta_description) || product.excerpt || SITE_DESCRIPTION;

// Galerie : image featured + gallery
const images: Array<{ url: string; alt: string }> = [];
if (product.featured_image) {
  const fi: any = product.featured_image;
  const url = typeof fi === 'string' ? fi : (fi.sizes?.full || fi.url);
  if (url) images.push({ url, alt: product.title });
}
for (const img of (product.gallery || [])) {
  if (img.url && !images.find(i => i.url === img.url)) images.push({ url: img.url, alt: img.alt || product.title });
}
if (images.length === 0 && product.custom_fields?.gallery) {
  try {
    const gal = typeof product.custom_fields.gallery === 'string' ? JSON.parse(product.custom_fields.gallery) : product.custom_fields.gallery;
    if (Array.isArray(gal)) {
      for (const g of gal) {
        const url = typeof g === 'string' ? g : (g.url || g.sizes?.full);
        if (url) images.push({ url, alt: product.title });
      }
    }
  } catch {}
}

const schemaOrg: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.excerpt || '',
  sku: product.variants[0]?.sku,
  image: images.map(i => i.url),
  offers: {
    '@type': product.has_variants ? 'AggregateOffer' : 'Offer',
    priceCurrency: product.currency,
    ...(product.has_variants
      ? { lowPrice: (product.price_cents_min / 100).toFixed(2), highPrice: (product.price_cents_max / 100).toFixed(2), offerCount: product.variants.length }
      : { price: (product.price_cents_min / 100).toFixed(2) }),
    availability: product.in_stock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
};

const crumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Boutique', href: '/boutique' },
  ...(product.breadcrumb || []).map((c: any) => ({ label: c.name, href: `/boutique/categorie/${c.path}` })),
  { label: product.title },
];

let contentBlocks: any[] = [];
try {
  if (product.content) {
    const parsed = typeof product.content === 'string' ? JSON.parse(product.content) : product.content;
    if (Array.isArray(parsed)) contentBlocks = parsed;
  }
} catch {}
---
<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={seoTitle} description={seoDesc} styleSettings={styleSettings} siteSettings={siteSettings} />
    <ModuleStyles blocks={contentBlocks} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)}></script>
  </head>
  <body>
    <Header siteName={siteName} navigation={navigation} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />

    <main id="main" class="main-page shop-product" role="main">
      <section>
        <div class="container-large">
          <Breadcrumb items={crumbs} />

          <div class="shop-product__layout">
            <!-- Galerie -->
            <div class="shop-product__gallery">
              {images.length > 0 && (
                <>
                  <div class="shop-product__gallery-main">
                    <img src={optimizedImageUrl(images[0].url, 1200, 85)} alt={images[0].alt} id="shopGalleryMain" />
                  </div>
                  {images.length > 1 && (
                    <div class="shop-product__gallery-thumbs">
                      {images.map((img, i) => (
                        <button type="button" class={`shop-product__thumb ${i === 0 ? 'active' : ''}`} data-full-url={img.url}>
                          <img src={optimizedImageUrl(img.url, 200, 80)} alt={img.alt} />
                        </button>
                      ))}
                    </div>
                  )}
                </>
              )}
            </div>

            <!-- Infos -->
            <div class="shop-product__info">
              <h1 class="shop-product__title title-section-1">{product.title}</h1>
              {product.excerpt && <p class="shop-product__excerpt">{product.excerpt}</p>}

              <div class="shop-product__price" id="shopCurrentVariantPrice">
                <PriceDisplay
                  priceCents={product.price_cents_min}
                  priceCentsMax={product.has_variants ? product.price_cents_max : undefined}
                  compareAtCents={product.compare_at_price_cents}
                />
              </div>

              <p class="shop-product__stock" id="shopCurrentVariantStock">
                {product.in_stock ? 'En stock' : 'Rupture de stock'}
              </p>

              <form id="shopProductForm" onsubmit="event.preventDefault()">
                {product.has_variants && (
                  <VariantSelector
                    variants={product.variants}
                    variantAttributes={product.custom_fields?.variant_attributes || []}
                  />
                )}
                <AddToCartButton productSlug={product.slug} disabled={!product.in_stock} />
              </form>

              {(() => {
                let feats: any = product.short_features;
                if (typeof feats === 'string') {
                  try { feats = JSON.parse(feats); } catch { feats = []; }
                }
                if (!Array.isArray(feats) || feats.length === 0) return null;
                return (
                  <dl class="shop-product__features">
                    {feats.map((f: any) => (
                      <div class="shop-product__feature">
                        <dt>{f.label}</dt>
                        <dd>{f.value}</dd>
                      </div>
                    ))}
                  </dl>
                );
              })()}
            </div>
          </div>

          {contentBlocks.length > 0 && (
            <section class="shop-product__description">
              <h2 class="title title-section-2">Description</h2>
              <BlockRenderer blocks={contentBlocks} />
            </section>
          )}

          {product.related && product.related.length > 0 && (
            <section class="shop-product__related">
              <h2 class="title title-section-2">Produits similaires</h2>
              <div class="shop-product__related-grid">
                {product.related.map((p) => <ProductCard product={p} />)}
              </div>
            </section>
          )}
        </div>
      </section>
    </main>
    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />

    <script is:inline>
      (function () {
        const main = document.getElementById('shopGalleryMain');
        if (!main) return;
        document.querySelectorAll('.shop-product__thumb').forEach(btn => {
          btn.addEventListener('click', () => {
            const url = btn.getAttribute('data-full-url');
            if (!url) return;
            const m = url.match(/\/uploads\/media\/([^/?#]+)$/);
            main.src = m ? `/uploads/media/_optimized/${m[1]}?w=1200&q=85&f=webp` : url;
            document.querySelectorAll('.shop-product__thumb').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
          });
        });
      })();
    </script>

    <style>
      .shop-product { padding: 40px 0 60px; }
      .shop-product__layout {
        display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 3rem;
      }
      .shop-product__gallery-main {
        position: relative; width: 100%; padding-top: 100%;
        background: var(--gray-100, #f3f4f6); border-radius: 10px; overflow: hidden;
      }
      .shop-product__gallery-main img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .shop-product__gallery-thumbs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 10px; }
      .shop-product__thumb {
        width: 100%; padding: 0; border: 2px solid transparent; border-radius: 6px;
        overflow: hidden; background: none; cursor: pointer; aspect-ratio: 1;
      }
      .shop-product__thumb img { width: 100%; height: 100%; object-fit: cover; }
      .shop-product__thumb.active { border-color: var(--color-primary, #0f62fe); }
      .shop-product__title { margin: 0 0 10px; }
      .shop-product__excerpt { color: var(--gray-600, #4b5563); margin: 0 0 16px; }
      .shop-product__price { font-size: 1.4rem; margin: 16px 0 8px; }
      .shop-product__stock { font-size: 14px; color: var(--success, #059669); font-weight: 500; }
      .shop-product__stock.out { color: var(--danger, #dc2626); }
      .shop-product__features {
        margin: 24px 0 0; padding: 16px; background: var(--gray-50, #f9fafb); border-radius: 8px;
      }
      .shop-product__feature {
        display: flex; gap: 16px; padding: 6px 0; font-size: 14px;
        border-bottom: 1px solid var(--gray-200, #e5e7eb);
      }
      .shop-product__feature:last-child { border-bottom: 0; }
      .shop-product__feature dt { flex: 0 0 40%; font-weight: 600; color: var(--gray-700, #374151); margin: 0; }
      .shop-product__feature dd { margin: 0; color: var(--gray-600, #4b5563); }
      .shop-product__description { padding: 2rem 0; border-top: 1px solid var(--gray-200, #e5e7eb); }
      .shop-product__related { padding: 2rem 0; border-top: 1px solid var(--gray-200, #e5e7eb); }
      .shop-product__related-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 1rem;
      }
      @media (max-width: 800px) { .shop-product__layout { grid-template-columns: 1fr; } }
    </style>
  </body>
</html>
