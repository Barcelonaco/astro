---
import BaseHead from '../../components/BaseHead.astro';
import ModuleStyles from '../../components/ModuleStyles.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import DeferredLoader from '../../components/DeferredLoader.astro';
import SiteOverlays from '../../components/SiteOverlays.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getActualites, getFrontendBootstrap, type ActualiteItem } from '../../lib/api';
import { cleanHtml } from '../../lib/module-classes';
import { optimizedImageUrl, responsiveSrcset, setDefaultImageUrl, getDefaultImageUrl } from '../../lib/module-helpers';

export async function getStaticPaths() {
  const result = await getActualites({ status: 'published', limit: 10000 });
  const items = Array.isArray(result) ? result : result.items;
  return items.map((item: any) => ({ params: { slug: item.slug }, props: { item } }));
}

const { slug } = Astro.params;
const { item } = Astro.props as { item: ActualiteItem };
const { siteInfo, styleSettings, siteSettings, navigation: navigationData, secondaryNavigation } = await getFrontendBootstrap();

const siteName = siteInfo.siteName || SITE_TITLE;
const siteDescription = siteInfo.siteDescription || SITE_DESCRIPTION;
setDefaultImageUrl(siteSettings.replacement_image || '');

if (!item) {
  throw new Error(`Actualité not found: ${slug}`);
}

const bodyClasses = [
  siteSettings.rounded === '1' ? 'border-rounded' : '',
  siteSettings.uppercase === '1' ? 'mode-uppercase' : '',
].filter(Boolean).join(' ');

const category = item.categories?.[0]?.name || '';
const date = item.published_date || item.created_at;
const formattedDate = date ? new Date(date).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';

// Featured image
let featuredImage = '';
if (item.featured_image) {
  const fi = item.featured_image as Record<string, any>;
  featuredImage = fi.sizes?.banner || fi.url || '';
}
if (!featuredImage) featuredImage = getDefaultImageUrl();

// Parse content blocks (flexible modules)
let blocks: any[] | null = null;
if (item.content) {
  try {
    const parsed = JSON.parse(item.content);
    if (Array.isArray(parsed) && parsed.every((b: any) => b && typeof b.type === 'string')) {
      blocks = parsed;
    }
  } catch {}
}

// Prev / Next navigation
const allResult = await getActualites({ status: 'published', limit: 10000 });
const allItems = Array.isArray(allResult) ? allResult : allResult.items;
const currentIndex = allItems.findIndex((a: ActualiteItem) => a.slug === slug);
const prevItem = currentIndex > 0 ? allItems[currentIndex - 1] : null;
const nextItem = currentIndex >= 0 && currentIndex < allItems.length - 1 ? allItems[currentIndex + 1] : null;

const justify = prevItem && nextItem ? 'space-between' : !prevItem && nextItem ? 'flex-end' : 'flex-start';
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`${item.title} | ${siteName}`} description={item.excerpt || siteDescription} styleSettings={styleSettings} siteSettings={siteSettings} />
    {blocks && <ModuleStyles blocks={blocks} />}
  </head>
  <body class={bodyClasses || undefined} data-cpt-slug="actualites" data-cpt-item-id={item.id}>
    <Header siteName={siteName} navigation={navigationData} secondaryNavigation={secondaryNavigation} siteSettings={siteSettings} styleSettings={styleSettings} />
    <main id="main" class="main-page page-single-news" role="main">
      <section>
        <article>
          <div class="head">
            <div class="container">
              {category && <div class="category">{category}</div>}
              <h1 class="title title-section-1">{item.title}</h1>
              {formattedDate && <time class="date">{formattedDate}</time>}
              {featuredImage && (
                <div class="illus-wrapper">
                  <img
                    src={optimizedImageUrl(featuredImage, 1200, 80)}
                    srcset={responsiveSrcset(featuredImage, [600, 900, 1200], 80) || undefined}
                    sizes="(max-width: 720px) 100vw, 720px"
                    alt={item.title}
                    class="illus"
                    loading="eager"
                  />
                </div>
              )}
            </div>
          </div>

          {/* Flexible content modules */}
          {blocks && blocks.length > 0 && (
            <div class="content content-blocks">
              <BlockRenderer blocks={blocks} pageTitle={item.title} />
            </div>
          )}

          {/* Prev / Next navigation */}
          {(prevItem || nextItem) && (
            <div class="container">
              <div class="btn-wrapper" style={`justify-content: ${justify}`}>
                {prevItem && (
                  <a href={`/actualites/${prevItem.slug}`} class="btn btn-tertiary prev">
                    &lt; <Fragment set:html={prevItem.title} />
                  </a>
                )}
                {nextItem && (
                  <a href={`/actualites/${nextItem.slug}`} class="btn btn-tertiary next">
                    <Fragment set:html={nextItem.title} /> &gt;
                  </a>
                )}
              </div>
            </div>
          )}
        </article>
      </section>
    </main>
    <Footer siteSettings={siteSettings} />
    <SiteOverlays siteSettings={siteSettings} />
    <DeferredLoader />
  </body>
</html>

<style is:global>
  .page-single-news {
    padding-bottom: 60px;
  }
  .page-single-news .head {
    padding-top: 60px;
    padding-bottom: 40px;
  }
  .page-single-news .head .category {
    margin-bottom: 8px;
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: .05em;
    color: var(--color-primary, #666);
    text-transform: uppercase;
    font-weight: 600;
  }
  .page-single-news .head .title {
    margin: 0;
  }
  .page-single-news .head .date {
    display: block;
    margin-top: 12px;
    font-size: 14px;
    color: #999;
  }
  .page-single-news .head .illus-wrapper {
    position: relative;
    width: 100%;
    margin-top: 30px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .border-rounded .page-single-news .head .illus-wrapper {
    border-radius: var(--border-radius, 0);
  }
  .page-single-news .head .illus {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .page-single-news .content-blocks {
    width: 100%;
    max-width: 100%;
    padding: 0;
  }
  .page-single-news .btn-wrapper {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 60px;
  }
  .page-single-news .btn-wrapper .prev,
  .page-single-news .btn-wrapper .next {
    max-width: 45%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 720px) {
    .page-single-news .head {
      padding-top: 30px;
      padding-bottom: 24px;
    }
    .page-single-news .btn-wrapper {
      flex-direction: column;
    }
    .page-single-news .btn-wrapper .prev,
    .page-single-news .btn-wrapper .next {
      max-width: 100%;
    }
  }
</style>
