---
import { getNavigation, type NavigationItem } from '../lib/api';

interface Props {
  navigation?: NavigationItem[];
  menuClass?: string;
  depth?: number;
  isSecondary?: boolean;
  side?: 'left' | 'right';
  mobile?: boolean;
}

const {
  menuClass = 'menu',
  depth = 3,
  isSecondary = false,
  side,
  mobile = false,
} = Astro.props;

const navigation = Astro.props.navigation || await getNavigation();

// For center menu style, split nav items in half
let items = navigation;
if (side === 'left') {
  items = navigation.slice(0, Math.ceil(navigation.length / 2));
} else if (side === 'right') {
  items = navigation.slice(Math.ceil(navigation.length / 2));
}

function hasChildren(item: any): boolean {
  return !!(item.children && item.children.length > 0);
}

function itemUrl(item: any): string {
  // Menu-based items have a url field; page-based fallback uses slug
  if (item.url) return item.url;
  if (item.slug) return `/pages/${item.slug}`;
  return '#';
}

function itemTarget(item: any): string | undefined {
  return item.open_in_new_tab ? '_blank' : undefined;
}
---

<div class="menu-wrapper">
  <ul class={menuClass}>
    {items.map((item) => (
      <li class:list={[
        hasChildren(item) ? 'menu-item-has-children' : '',
        item.status === 'private' ? 'nav-private' : '',
      ]} data-private={item.status === 'private' ? 'true' : undefined}>
        <a href={itemUrl(item)} target={itemTarget(item)}>{item.title}</a>
        {hasChildren(item) && depth >= 2 && (
          <ul class="sub-menu">
            {item.children!.map((child: any) => (
              <li class:list={[
                hasChildren(child) ? 'menu-item-has-children' : '',
                child.status === 'private' ? 'nav-private' : '',
              ]} data-private={child.status === 'private' ? 'true' : undefined}>
                <a href={itemUrl(child)} target={itemTarget(child)}>{child.title}</a>
                {hasChildren(child) && depth >= 3 && (
                  <ul class="sub-menu">
                    {child.children!.map((grandchild: any) => (
                      <li>
                        <a href={itemUrl(grandchild)} target={itemTarget(grandchild)}>{grandchild.title}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
  .nav-private { display: none; }
  :global(body.user-authenticated) .nav-private { display: list-item; }
</style>

<script>
  const token = localStorage.getItem('auth_token') || sessionStorage.getItem('auth_token');
  if (token) document.body.classList.add('user-authenticated');
</script>
