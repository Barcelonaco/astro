---
/**
 * ThemeInjector — Server-side version.
 * Accepts pre-fetched settings as prop to avoid extra API call during component render.
 * Falls back to fetching if no prop provided (for backward compat).
 */
import { getStyleSettings } from '../lib/api';

interface Props {
  styleSettings?: Record<string, string>;
}

const THEME_COLORS: Record<string, Record<string, string>> = {
  default: { accent: '#2337ff', accentDark: '#000d8a', black: '15, 18, 25', gray: '96, 115, 159', grayLight: '229, 233, 240', grayDark: '34, 41, 57' },
  dark: { accent: '#00d4ff', accentDark: '#0088cc', black: '255, 255, 255', gray: '160, 175, 199', grayLight: '30, 33, 40', grayDark: '220, 225, 232' },
  minimal: { accent: '#000000', accentDark: '#333333', black: '0, 0, 0', gray: '100, 100, 100', grayLight: '240, 240, 240', grayDark: '50, 50, 50' },
  colorful: { accent: '#ff6b6b', accentDark: '#ee5a5a', black: '20, 20, 30', gray: '100, 110, 140', grayLight: '240, 242, 250', grayDark: '40, 44, 52' },
  nature: { accent: '#2ecc71', accentDark: '#27ae60', black: '30, 39, 46', gray: '119, 140, 163', grayLight: '223, 230, 233', grayDark: '45, 52, 54' },
};

const FONT_TITLES: Record<string, string> = {
  'anek-odia': 'Anek Odia', 'crimson-pro': 'Crimson Pro', 'dm-serif': 'DM Serif Display',
  encode: 'Encode Sans Expanded', inter: 'Inter', jakarta: 'Plus Jakarta Sans',
  jost: 'Jost', kanit: 'Kanit', 'lilita-one': 'Lilita One', lora: 'Lora',
  montserrat: 'Montserrat', onest: 'Onest', 'open-sans': 'Open Sans', oswald: 'Oswald',
  'playfair-display': 'Playfair Display', poppins: 'Poppins', prompt: 'Prompt',
  raleway: 'Raleway', rubik: 'Rubik', ubuntu: 'Ubuntu', 'zilla-slab': 'Zilla Slab',
};

const FONT_GENERALS: Record<string, string> = {
  barlow: 'Barlow', bitter: 'Bitter', 'cormorant-garamond': 'Cormorant Garamond',
  encode: 'Encode Sans Expanded', exo: 'Exo', inter: 'Inter', jakarta: 'Plus Jakarta Sans',
  jost: 'Jost', kanit: 'Kanit', lora: 'Lora', montserrat: 'Montserrat', onest: 'Onest',
  'open-sans': 'Open Sans', roboto: 'Roboto', rubik: 'Rubik',
};


// Use pre-fetched settings or fetch as fallback
const settings = Astro.props.styleSettings || await getStyleSettings();

// Theme colors
const useChildTheme = settings.theme_use_child === '1';
const activeTheme = settings.active_theme || 'default';
const themeColors = useChildTheme ? THEME_COLORS[activeTheme] : null;
const isDark = useChildTheme && activeTheme === 'dark';

// Nickl colors
const colorDefault = settings.text_color || '#001527';
const colorPrimary = settings.primary_color || '#006a9b';
const colorPrimaryBis = settings.brand_primary_dark || colorPrimary;
const colorSecondary = settings.secondary_color || '#ea644e';
const colorSecondaryBis = settings.brand_secondary_dark || colorSecondary;
const colorTertiary = settings.tertiary_color || '#d0d0d0';
const colorBackground = settings.background_color || '#ffffff';
const colorForm = settings.bg_form_field || '#e3f3fc';

// Fonts
const fontTitleKey = settings.font_title || 'poppins';
const fontGeneralKey = settings.font_general || 'jakarta';
const fontTitle = FONT_TITLES[fontTitleKey] || 'Poppins';
const fontGeneral = FONT_GENERALS[fontGeneralKey] || 'Plus Jakarta Sans';

// Logo
const logoHeight = parseInt(settings.logo_height || '100', 10);

// Google Fonts — fetch at build time, download woff2 files locally, rewrite URLs
import fs from 'node:fs';
import path from 'node:path';

const fontsToLoad = new Set<string>();
if (fontTitle) fontsToLoad.add(fontTitle);
if (fontGeneral) fontsToLoad.add(fontGeneral);
const googleFontsUrl = fontsToLoad.size > 0
  ? 'https://fonts.googleapis.com/css2?' +
    Array.from(fontsToLoad).map(f => `family=${f.replace(/ /g, '+')}:wght@400;500;600;700`).join('&') +
    '&display=swap'
  : '';

// Fetch @font-face CSS and self-host the woff2 files
let googleFontsCss = '';
const fontPreloads: string[] = [];
if (googleFontsUrl) {
  try {
    const res = await fetch(googleFontsUrl, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36' }
    });
    if (res.ok) {
      let css = await res.text();

      // Download each woff2 file and save locally
      const fontsDir = path.join(process.cwd(), 'public', 'fonts', 'google');
      fs.mkdirSync(fontsDir, { recursive: true });

      const urlRegex = /url\((https:\/\/fonts\.gstatic\.com\/[^)]+\.woff2)\)/g;
      let match;
      const downloads: Promise<void>[] = [];
      const urlMap = new Map<string, string>();

      while ((match = urlRegex.exec(css)) !== null) {
        const remoteUrl = match[1];
        if (urlMap.has(remoteUrl)) continue;
        // Generate local filename from URL
        const filename = remoteUrl.split('/').slice(-2).join('-').replace(/[^a-zA-Z0-9._-]/g, '');
        const localPath = `/fonts/google/${filename}`;
        urlMap.set(remoteUrl, localPath);

        const filePath = path.join(fontsDir, filename);
        if (!fs.existsSync(filePath)) {
          downloads.push(
            fetch(remoteUrl).then(r => r.arrayBuffer()).then(buf => {
              fs.writeFileSync(filePath, Buffer.from(buf));
            }).catch(() => {})
          );
        }
      }

      await Promise.all(downloads);

      // Rewrite URLs in CSS to local paths
      for (const [remote, local] of urlMap) {
        css = css.replaceAll(remote, local);
      }

      // Inline critical font files (weight 400 latin) as base64 data URIs
      // This embeds ~26KB of woff2 directly in the HTML — zero network request, zero CLS
      const blocks = css.split(/(?=@font-face)/);
      const inlinedFamilies = new Set<string>();
      googleFontsCss = blocks.map(block => {
        if (!block.includes('font-weight')) return block;
        // Only inline weight 400, latin subset (not latin-ext, cyrillic, etc.)
        if (!/font-weight:\s*400/.test(block)) return block;
        if (/unicode-range:\s*U\+0100/i.test(block)) return block; // latin-ext
        if (/cyrillic|greek|vietnamese/i.test(block)) return block;
        const urlM = block.match(/url\(([^)]+\.woff2)\)/);
        const famM = block.match(/font-family:\s*'([^']+)'/);
        if (!urlM || !famM || inlinedFamilies.has(famM[1])) return block;
        // Read local file and convert to base64 data URI
        const localPath = urlM[1]; // e.g. /fonts/google/xxx.woff2
        const filePath = path.join(process.cwd(), 'public', localPath);
        if (fs.existsSync(filePath)) {
          const fontBuffer = fs.readFileSync(filePath);
          const b64 = fontBuffer.toString('base64');
          inlinedFamilies.add(famM[1]);
          return block.replace(urlM[0], `url(data:font/woff2;base64,${b64})`);
        }
        return block;
      }).join('');
    }
  } catch {}
}

// Build CSS variables string
const cssVars: string[] = [];
if (themeColors) {
  cssVars.push(`--accent:${themeColors.accent}`);
  cssVars.push(`--accent-dark:${themeColors.accentDark}`);
  cssVars.push(`--black:${themeColors.black}`);
  cssVars.push(`--gray:${themeColors.gray}`);
  cssVars.push(`--gray-light:${themeColors.grayLight}`);
  cssVars.push(`--gray-dark:${themeColors.grayDark}`);
}
cssVars.push(`--color-default:${colorDefault}`);
cssVars.push(`--color-primary:${colorPrimary}`);
cssVars.push(`--color-primary-bis:${colorPrimaryBis}`);
cssVars.push(`--color-secondary:${colorSecondary}`);
cssVars.push(`--color-secondary-bis:${colorSecondaryBis}`);
cssVars.push(`--color-tertiary:${colorTertiary}`);
cssVars.push(`--color-background:${colorBackground}`);
cssVars.push(`--color-form:${colorForm}`);
cssVars.push(`--font-title:'${fontTitle}',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif`);
cssVars.push(`--font-general:'${fontGeneral}',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif`);
if (!isNaN(logoHeight)) cssVars.push(`--logo-height:${logoHeight}px`);
---

{/* Inline CSS variables — no client-side fetch needed */}
<style set:html={`:root{${cssVars.join(';')}}`} />

{/* Google Fonts — inlined at build time to avoid external blocking request */}
{googleFontsCss ? (
  <style set:html={googleFontsCss} />
) : googleFontsUrl ? (
  <link rel="stylesheet" href={googleFontsUrl} media="print" onload="this.media='all'" />
) : null}
