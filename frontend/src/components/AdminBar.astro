---
/**
 * AdminBar — front-end admin toolbar (client-side only).
 * Visible when the user has a valid JWT token in localStorage.
 * Renders a fixed bar at the top of the page with links to the back-office.
 */
interface Props {
  siteSettings?: Record<string, string>;
}

const { siteSettings: s = {} } = Astro.props;
---

<script>
document.addEventListener('DOMContentLoaded', function() {
  const token = localStorage.getItem('token');
  if (!token) return;

  const adminUrl = window.location.origin + '/admin';

  // Decode JWT payload to get user info
  let user = null;
  try {
    const payload = JSON.parse(atob(token.split('.')[1]));
    // Check expiry
    if (payload.exp && payload.exp * 1000 < Date.now()) {
      localStorage.removeItem('token');
      return;
    }
    user = payload;
  } catch (e) {
    return;
  }

  // Build admin bar
  const bar = document.createElement('div');
  bar.id = 'admin-bar';
  bar.innerHTML = `
    <div class="admin-bar-inner">
      <div class="admin-bar-left">
        <a href="${adminUrl}" class="admin-bar-logo" title="Tableau de bord">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </a>
        ${document.body.dataset.pageId ? `<a href="${adminUrl}/#builder:${document.body.dataset.pageId}" class="admin-bar-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Modifier la page</a>` : ''}
        ${document.body.dataset.cptSlug && document.body.dataset.cptItemId ? `<a href="${adminUrl}/#cpt-edit:${document.body.dataset.cptSlug}:${document.body.dataset.cptItemId}" class="admin-bar-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Modifier</a>` : ''}
      </div>
      <div class="admin-bar-right">
        <span class="admin-bar-user">Bonjour, ${user.name || user.email?.split('@')[0] || 'Admin'}</span>
        <a href="#" class="admin-bar-link admin-bar-logout">Déconnexion</a>
      </div>
    </div>
  `;

  // Inject styles
  const style = document.createElement('style');
  style.textContent = `
    #admin-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 32px;
      background: #23282d;
      color: #c3c4c7;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 13px;
      z-index: 100000;
      line-height: 32px;
    }
    #admin-bar a { color: #c3c4c7; text-decoration: none; }
    #admin-bar a:hover { color: #00b9eb; }
    .admin-bar-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 8px;
      height: 100%;
      max-width: 100%;
    }
    .admin-bar-left, .admin-bar-right {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .admin-bar-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: #0073aa;
      margin-left: -8px;
      margin-right: 4px;
      color: #fff !important;
    }
    .admin-bar-logo:hover { background: #00b9eb; }
    .admin-bar-link {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 0 8px;
      height: 32px;
      transition: color 0.15s;
    }
    .admin-bar-link svg { opacity: 0.8; }
    .admin-bar-link:hover svg { opacity: 1; }
    .admin-bar-user {
      padding: 0 8px;
      color: #c3c4c7;
    }
    body.has-admin-bar {
      padding-top: 32px !important;
    }
    body.has-admin-bar .site-header,
    body.has-admin-bar header,
    body.has-admin-bar .header-wrapper,
    body.has-admin-bar #header .header-wrapper {
      top: 32px;
    }
    @media (max-width: 600px) {
      .admin-bar-user { display: none; }
    }
  `;

  document.head.appendChild(style);
  document.body.prepend(bar);
  document.body.classList.add('has-admin-bar');

  // Logout handler
  bar.querySelector('.admin-bar-logout')?.addEventListener('click', (e) => {
    e.preventDefault();
    localStorage.removeItem('token');
    bar.remove();
    document.body.classList.remove('has-admin-bar');
  });
});
</script>
