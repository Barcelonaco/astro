  // ── Event binding ─────────────────────────────────────────────────────
  function bindStepEvents(): void {
    const root = document.getElementById('poolp-step-content')
    if (!root) return

    root.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(input => {
      input.addEventListener('input', () => {
        const v = parseFloat(input.value.replace(',', '.'))
        if (!isNaN(v)) updateInput({ [input.name]: v } as Partial<PoolpInput>)
      })
    })
    root.querySelectorAll<HTMLInputElement>('input[type="text"]').forEach(input => {
      input.addEventListener('input', () => updateInput({ [input.name]: input.value } as Partial<PoolpInput>))
    })

    root.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.toggle as keyof PoolpInput
        const current = getState().input[key] as boolean
        updateInput({ [key]: !current } as Partial<PoolpInput>)
      })
    })

    root.querySelectorAll<HTMLButtonElement>('[data-go-step]').forEach(btn => {
      btn.addEventListener('click', () => setStep(Number(btn.dataset.goStep) as 1|3|4|5|6|7))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-filtre]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ filtre: btn.dataset.setFiltre as FiltreType }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-pompe]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ pompe: btn.dataset.setPompe as PompeType }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-traitement]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.disabled) return
        updateInput({ traitement: btn.dataset.setTraitement as Traitement })
      })
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-bypass]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ bypass_pac: btn.dataset.setBypass === '1' }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-finition]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ finition_id: Number(btn.dataset.setFinition) }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-set-mode]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ mode_livraison: btn.dataset.setMode as 'kit'|'montee' }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-led]').forEach(btn => {
      btn.addEventListener('click', () => updateInput({ projecteurs_led: Number(btn.dataset.led) as 0|1|2 }))
    })
    root.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
      btn.addEventListener('click', () => onRecapAction(btn.dataset.action as string))
    })
  }

  async function onRecapAction(action: string): Promise<void> {
    const status = document.getElementById('poolp-recap-status')
    const setStatus = (msg: string) => { if (status) status.textContent = msg }
    const s = getState()

    if (action === 'save-project') {
      setStatus('Sauvegarde…')
      const result = await saveProject(s.input)
      if (!result) return setStatus('Erreur lors de la sauvegarde.')
      setProjectToken(result.token)
      const url = new URL(window.location.href)
      url.searchParams.set('p', result.token)
      window.history.replaceState({}, '', url.toString())
      setStatus(`Projet sauvegardé (réf : ${result.token.slice(0, 8)}…)`)
      return
    }
    if (action === 'export-pdf') {
      setStatus('Génération du PDF…')
      let token = s.projectToken
      if (!token) {
        const saved = await saveProject(s.input)
        if (!saved) return setStatus('Sauvegarde du projet échouée.')
        setProjectToken(saved.token); token = saved.token
      }
      const result = await exportProjectPdf(token)
      if (!result) return setStatus('Erreur PDF — vérifiez que Dompdf est installé côté backend.')
      window.open(result.url, '_blank')
      setStatus(`PDF prêt : ${result.url}`)
      return
    }
    if (action === 'add-to-cart') {
      setStatus('Ajout au panier…')
      let token = s.projectToken
      if (!token) {
        const saved = await saveProject(s.input)
        if (!saved) return setStatus('Sauvegarde du projet échouée.')
        setProjectToken(saved.token); token = saved.token
      }
      const result = await addProjectToCart(token)
      if (!result) return setStatus("Le panier nécessite l'activation du plugin ecommerce.")
      setStatus('Ajouté au panier ✓')
      window.location.href = '/panier'
    }
  }

  // ── Subscribe + bootstrap ─────────────────────────────────────────────
  subscribe(state => {
    renderStepper(state.step)
    renderSidebar()
    renderStep()
  })

  void (async () => {
    const ok = await clientBootstrap()
    if (ok) void runCompute()
  })()
</script>
