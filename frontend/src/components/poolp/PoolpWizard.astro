  // ── Step 4 : Box result ───────────────────────────────────────────────
  function stepBoxResult(s: { input: PoolpInput; computed: ReturnType<typeof getState>['computed'] }): string {
    const c = s.computed
    if (!c || c.error || !c.box) {
      const msg = c?.error === 'volume_hors_gamme'
        ? "Volume hors gamme — votre bassin dépasse la capacité maximale (75 m³). Contactez l'équipe pour un devis adapté."
        : 'Calcul en cours…'
      return `<div class="poolp-step-title">Étape 3 — Votre box</div>
        <div class="poolp-error">${escapeHtml(msg)}</div>
        <div class="poolp-nav-btns"><button class="poolp-btn sec" data-go-step="3" type="button">← Étape précédente</button></div>`
    }

    const eqEntries = Object.entries(c.equipements || {}).filter(([, eq]) => eq)
    const cards = eqEntries.map(([key, eq]) => {
      const iconKey = (key === 'filtre') ? (s.input.filtre === 'cartouche' ? 'cartouche' : 'sable')
        : (key === 'pompe') ? (s.input.pompe === 'variable' ? 'variable' : 'mono')
        : (key === 'traitement') ? (s.input.traitement || 'aucun')
        : (key === 'coffret_programmation') ? 'coffret_wifi'
        : (key === 'coffret_distribution') ? 'coffret_distrib'
        : 'coffret_distrib'
      return `<div class="poolp-product-card">
        <div class="poolp-product-img">${ICONS[iconKey] || ICONS.coffret_distrib}</div>
        <div class="poolp-product-body">
          <div class="poolp-product-name">${escapeHtml(eq!.label)}</div>
          <div class="poolp-product-ref">${eq!.reference ? `Réf. ${escapeHtml(eq!.reference)}` : 'Réf. [à fournir Scanzi]'}</div>
        </div>
      </div>`
    }).join('')

    return `
      <div class="poolp-step-title">Étape 3 — Votre box configurée</div>
      <p class="poolp-step-sub">Voici les équipements sélectionnés pour votre bassin de ${fmtVol(c.hydraulic.volume)}. Tout est intégré dans votre box POOLP.</p>

      <div class="poolp-product-grid">
        ${cards}
        <div class="poolp-product-card featured">
          <div class="poolp-product-img">${(() => {
            const apiOrigin = API_URL.replace(/\/api\/?$/, '')
            const src = c.box.photo_url ? resolveImageUrl(c.box.photo_url, apiOrigin, 'banner') : ''
            return src ? `<img src="${escapeHtml(src)}" alt="${escapeHtml(c.box.label)}">` : ICONS.box_l
          })()}</div>
          <div class="poolp-product-body">
            <div class="poolp-product-name">${escapeHtml(c.box.label)} — ${c.box.surface_utile} m²</div>
            <div class="poolp-product-ref">Inclut tous les équipements ci-dessus</div>
          </div>
        </div>
      </div>

      <div class="poolp-nav-btns">
        <button class="poolp-btn sec" data-go-step="3" type="button">← Étape précédente</button>
        <button class="poolp-btn cta" data-go-step="5" type="button">Choisir les finitions →</button>
      </div>`
  }

  // ── Step 5 : Finitions ────────────────────────────────────────────────
  function stepFinitions(s: { input: PoolpInput }): string {
    const swatches = (finitions as Array<{ id: number; title: string; custom_fields: Record<string, unknown> }>).map(f => {
      const cf = f.custom_fields || {}
      const hex = (cf as { color_hex?: string }).color_hex || '#ddd'
      const isSel = s.input.finition_id === f.id
      return `<button class="poolp-color-swatch" data-set-finition="${f.id}" type="button">
        <div class="poolp-color-circle ${isSel ? 'sel' : ''}" style="background:${escapeHtml(hex)}"></div>
        <div class="poolp-color-name ${isSel ? 'sel' : ''}">${escapeHtml(f.title)}</div>
      </button>`
    }).join('') || '<div class="poolp-empty-note">Aucune finition disponible. Configurez le catalogue dans l\'admin.</div>'

    const apiOrigin = API_URL.replace(/\/api\/?$/, '')
    const selectedFin = finitions.find(f => f.id === s.input.finition_id)
    let previewRaw: unknown = selectedFin ? (selectedFin.custom_fields as { preview_image?: unknown }).preview_image : null
    if (typeof previewRaw === 'string' && previewRaw.trim().startsWith('{')) {
      try { previewRaw = JSON.parse(previewRaw) } catch { /* keep raw */ }
    }
    const previewSrc = previewRaw ? resolveImageUrl(previewRaw, apiOrigin, 'banner') : ''
    const previewBlock = previewSrc
      ? `<div class="poolp-color-preview has-img"><img src="${escapeHtml(previewSrc)}" alt="${escapeHtml(selectedFin?.title || 'Aperçu finition')}"></div>`
      : `<div class="poolp-color-preview">${selectedFin ? 'Aperçu indisponible' : 'Sélectionnez une finition pour voir l\'aperçu.'}</div>`

    return `
      <div class="poolp-step-title">Étape 4 — Finitions</div>
      <p class="poolp-step-sub">Choisissez la couleur des panneaux thermolaqués de votre box.</p>

      <div class="poolp-color-grid">${swatches}</div>

      ${previewBlock}
      
      <div class="poolp-nav-btns">
        <button class="poolp-btn sec" data-go-step="4" type="button">← Étape précédente</button>
        <button class="poolp-btn cta" data-go-step="6" type="button">Étape suivante →</button>
      </div>`
  }

