---
/**
 * SiteOverlays — Regroupe Popup/Alert, Bouton flottant et Mode maintenance.
 * Inclure une seule fois dans les layouts de page (body).
 */

import { getSiteInfo } from '../consts';
import { MEDIA_ORIGIN, type NavigationItem } from '../lib/api';
interface Props {
  siteName?: string;
  siteSettings?: Record<string, string>;
}

const { siteName: propSiteName, siteSettings: s = {} } = Astro.props;

const siteName = propSiteName || (await getSiteInfo()).siteName;

const apiOrigin = MEDIA_ORIGIN;

// Popup / Alert
const showAlert = s.show_alert === '1';
const blocColorAlert = s.bloc_color_alert || 'no-background-color';
const alertText = s.alert_text || '';
const alertCtaUrl = s.alert_cta_url || '';
const alertCtaText = s.alert_cta_text || '';
const alertCta2Url = s.alert_cta2_url || '';
const alertCta2Text = s.alert_cta2_text || '';
const hasAlertCtas = (alertCtaUrl && alertCtaText) || (alertCta2Url && alertCta2Text);

// Floating button
const showBtn = s.show_btn === '1';
const floatingBtnLink = s.floating_btn_link || '';
const floatingBtnLinkTitle = s.floating_btn_link_title || '';
const floatingBtnImg = s.floating_btn_img || '';

// Maintenance
const isMaintenance = s.is_maintenance === '1';
const logoUrl = s.logo_white || '';
function resolveUrl(url: string) {
  if (!url) return '';
  if (url.startsWith('http')) return url;
  return `${apiOrigin}${url.startsWith('/') ? '' : '/'}${url}`;
}
const logo = resolveUrl(logoUrl);
const replacementImage = resolveUrl(s.replacement_image || '');
const titleMaintenance = s.title_maintenance || 'Site en maintenance';
const textMaintenance = s.text_maintenance || '';
const showInfos = s.show_infos === '1';
const showRs = s.show_rs === '1';
const phone = s.phone || '';
const email = s.email || '';
const schedule = s.schedule || '';

const _socialSvg = {
