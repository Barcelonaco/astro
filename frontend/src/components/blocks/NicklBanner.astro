---
/**
 * Module Banner — Reproduit banner.blade.php
 * En-tête de page avec image de fond, titre H1 ou P.
 * Hauteurs : small, medium, large, none.
 */
import { resolveImageUrl, optimizedImageUrl } from '../../lib/module-helpers';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
const apiOrigin = new URL(API_URL).origin;

const number = (data.id_bloc as string) || 'section_0';
const heightBanner = (data.banner_height as string) || 'small';
const titleInHeader = data.title_in_header !== 'hideTitle' ? 'showTitle' : 'hideTitle';
const h1InHeader = (data.h1_in_header as string) || 'yes';
const title = (data.title as string) || '';
const titleSize = (data.title_size as string) || '';
const imgBanner = data.image as any;
const imgUrl = resolveImageUrl(imgBanner, apiOrigin);

const hideTitleClass = titleInHeader === 'hideTitle' ? ' hide_banner_title' : '';
const heightClass = heightBanner ? ` ${heightBanner}` : ' small';
const titleSizeClass = titleSize ? ` h1-${titleSize}` : '';
---

<div
  id={number}
  class={`module module-banner-page${hideTitleClass}${heightClass}${titleSizeClass}`}
>
  {heightBanner !== 'none' && imgUrl && (
    <div class="background">
      <img src={optimizedImageUrl(imgUrl, 1440, 55)} width="1440" height="600" fetchpriority="high" loading="eager" decoding="sync" alt="" class="illus" />
    </div>
  )}

  <div class="container-large">
    <div class="desc">
      {titleInHeader !== 'hideTitle' && (
        h1InHeader === 'yes' ? (
          <h1 class="title title-section-1">
            <Fragment set:html={title} />
          </h1>
        ) : (
          <p class="title title-section-1">
            <Fragment set:html={title} />
          </p>
        )
      )}
    </div>
  </div>
</div>

<script is:inline>
(function(){
  var banner = document.querySelector('.module-banner-page');
  if (!banner) return;
  var header = document.getElementById('header');
  if (!header) return;
  var isTransparent = header.classList.contains('background-transparent');
  var size = banner.classList.contains('large') ? 'large'
           : banner.classList.contains('medium') ? 'medium'
           : banner.classList.contains('small') ? 'small' : null;
  if (!size) return;
  var hh = isTransparent ? 0 : header.offsetHeight;
  var vh = window.innerHeight;
  var heights = { large: vh - hh, medium: Math.round(vh * 0.7), small: Math.round(vh * 0.5) };
  banner.style.height = heights[size] + 'px';
  banner.style.overflow = 'hidden';
  // Positionner le titre en bas via absolute positioning
  var container = banner.querySelector('.container-large');
  if (container) {
    container.style.position = 'absolute';
    container.style.bottom = '0';
    container.style.left = '0';
    container.style.width = '100%';
    container.style.zIndex = '10';
  }
  // Neutraliser le ::before CSS qui crée une hauteur parasite
  var s = document.createElement('style');
  s.textContent = '.module-banner-page .desc::before{padding-top:0!important;min-height:0!important}';
  document.head.appendChild(s);
})();
</script>
