---
/**
 * Module Banner — Reproduit banner.blade.php
 * En-tete de page avec image de fond, titre H1 ou P.
 * Hauteurs : small, medium, large, none.
 */
import { buildModuleClasses, resolveBackgroundImage } from '../../lib/module-classes';
import { resolveImageUrl, resolveImageAlt, resolveImageTitle, resolveImageDimensions, optimizedImageUrl, responsiveSrcset, getPreset } from '../../lib/module-helpers';
import { MEDIA_ORIGIN } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const apiOrigin = MEDIA_ORIGIN;

/* --- BlockParams standard --- */
const id = (data.id_bloc as string) || 'section_0';
const isVisible = (data.is_visible ?? 'yes') !== 'no';
const classes = buildModuleClasses(data);
const backgroundImage = resolveBackgroundImage(data, apiOrigin);
const p = getPreset('banner');

/* --- Champs specifiques banner --- */
const heightBanner = (data.banner_height as string) || 'small';
const titleInHeader = data.title_in_header !== 'hideTitle' ? 'showTitle' : 'hideTitle';
const h1InHeader = (data.h1_in_header as string) || 'yes';
const title = (data.title as string) || '';
const titleSize = (data.title_size as string) || '';
const imgBanner = data.image as any;
const imgUrl = resolveImageUrl(imgBanner, apiOrigin);
const imgAlt = resolveImageAlt(imgBanner);
const imgTitle = resolveImageTitle(imgBanner);
const rawBannerUrl = typeof imgBanner === 'string' ? imgBanner : (imgBanner as any)?.url || '';
const bannerSrcset = responsiveSrcset(rawBannerUrl, p.srcsetWidths, p.srcsetQuality);
const imgDims = resolveImageDimensions(imgBanner);

const hideTitleClass = titleInHeader === 'hideTitle' ? ' hide_banner_title' : '';
const heightClass = heightBanner ? ` ${heightBanner}` : ' small';
const titleSizeClass = titleSize ? ` h1-${titleSize}` : '';
---

{isVisible && (
  <div
    id={id}
    class={`module module-banner-page${hideTitleClass}${heightClass}${titleSizeClass} ${classes}`}
  >
    {/* Background image BlockParams (bg_img + opacity) */}
    {backgroundImage && backgroundImage.url && (
      <div
        class="background background-overlay"
        style={`background-image: url(${backgroundImage.url}); opacity: ${Number(backgroundImage.opacity ?? 10) / 100};`}
      />
    )}

    {/* Image banner principale */}
    {heightBanner !== 'none' && imgUrl && (
      <div class="background">
        <img src={optimizedImageUrl(imgUrl, p.width, p.quality)} srcset={bannerSrcset || undefined} sizes="100vw" width={imgDims.width || 1440} height={imgDims.height || 600} fetchpriority="high" loading="eager" decoding="sync" alt={imgAlt} title={imgTitle || undefined} class="illus" />
      </div>
    )}

    <div class="container-large">
      <div class="desc">
        {titleInHeader !== 'hideTitle' && (
          h1InHeader === 'yes' ? (
            <h1 class="title title-section-1">
              <Fragment set:html={title} />
            </h1>
          ) : (
            <p class="title title-section-1">
              <Fragment set:html={title} />
            </p>
          )
        )}
      </div>
    </div>
  </div>
)}