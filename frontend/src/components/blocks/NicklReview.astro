---
/**
 * Module Review — Intégration TrustIndex
 * Charge le widget TrustIndex via son ID pour afficher les avis (Google, Airbnb, etc.)
 */
import NicklModuleWrapper from './NicklModuleWrapper.astro';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const reviewsSrc = (data.reviews_src as string) || 'google';
const widgetId = (data.trustindex_widget_id as string) || '';
---

<NicklModuleWrapper data={data} moduleName="review" containerLarge>
  {widgetId ? (
    <div class="trustindex-widget-wrapper" data-ti-widget-id={widgetId}>
      <div class="ti-placeholder" style="min-height:200px;"></div>
    </div>
  ) : (
    <p class="placeholder-message" style="text-align:center;opacity:0.6;">
      Aucun Widget ID TrustIndex configuré pour les avis ({reviewsSrc}).
    </p>
  )}
</NicklModuleWrapper>

{widgetId && (
  <script is:inline>
  (function(){
    var loaded=false;
    var el=document.querySelector('[data-ti-widget-id]');
    if(!el)return;
    var id=el.getAttribute('data-ti-widget-id');
    function load(){
      if(loaded)return;loaded=true;
      var s=document.createElement('script');
      s.src='https://cdn.trustindex.io/loader.js?'+id;
      s.defer=true;
      el.appendChild(s);
    }
    if('IntersectionObserver' in window){
      new IntersectionObserver(function(entries,obs){
        if(entries[0].isIntersecting){load();obs.disconnect();}
      },{rootMargin:'200px'}).observe(el);
    }else{
      window.addEventListener('load',load);
    }
  })();
  </script>
)}

