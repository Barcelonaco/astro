---
/**
 * Module Review — Intégration TrustIndex
 * Charge le widget TrustIndex via son ID pour afficher les avis (Google, Airbnb, etc.)
 */
import NicklModuleWrapper from './NicklModuleWrapper.astro';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const reviewsSrc = (data.reviews_src as string) || 'google';
const widgetId = (data.trustindex_widget_id as string) || '';
---

<NicklModuleWrapper data={data} moduleName="review" containerLarge>
  {widgetId ? (
    <div class="trustindex-widget-wrapper">
      <script is:inline src={`https://cdn.trustindex.io/loader.js?${widgetId}`} defer></script>
    </div>
  ) : (
    <p class="placeholder-message" style="text-align:center;opacity:0.6;">
      Aucun Widget ID TrustIndex configuré pour les avis ({reviewsSrc}).
    </p>
  )}
</NicklModuleWrapper>
