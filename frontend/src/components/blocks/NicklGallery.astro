---
import { buildModuleClasses, cleanHtml } from '../../lib/module-classes';
import { optimizedImageUrl, responsiveSrcset, getDefaultImageUrl } from '../../lib/module-helpers';

interface NicklGalleryProps {
  data: Record<string, any>;
}

const { data } = Astro.props as NicklGalleryProps;

/* ── Reproduit la logique du View Composer PHP (Gallery.php) ── */

// getId()
const id = (data.id_bloc as string) || '';

// getClasses() — délégué à buildModuleClasses (même logique)
const classes = buildModuleClasses(data);

// getBackgroundImage()
const bgImg = data.bg_img || null;
const backgroundImage = bgImg
  ? {
      url: bgImg?.sizes?.banner || bgImg?.url || '',
      opacity: data.bg_opacity !== '' && data.bg_opacity != null
        ? Number(data.bg_opacity) / 100
        : 1,
    }
  : null;

// title_bloc, title_style, title_align
const titleBloc = (data.title as string) ?? '';
const titleStyle = (data.title_style as string) ?? '';
const titleAlign = (data.title_align as string) ?? '';

// indexPopin
const indexPopin = Math.floor(Math.random() * 1000);

// get_options()
const width = (data as any)['container-width'] === 'large' ? '-large' : '';
const nbrColumn = (data.nbr_column as string) || '';
const typeImg = (data.type_img as string) || '';

// $sizes (image size key)
function getSizeKey(): string {
  if (typeImg === 'img-fluid') return 'module-gallery-fluid';
  if (typeImg === 'img-fixe' && nbrColumn === 'columns-1') return 'banner';
  if (typeImg === 'img-fixe' && nbrColumn === 'columns-2') return 'half';
  return 'module-gallery-fixe';
}
const sizes = getSizeKey();

const list = (data.list as any[]) ?? [];
---

<div id={id} class={`module module-gallery ${classes}`}>

  {backgroundImage && backgroundImage.url && (
        <div
          class="background"
          style={`background-image: url(${optimizedImageUrl(backgroundImage.url, 1200, 80)}); opacity: ${backgroundImage.opacity};`}
        />
      )}

  <div class={`container${width}`}>

    {titleBloc && (
      <div class={`bloc-title-module align-${titleAlign}`}>
        <h2 class={`title-module title-section-${titleStyle}`}>{titleBloc}</h2>
      </div>
    )}

    <ul class={`list ${nbrColumn} ${typeImg}`}>

      {list.map((gallery, index) => {
        const image = gallery.image || {};
        const imgSizes = image.sizes || {};
        const imgUrl = imgSizes[sizes] || image.url || getDefaultImageUrl();
        return (
          <li class="item">
            <button
              type="button"
              class="link js_open-popin"
              data-popin={"gallery-" + indexPopin}
              data-slide={String(index + 1)}
            >
              <div class="illus-wrapper">
                <img src={optimizedImageUrl(imgUrl, 600, 75)} srcset={responsiveSrcset(imgUrl, [300, 450, 600], 75) || undefined} sizes="(max-width: 600px) 50vw, 25vw" alt={image.alt || ''} class="illus" width="600" height="450" loading="lazy" fetchpriority="low" />
                <div class="overlay">
                  <span class="icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="24" viewBox="0 0 40 23.99" fill="currentColor"><path d="M20,0C12.76,0,5.52,4,0,12c11.04,16,28.96,16,40,0C34.48,4,27.25,0,20,0m0,20c-4.42,0-8.01-3.58-8.02-8.01S15.57,3.98,19.99,3.98c4.42,0,8.01,3.58,8.02,8.01,0,0,0,.01,0,.01,0,4.42-3.59,8-8,8"/><path d="M20,7.99c2.21,0,4,1.79,4,4s-1.79,4-4,4-4-1.79-4-4h0c0-2.21,1.79-4,4-4"/></svg>
                  </span>
                  Agrandir
                </div>
              </div>
              {(!!(gallery.tag) || !!(gallery.titre)) && (
                <div class="desc">
                  {gallery.tag && <p class="category">{gallery.tag}</p>}
                  {gallery.titre && (
                    <h2 class="title title-section-3" data-text={gallery.titre}>{gallery.titre}</h2>
                  )}
                  {gallery.desc && (
                    <div class="txt editor">
                      <p set:html={cleanHtml(gallery.desc).replace(/\n/g, '<br>')} />
                    </div>
                  )}
                  <span class="fake-btn btn btn-tertiary">En savoir plus</span>
                </div>
              )}
            </button>
          </li>
        );
      })}

    </ul>

  </div>

  <div class="popin-wrapper popin-gallery-wrapper" style="display: none;" data-popin={"gallery-" + indexPopin}>
    <div class="popin">

      <button type="button" class="btn-close js_close-popin" title="Fermer la popin">
        <span class="icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8,6.61L14.61,0l1.39,1.39-6.61,6.61,6.61,6.61-1.39,1.39-6.61-6.61L1.39,16l-1.39-1.39,6.61-6.61L0,1.39,1.39,0l6.61,6.61Z"/></svg>
        </span>
      </button>

      <div class="module module-images-slider full-width no-padding">
        <div class="container-large container-1">
          <div class="slider-wrapper">
            <div class="swiper slider js_images-slider">
              <div class="swiper-wrapper">

                {list.map((gallery) => {
                  const image = gallery.image || {};
                  const hasDesc = !!(gallery.titre) || !!(gallery.desc) || !!(gallery.link?.url);
                  return (
                    <div class={`swiper-slide item ${hasDesc ? 'has-desc' : 'no-desc'}`}>
                      <div class="illus-wrapper">
                        <img src={optimizedImageUrl(image.url || getDefaultImageUrl(), 800, 75)} srcset={responsiveSrcset(image.url || getDefaultImageUrl(), [400, 600, 800], 75) || undefined} sizes="100vw" alt={image.alt || ''} class="illus" width="600" height="450" loading="lazy" />
                      </div>
                      {hasDesc && (
                        <div class="container-large container-2">
                          <div class="desc">
                            {gallery.titre && (
                              <p class="title title-section-3">{gallery.titre}</p>
                            )}
                            {gallery.desc && (
                              <div class="txt editor">
                                <p set:html={cleanHtml(gallery.desc).replace(/\n/g, '<br>')} />
                              </div>
                            )}
                            {gallery.link?.url && (
                              <div class="btn-wrapper">
                                <a
                                  href={gallery.link.url}
                                  class="btn btn-primary"
                                  target={gallery.link.target || '_self'}
                                >{gallery.link.title}</a>
                              </div>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}

              </div>
            </div>
            <button type="button" class="slider-navigation prev js_images-slider-btn-prev" />
            <button type="button" class="slider-navigation next js_images-slider-btn-next" />
            <div class="slider-pagination js_images-slider-pagination" />
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<style is:global>
  /* Popin gallery — critical styles (reproduces _popins.scss + _images-slider.scss) */
  .popin-gallery-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    visibility: hidden;
    opacity: 0;
    z-index: 9999;
    transition: all .6s ease;
  }
  .popin-gallery-wrapper::before {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: .74;
    z-index: -1;
    background-color: #000;
    content: '';
  }
  .popin-gallery-wrapper.active {
    visibility: visible;
    opacity: 1;
  }
  .popin-gallery-wrapper .popin {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background-color: rgba(0, 0, 0, .5);
  }
  .popin-gallery-wrapper .popin .btn-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 70px;
    height: 70px;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: none;
    cursor: pointer;
  }
  .popin-gallery-wrapper .popin .btn-close .icon {
    display: block;
    max-width: 24px;
  }
  .popin-gallery-wrapper .popin .btn-close svg * {
    fill: #fff;
  }
  /* Swiper critical */
  .popin-gallery-wrapper .swiper {
    overflow: hidden;
    width: 100%;
    height: 100%;
  }
  .popin-gallery-wrapper .swiper-wrapper {
    display: flex;
    height: 100%;
  }
  .popin-gallery-wrapper .swiper-slide {
    flex-shrink: 0;
    width: 100%;
    height: 100%;
  }
  /* Slide item — reproduces .module-images-slider.full-width .item */
  .popin-gallery-wrapper .item {
    position: relative;
    display: flex;
    align-items: flex-end;
    height: 100vh;
    max-height: 100vh;
    color: #fff;
  }
  .popin-gallery-wrapper .item::after {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    z-index: 5;
    background: linear-gradient(0deg, rgba(0,0,0,.5) 50%, rgba(255,255,255,0) 100%);
    content: '';
  }
  .popin-gallery-wrapper .item.no-desc::after {
    display: none;
  }
  /* Image — full cover behind desc */
  .popin-gallery-wrapper .illus-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .popin-gallery-wrapper .illus {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  /* Desc overlay — reproduces .module-images-slider .desc */
  .popin-gallery-wrapper .container-large {
    max-width: 100vw;
  }
  .popin-gallery-wrapper .container-2 {
    padding-right: 0;
    padding-left: 0;
  }
  .popin-gallery-wrapper .desc {
    position: relative;
    width: 100%;
    padding: 0 3.5% 6%;
    z-index: 10;
    text-shadow: 0 0 20px rgba(0,0,0,.5);
  }
  .popin-gallery-wrapper .desc .title {
    margin: 0;
    max-width: 726px;
    text-align: inherit;
    color: #fff;
  }
  .popin-gallery-wrapper .desc .txt {
    max-width: 726px;
    margin-top: 18px;
  }
  .popin-gallery-wrapper .desc .btn-wrapper {
    margin-top: 30px;
  }
  /* Pagination — reproduces .module-images-slider.full-width .slider-pagination */
  .popin-gallery-wrapper .slider-pagination {
    top: auto;
    bottom: 0;
    padding-bottom: 2.72%;
  }
  .popin-gallery-wrapper .slider-pagination .swiper-pagination-bullet {
    background-color: #fff;
  }
  /* Navigation — reproduces .module-images-slider.full-width .slider-navigation */
  .popin-gallery-wrapper .slider-navigation::before {
    border-color: #fff;
  }
  .popin-gallery-wrapper .slider-navigation.prev {
    left: 8px;
  }
  .popin-gallery-wrapper .slider-navigation.next {
    right: 8px;
  }
  html.disable-scroll {
    overflow: hidden;
  }
</style>

<script is:inline>
(function() {
  function initGallerySwiper(el, slide) {
    // Destroy any existing broken instance (e.g. initialized while hidden)
    if (el.swiper) {
      el.swiper.destroy(true, true);
    }
    var count = el.querySelectorAll(':scope > .swiper-wrapper > .swiper-slide').length;
    if (count < 1) return;
    var w = el.closest('.slider-wrapper');
    var pagEl = w ? w.querySelector('.js_images-slider-pagination') : null;
    new window.Swiper(el, {
      loop: count > 2,
      speed: 750,
      slidesPerView: 1,
      initialSlide: (slide || 1) - 1,
      autoplay: false,
      navigation: {
        nextEl: w ? w.querySelector('.next') : null,
        prevEl: w ? w.querySelector('.prev') : null
      },
      pagination: { el: pagEl, type: 'bullets', clickable: true }
    });
  }

  function loadSwiper(callback) {
    if (window.Swiper) { callback(); return; }
    // Load Swiper CSS
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
    document.head.appendChild(link);
    // Load Swiper JS
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
    s.onload = callback;
    document.head.appendChild(s);
  }

  function openGalleryPopin(popinId, slide) {
    var wrapper = document.querySelector('.popin-wrapper[data-popin="' + popinId + '"]');
    if (!wrapper) return;

    wrapper.style.display = '';
    // Force reflow before adding active class for CSS transition
    wrapper.offsetHeight;
    wrapper.classList.add('active');
    document.documentElement.classList.add('disable-scroll');

    // Init Swiper (always destroy + recreate to get correct dimensions)
    var sliderEl = wrapper.querySelector('.js_images-slider');
    if (sliderEl) {
      loadSwiper(function() { initGallerySwiper(sliderEl, slide); });
    }
  }

  function closeGalleryPopin(wrapper) {
    if (!wrapper) return;
    wrapper.classList.remove('active');
    setTimeout(function() {
      document.documentElement.classList.remove('disable-scroll');
      wrapper.style.display = 'none';
    }, 600);
  }

  // Popin open
  document.querySelectorAll('.module-gallery .js_open-popin').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var popinId = this.getAttribute('data-popin');
      var slide = parseInt(this.getAttribute('data-slide'), 10) || 1;
      openGalleryPopin(popinId, slide);
    });
  });

  // Popin close
  document.querySelectorAll('.popin-gallery-wrapper .js_close-popin').forEach(function(btn) {
    btn.addEventListener('click', function() {
      closeGalleryPopin(this.closest('.popin-wrapper'));
    });
  });

  // Close on click outside
  document.querySelectorAll('.popin-gallery-wrapper').forEach(function(wrapper) {
    wrapper.addEventListener('click', function(e) {
      if (e.target === this) closeGalleryPopin(this);
    });
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var active = document.querySelector('.popin-gallery-wrapper.active');
      if (active) closeGalleryPopin(active);
    }
  });
})();
</script>
