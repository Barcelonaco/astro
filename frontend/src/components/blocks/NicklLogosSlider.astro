---
/**
 * Module LogosSlider — Reproduit logos-slider.blade.php
 * Carousel Swiper de logos avec liens optionnels.
 */
import NicklModuleWrapper from './NicklModuleWrapper.astro';
import { resolveLink } from '../../lib/module-classes';
import { resolveImageUrl, resolveImageAlt, getPreset } from '../../lib/module-helpers';
import { MEDIA_ORIGIN } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const apiOrigin = MEDIA_ORIGIN;

const logos = (data.logos as any[]) || [];
---

<NicklModuleWrapper data={data} moduleName="logos-slider">
  {logos.length > 0 && (
    <div class="slider-wrapper">
      <div class="swiper slider js_logos-slider">
        <div class="swiper-wrapper">
          {logos.map((logo) => {
            const link = resolveLink(logo.link);
            const logoUrl = resolveImageUrl(logo.logo, apiOrigin, 'module-logo', 'icon');
            const logoAlt = resolveImageAlt(logo.logo);

            return (
              <div class="swiper-slide item">
                {link ? (
                  <a href={link.url} class="link" target={link.target}>
                    <img src={logoUrl} alt={logoAlt} class="illus" width="200" height="100" loading="lazy" />
                  </a>
                ) : (
                  <div class="link">
                    <img src={logoUrl} alt={logoAlt} class="illus" width="200" height="100" loading="lazy" />
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
      <button type="button" class="slider-navigation js_logos-slider-btn-prev prev"></button>
      <button type="button" class="slider-navigation js_logos-slider-btn-next next"></button>
    </div>
  )}
</NicklModuleWrapper>
