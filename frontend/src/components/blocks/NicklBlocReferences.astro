---
/**
 * Module BlocReferences — Reproduit modules/references.blade.php
 * Affiche 3 références (manuelles ou automatiques) avec slider d'images,
 * catégorie, titre, nom client. Optionnel : lien vers l'archive.
 */
import NicklModuleWrapper from './NicklModuleWrapper.astro';
import { resolveLink } from '../../lib/module-classes';
import { resolveImageUrl, resolveImageAlt, optimizedImageUrl, responsiveSrcset, getDefaultImageUrl, getPreset } from '../../lib/module-helpers';
import { getReferences, type ReferenceItem, MEDIA_ORIGIN } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

const p = getPreset('card');
const apiOrigin = MEDIA_ORIGIN;

// Fetch references: manual (refs_id) or automatic (3 latest)
let refs: ReferenceItem[] = [];
const isManual = data.is_manual === true || data.is_manual === 1 || data.is_manual === '1';
const refsId = (data.refs_id as number[]) || [];

if (isManual && refsId.length > 0) {
  // Manual: fetch all published, then filter by IDs
  const allRefs = await getReferences({ status: 'published' });
  const allItems = Array.isArray(allRefs) ? allRefs : allRefs.items;
  refs = refsId
    .map(id => allItems.find(r => r.id === id))
    .filter((r): r is ReferenceItem => !!r)
    .slice(0, 3);
} else {
  // Automatic: 3 latest published
  const result = await getReferences({ status: 'published', limit: 3 });
  refs = Array.isArray(result) ? result.slice(0, 3) : result.items.slice(0, 3);
}

const showArchiveLink = data.display_archive_link === true || data.display_archive_link === 1 || data.display_archive_link === '1';
const archiveLinkLabel = (data.archive_link_label as string) || 'Voir toutes les références';

// Parse photos from custom_fields
function getPhotos(ref: ReferenceItem): string[] {
  const raw = ref.custom_fields?.photos;
  if (!raw) return [];
  try {
    const parsed = JSON.parse(raw);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function getFeaturedImageUrl(ref: ReferenceItem): string {
  if (ref.featured_image) {
    return resolveImageUrl(ref.featured_image, apiOrigin, 'half');
  }
  return getDefaultImageUrl() ? optimizedImageUrl(getDefaultImageUrl(), p.width, p.quality) : '';
}

function getCategory(ref: ReferenceItem): string {
  return ref.categories?.[0]?.name || '';
}

const indexPopin = Math.floor(Math.random() * 1000);
---

<NicklModuleWrapper data={data} moduleName="references" containerLarge>
  {refs.length > 0 && (
    <>
      <ul class="list">
        {refs.map((ref) => {
          const photos = getPhotos(ref);
          const mainImage = photos[0] || getFeaturedImageUrl(ref);
          const category = getCategory(ref);
          const customerName = ref.custom_fields?.customer_name || '';

          return (
            <li class="item">
              <div class="slider-wrapper" style="aspect-ratio:100/74.78;overflow:hidden;position:relative;">
                {photos.length > 1 ? (
                  <div class="swiper slider js_references-slider">
                    <div class="swiper-wrapper">
                      {photos.map((photo) => (
                        <div class="swiper-slide">
                          <a href={`/references/${ref.slug}`} class="illus-wrapper">
                            <img src={optimizedImageUrl(photo, p.width, p.quality)} srcset={responsiveSrcset(photo, p.srcsetWidths, p.srcsetQuality) || undefined} sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 33vw" alt={ref.title} class="illus" width="400" height="300" loading="lazy" />
                            <div class="overlay">
                              <span class="icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="24" viewBox="0 0 40 23.99" fill="currentColor"><path d="M20,0C12.76,0,5.52,4,0,12c11.04,16,28.96,16,40,0C34.48,4,27.25,0,20,0m0,20c-4.42,0-8.01-3.58-8.02-8.01S15.57,3.98,19.99,3.98c4.42,0,8.01,3.58,8.02,8.01,0,0,0,.01,0,.01,0,4.42-3.59,8-8,8"/><path d="M20,7.99c2.21,0,4,1.79,4,4s-1.79,4-4,4-4-1.79-4-4h0c0-2.21,1.79-4,4-4"/></svg>
                              </span>
                              <span>Découvrir</span>
                            </div>
                          </a>
                        </div>
                      ))}
                    </div>
                    <button type="button" class="slider-navigation prev"></button>
                    <button type="button" class="slider-navigation next"></button>
                    <div class="slider-pagination js_references-slider-pagination"></div>
                  </div>
                ) : (
                  <a href={`/references/${ref.slug}`} class="illus-wrapper" style="position:relative;overflow:hidden;">
                    {mainImage && <img src={optimizedImageUrl(mainImage, p.width, p.quality)} srcset={responsiveSrcset(mainImage, p.srcsetWidths, p.srcsetQuality) || undefined} sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 33vw" alt={ref.title} class="illus" width="400" height="300" loading="lazy" />}
                    <div class="overlay">
                      <span class="icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="24" viewBox="0 0 40 23.99" fill="currentColor"><path d="M20,0C12.76,0,5.52,4,0,12c11.04,16,28.96,16,40,0C34.48,4,27.25,0,20,0m0,20c-4.42,0-8.01-3.58-8.02-8.01S15.57,3.98,19.99,3.98c4.42,0,8.01,3.58,8.02,8.01,0,0,0,.01,0,.01,0,4.42-3.59,8-8,8"/><path d="M20,7.99c2.21,0,4,1.79,4,4s-1.79,4-4,4-4-1.79-4-4h0c0-2.21,1.79-4,4-4"/></svg>
                      </span>
                      <span>Découvrir</span>
                    </div>
                  </a>
                )}
              </div>
              <a href={`/references/${ref.slug}`} class="link">
                {category && <p class="category">{category}</p>}
                <h3 class="title title-section-3">{ref.title}</h3>
                {customerName && <p class="name">{customerName}</p>}
              </a>
            </li>
          );
        })}
      </ul>

      {showArchiveLink && (
        <div class="btn-more-wrapper">
          <a href="/references" class="btn btn-tertiary color-primary">{archiveLinkLabel}</a>
        </div>
      )}
    </>
  )}
</NicklModuleWrapper>
<script is:inline>
(function() {
  // Init Swiper sliders for references module (deferred)
  function initRefSliders() {
    if (!window.Swiper) return;
    document.querySelectorAll('.module-references .js_references-slider').forEach(function(el) {
      if (el.swiper) return;
      var count = el.querySelectorAll('.swiper-slide').length;
      if (count < 2) return;
      var w = el.closest('.slider-wrapper') || el.parentElement;
      new window.Swiper(el, {
        loop: count > 2,
        speed: 750,
        slidesPerView: 1,
        navigation: {
          nextEl: w.querySelector('.next'),
          prevEl: w.querySelector('.prev')
        },
        pagination: {
          el: w.querySelector('.js_references-slider-pagination'),
          type: 'bullets',
          clickable: true
        }
      });
    });
  }

  // Wait for Swiper to be loaded (by DeferredLoader)
  if (window.Swiper) {
    initRefSliders();
  } else {
    var check = setInterval(function() {
      if (window.Swiper) { clearInterval(check); initRefSliders(); }
    }, 500);
    setTimeout(function() { clearInterval(check); }, 15000);
  }
})();
</script>
