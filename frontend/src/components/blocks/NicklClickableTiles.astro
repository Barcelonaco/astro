---
import { buildModuleClasses } from '../../lib/module-classes';
import { optimizedImageUrl, responsiveSrcset, getDefaultImageUrl } from '../../lib/module-helpers';
import { MEDIA_ORIGIN } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props as Props;

const apiOrigin = MEDIA_ORIGIN;

const inColumns = !!data.columns;
const id = inColumns ? '' : ((data.id_bloc as string) ?? '');
const classes = inColumns ? '' : buildModuleClasses(data);
const bgImg = inColumns ? null : ((data.bg_img as any) ?? null);
const rawBgOpacity = data.bg_opacity as number | string | undefined;
const opacityPercent =
  rawBgOpacity === undefined || rawBgOpacity === null || rawBgOpacity === ''
    ? 10
    : Number(rawBgOpacity);
const bgOpacity = Number.isNaN(opacityPercent) ? 10 : opacityPercent;

const backgroundImage = bgImg
  ? {
      url: typeof bgImg === 'string'
        ? (bgImg.startsWith('http') ? bgImg : apiOrigin + bgImg)
        : (typeof bgImg.url === 'string' && bgImg.url.startsWith('http')
            ? bgImg.url
            : apiOrigin + String(bgImg.url || '')),
      opacity: bgOpacity,
    }
  : null;
const titleBloc = inColumns ? '' : ((data.title_bloc as string) ?? (data.title as string) ?? '');
const titleStyle = (data.title_style as number | string) ?? 2;
const titleAlign = (data.title_align as string) ?? 'center';

const listItems = (data.list_interlocking as any[]) ?? [];
const interlockingTiles = data.interlocking_tiles === true || data.interlocking_tiles === 1 || data.interlocking_tiles === '1';
const orientation = data.orientation === true || data.orientation === 1 || data.orientation === '1';
const clickableBlock = data.clickable_block === true || data.clickable_block === 1 || data.clickable_block === '1';
const mainBlocRight = data['main-bloc-position'] === true || data['main-bloc-position'] === 1 || data['main-bloc-position'] === '1';
const styleChoice = (data.style_choice as string) ?? 'style-1';
const isVisible = (data.is_visible ?? 'yes') !== 'no';

const extraClasses = [
  mainBlocRight ? 'main-bloc-right' : 'main-bloc-left',
  styleChoice,
].filter(Boolean).join(' ');

// Layout logic matching Blade template
const count = listItems.length;
const useCols = interlockingTiles; // Blade always uses cols-wrapper for interlocking

// Col splits for interlocking (2-6 items)
const firstItem = listItems.slice(0, 1);
const secondItem = listItems.slice(1, 2);
const otherItemsFrom2 = listItems.slice(2); // for 6-item case
const otherItems = listItems.slice(1);       // for standard col case

function resolveFileUrl(file: any): string {
  const url = file ? (typeof file === 'string' ? file : (file.url || '')) : '';
  const finalUrl = url || getDefaultImageUrl();
  if (!finalUrl) return '';
  const fullUrl = finalUrl.startsWith('http') ? finalUrl : apiOrigin + finalUrl;
  return optimizedImageUrl(fullUrl, 500, 75);
}

function resolveFileSrcset(file: any): string {
  const url = typeof file === 'string' ? file : (file?.url || '');
  return responsiveSrcset(url, [300, 400, 500, 700], 75);
}

function isVideo(file: any): boolean {
  if (!file) return false;
  const mime = file.mime_type || file.type || '';
  if (mime.startsWith('video/')) return true;
  const url = typeof file === 'string' ? file : (file.url || '');
  return /\.(mp4|mov|mpeg|mpg)$/i.test(url);
}

function hasDesc(item: any): boolean {
  return !!(item.title || item.catchphrase || (!clickableBlock && (item.primary_link?.url || item.secondary_link?.url)));
}
---

{isVisible && listItems.length > 0 && (
  <div id={id} class={`module module-clickable ${classes} ${extraClasses}`}>
    {backgroundImage && backgroundImage.url && (
      <div
        class="background"
        style={`background-image: url(${backgroundImage.url}); opacity: ${Number(backgroundImage.opacity ?? 10) / 100};`}
      />
    )}

    <div class="container-large">
      {titleBloc && (
        <div class={`bloc-title-module align-${titleAlign}`}>
          <h2 class={`title-module title-section-${titleStyle}`}>{titleBloc}</h2>
        </div>
      )}

      {/* Flat grid: non-interlocking OR interlocking 8+ items (same single-row layout) */}
      {!interlockingTiles || count >= 8 ? (
        <div class={`list items items-${count}`}>
          {listItems.map((item) => (
            <div
              class={`item ${hasDesc(item) ? 'has-desc' : 'no-desc'} ${!orientation ? 'landscape' : ''}`}
              role="article"
            >
              {clickableBlock && item.primary_link?.url ? (
                <a href={item.primary_link.url} class="item-content" target={item.primary_link.target || '_self'} rel="bookmark">
                  {isVideo(item.file) ? (
                    <div class="video-wrapper">
                      <video class="background-video" autoplay loop muted playsinline>
                        <source src={resolveFileUrl(item.file)} type="video/mp4" />
                      </video>
                    </div>
                  ) : (
                    <div class="illus-wrapper">
                      <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                    </div>
                  )}
                  {hasDesc(item) && (
                    <div class="desc">
                      {item.title && <h3 class="title">{item.title}</h3>}
                      {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                    </div>
                  )}
                </a>
              ) : (
                <div class="item-content">
                  {isVideo(item.file) ? (
                    <div class="video-wrapper">
                      <video class="background-video" autoplay loop muted playsinline>
                        <source src={resolveFileUrl(item.file)} type="video/mp4" />
                      </video>
                    </div>
                  ) : (
                    <div class="illus-wrapper">
                      <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                    </div>
                  )}
                  {hasDesc(item) && (
                    <div class="desc">
                      {item.title && <h3 class="title">{item.title}</h3>}
                      {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                      {!clickableBlock && (item.primary_link?.url || item.secondary_link?.url) && (
                        <div class="btn-wrapper">
                          {item.primary_link?.url && (
                            <a href={item.primary_link.url} class="btn btn-primary" target={item.primary_link.target || '_self'}>
                              {item.primary_link.title}
                            </a>
                          )}
                          {item.secondary_link?.url && (
                            <a href={item.secondary_link.url} class="btn btn-secondary" target={item.secondary_link.target || '_self'}>
                              {item.secondary_link.title}
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        /* Interlocking cols */
        <div class={`cols-wrapper items-${count}`}>
          {count >= 8 ? (
            /* 8+ items: flat layout inside cols-wrapper */
            <div class="items">
              {listItems.map((item) => (
                <div class={`item ${hasDesc(item) ? 'has-desc' : 'no-desc'} ${!orientation ? 'landscape' : ''}`} role="article">
                  {clickableBlock && item.primary_link?.url ? (
                    <a href={item.primary_link.url} class="item-content" target={item.primary_link.target || '_self'} rel="bookmark">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                        </div>
                      )}
                    </a>
                  ) : (
                    <div class="item-content">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                          {!clickableBlock && (item.primary_link?.url || item.secondary_link?.url) && (
                            <div class="btn-wrapper">
                              {item.primary_link?.url && (
                                <a href={item.primary_link.url} class="btn btn-primary" target={item.primary_link.target || '_self'}>
                                  {item.primary_link.title}
                                </a>
                              )}
                              {item.secondary_link?.url && (
                                <a href={item.secondary_link.url} class="btn btn-secondary" target={item.secondary_link.target || '_self'}>
                                  {item.secondary_link.title}
                                </a>
                              )}
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          ) : (
          <>
          {/* Colonne 1 */}
          <div class="items col col-1">
            {firstItem.map((item) => (
              <div class={`item ${hasDesc(item) ? 'has-desc' : 'no-desc'} ${!orientation ? 'landscape' : ''}`} role="article">
                {clickableBlock && item.primary_link?.url ? (
                  <a href={item.primary_link.url} class="item-content" target={item.primary_link.target || '_self'} rel="bookmark">
                    {isVideo(item.file) ? (
                      <div class="video-wrapper">
                        <video class="background-video" autoplay loop muted playsinline>
                          <source src={resolveFileUrl(item.file)} type="video/mp4" />
                        </video>
                      </div>
                    ) : (
                      <div class="illus-wrapper">
                        <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                      </div>
                    )}
                    {hasDesc(item) && (
                      <div class="desc">
                        {item.title && <h3 class="title">{item.title}</h3>}
                        {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="item-content">
                    {isVideo(item.file) ? (
                      <div class="video-wrapper">
                        <video class="background-video" autoplay loop muted playsinline>
                          <source src={resolveFileUrl(item.file)} type="video/mp4" />
                        </video>
                      </div>
                    ) : (
                      <div class="illus-wrapper">
                        <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                      </div>
                    )}
                    {hasDesc(item) && (
                      <div class="desc">
                        {item.title && <h3 class="title">{item.title}</h3>}
                        {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                        {!clickableBlock && (item.primary_link?.url || item.secondary_link?.url) && (
                          <div class="btn-wrapper">
                            {item.primary_link?.url && (
                              <a href={item.primary_link.url} class="btn btn-primary" target={item.primary_link.target || '_self'}>
                                {item.primary_link.title}
                              </a>
                            )}
                            {item.secondary_link?.url && (
                              <a href={item.secondary_link.url} class="btn btn-secondary" target={item.secondary_link.target || '_self'}>
                                {item.secondary_link.title}
                              </a>
                            )}
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          {/* Colonne 1-bis (6 items only) */}
          {count === 6 && (
            <div class="items col col-1-bis">
              {secondItem.map((item) => (
                <div class={`item ${hasDesc(item) ? 'has-desc' : 'no-desc'} ${!orientation ? 'landscape' : ''}`} role="article">
                  {clickableBlock && item.primary_link?.url ? (
                    <a href={item.primary_link.url} class="item-content" target={item.primary_link.target || '_self'} rel="bookmark">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                        </div>
                      )}
                    </a>
                  ) : (
                    <div class="item-content">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                          {!clickableBlock && (item.primary_link?.url || item.secondary_link?.url) && (
                            <div class="btn-wrapper">
                              {item.primary_link?.url && (
                                <a href={item.primary_link.url} class="btn btn-primary" target={item.primary_link.target || '_self'}>
                                  {item.primary_link.title}
                                </a>
                              )}
                              {item.secondary_link?.url && (
                                <a href={item.secondary_link.url} class="btn btn-secondary" target={item.secondary_link.target || '_self'}>
                                  {item.secondary_link.title}
                                </a>
                              )}
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}

          {/* Colonne 2 */}
          {(count === 6 ? otherItemsFrom2 : otherItems).length > 0 && (
            <div class="items col col-2">
              {(count === 6 ? otherItemsFrom2 : otherItems).map((item) => (
                <div class={`item ${hasDesc(item) ? 'has-desc' : 'no-desc'} ${!orientation ? 'landscape' : ''}`} role="article">
                  {clickableBlock && item.primary_link?.url ? (
                    <a href={item.primary_link.url} class="item-content" target={item.primary_link.target || '_self'} rel="bookmark">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                        </div>
                      )}
                    </a>
                  ) : (
                    <div class="item-content">
                      {isVideo(item.file) ? (
                        <div class="video-wrapper">
                          <video class="background-video" autoplay loop muted playsinline>
                            <source src={resolveFileUrl(item.file)} type="video/mp4" />
                          </video>
                        </div>
                      ) : (
                        <div class="illus-wrapper">
                          <img src={resolveFileUrl(item.file)} srcset={resolveFileSrcset(item.file) || undefined} sizes="(max-width: 600px) calc(100vw - 40px), (max-width: 960px) 45vw, 30vw" alt="" class="illus" width="700" height="500" loading="lazy" />
                        </div>
                      )}
                      {hasDesc(item) && (
                        <div class="desc">
                          {item.title && <h3 class="title">{item.title}</h3>}
                          {item.catchphrase && <div class="editor txt"><p>{item.catchphrase}</p></div>}
                          {!clickableBlock && (item.primary_link?.url || item.secondary_link?.url) && (
                            <div class="btn-wrapper">
                              {item.primary_link?.url && (
                                <a href={item.primary_link.url} class="btn btn-primary" target={item.primary_link.target || '_self'}>
                                  {item.primary_link.title}
                                </a>
                              )}
                              {item.secondary_link?.url && (
                                <a href={item.secondary_link.url} class="btn btn-secondary" target={item.secondary_link.target || '_self'}>
                                  {item.secondary_link.title}
                                </a>
                              )}
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
          </>
          )}
        </div>
      )}
    </div>
  </div>
)}

<style is:global>
/* Clickable tiles 6-8 items: desc hidden by default, revealed on hover */
.module-clickable .list.items-6 .item .desc,
.module-clickable .list.items-7 .item .desc,
.module-clickable .list.items-8 .item .desc {
  opacity: 0 !important;
  transition: opacity 0.3s ease;
}
.module-clickable .list.items-6 .item:hover .desc,
.module-clickable .list.items-7 .item:hover .desc,
.module-clickable .list.items-8 .item:hover .desc {
  opacity: 1 !important;
}
/* Hover expansion + height for 6-8 items row */
.module-clickable .list.items-6 .item,
.module-clickable .list.items-7 .item,
.module-clickable .list.items-8 .item {
  transition: flex-basis 0.3s ease;
}
.module-clickable .list.items-6 .item::before,
.module-clickable .list.items-7 .item::before,
.module-clickable .list.items-8 .item::before {
  padding-top: 40.625rem !important; /* 650px — tall vertical strips */
}
.module-clickable .list.items-6 .item:hover,
.module-clickable .list.items-7 .item:hover,
.module-clickable .list.items-8 .item:hover {
  flex-basis: 25% !important;
}
</style>
