---
/**
 * Module ReusableBloc — Fetch le bloc réutilisable par ID
 * et rend ses modules inline via BlockRenderer.
 */
import BlockRenderer from '../BlockRenderer.astro';
import { getReusableBlocById } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;
const blocId = data.bloc_id;
const isVisible = (data.is_visible ?? 'yes') !== 'no';

let blocks: any[] = [];
if (blocId && isVisible) {
  const bloc = await getReusableBlocById(Number(blocId));
  if (bloc && bloc.content) {
    try {
      const parsed = JSON.parse(bloc.content);
      if (Array.isArray(parsed)) blocks = parsed;
    } catch { /* invalid JSON */ }
  }
}
---

{isVisible && blocks.length > 0 && (
  <BlockRenderer blocks={blocks} />
)}
