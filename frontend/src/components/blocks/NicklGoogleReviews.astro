---
/**
 * Module GoogleReviews — Plugin Avis Google
 * Fetch les avis depuis le backend (options plugin) et affiche style TrustIndex.
 */
import NicklModuleWrapper from './NicklModuleWrapper.astro';
import { getGoogleReviews } from '../../lib/api';

interface Props {
  data: Record<string, any>;
}

const { data } = Astro.props;

let reviewsData = null;
let error = '';

try {
  reviewsData = await getGoogleReviews();
} catch (e) {
  error = 'Erreur lors de la récupération des avis Google.';
}

const reviews = reviewsData?.reviews || [];
const rating = reviewsData?.rating || 0;
const total = reviewsData?.total || 0;

function renderStars(score: number): string {
  return Array.from({ length: 5 }, (_, i) =>
    `<svg class="ti-star ${i < Math.round(score) ? 'ti-star-filled' : ''}" viewBox="0 0 24 24" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`
  ).join('');
}

function renderStarsLg(score: number): string {
  return Array.from({ length: 5 }, (_, i) =>
    `<svg class="ti-star ${i < Math.round(score) ? 'ti-star-filled' : ''}" viewBox="0 0 24 24" width="24" height="24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`
  ).join('');
}
---

<NicklModuleWrapper data={data} moduleName="google-reviews" containerLarge>
  {error ? (
    <p class="ti-error">{error}</p>
  ) : reviews.length === 0 ? (
    <p class="ti-error">Aucun avis disponible.</p>
  ) : (
    <div class="ti-widget">
      <div class="ti-widget-container">
        {/* Header badge */}
        <div class="ti-rating-header">
          <div class="ti-rating-badge">
            <span class="ti-rating-score">{rating.toFixed(1)}</span>
            <div class="ti-rating-info">
              <div class="ti-rating-stars" set:html={renderStarsLg(rating)} />
              <span class="ti-rating-text">Basé sur <strong>{total}</strong> avis</span>
            </div>
          </div>
          <div class="ti-powered">
            <svg viewBox="0 0 24 24" width="20" height="20" style="vertical-align:middle;margin-right:4px;"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google
          </div>
        </div>

        {/* Reviews slider */}
        <div class="ti-reviews-wrapper">
          <div class="swiper js_google-reviews-slider">
            <div class="swiper-wrapper">
              {reviews.map((review) => (
                <div class="swiper-slide ti-review-card">
                  <div class="ti-review-header">
                    <img src={review.profile_photo_url} alt={review.author_name} class="ti-author-photo" loading="lazy" width="44" height="44" />
                    <div class="ti-author-info">
                      <span class="ti-author-name">{review.author_name}</span>
                      <span class="ti-review-time">{review.relative_time_description}</span>
                    </div>
                    <svg class="ti-google-icon" viewBox="0 0 24 24" width="20" height="20"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                  </div>
                  <div class="ti-review-stars" set:html={renderStars(review.rating)} />
                  <div class={`ti-review-content${review.text.length > 200 ? '' : ' short'}`}>
                    <p class="ti-review-text">{review.text}</p>
                  </div>
                  {review.text.length > 200 && (
                    <button class="ti-read-more" type="button">Lire plus</button>
                  )}
                </div>
              ))}
            </div>
          </div>
          <button class="ti-nav ti-nav-prev" type="button" aria-label="Précédent">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <button class="ti-nav ti-nav-next" type="button" aria-label="Suivant">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
          </button>
          <div class="ti-pagination"></div>
        </div>

      </div>
    </div>
  )}
</NicklModuleWrapper>

<script is:inline>
(function() {
  function initGoogleReviewsSliders() {
    document.querySelectorAll('.module-google-reviews').forEach(function(module) {
      var swiperEl = module.querySelector('.js_google-reviews-slider');
      if (!swiperEl || swiperEl.swiper) return;

      var swiper = new window.Swiper(swiperEl, {
        slidesPerView: 1,
        spaceBetween: 16,
        autoplay: { delay: 6000, disableOnInteraction: true },
        navigation: {
          prevEl: module.querySelector('.ti-nav-prev'),
          nextEl: module.querySelector('.ti-nav-next'),
        },
        pagination: {
          el: module.querySelector('.ti-pagination'),
          clickable: true,
        },
        breakpoints: {
          640: { slidesPerView: 2 },
          1024: { slidesPerView: 3 },
        },
      });

      module.querySelectorAll('.ti-read-more').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var content = btn.previousElementSibling;
          if (content) {
            content.classList.toggle('expanded');
            btn.textContent = content.classList.contains('expanded') ? 'Lire moins' : 'Lire plus';
            swiper.update();
          }
        });
      });
    });
  }

  if (window.Swiper) {
    initGoogleReviewsSliders();
  } else {
    var check = setInterval(function() {
      if (window.Swiper) { clearInterval(check); initGoogleReviewsSliders(); }
    }, 100);
  }
})();
</script>
