};

// Reusable bloc
const footerCustomBloc = s.footer_custom_bloc || '';
const footerCustomBlocLocation = s.footer_custom_bloc_location || 'none';
let customBlocBlocks: unknown[] | null = null;
if (footerCustomBloc && footerCustomBlocLocation !== 'none') {
  try {
    const { getReusableBlocById } = await import('../lib/api');
    const bloc = await getReusableBlocById(Number(footerCustomBloc));
    if (bloc?.content) {
      const parsed = JSON.parse(bloc.content);
      if (Array.isArray(parsed)) customBlocBlocks = parsed;
    }
  } catch {}
}

// Footer + credit menus (fetched from menu system)
let footerLinks: { url: string; title: string }[] = [];
let creditLinks: { url: string; title: string }[] = [];
try {
  const API_URL = import.meta.env.BUILD_API_URL || import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
  const [footerRes, creditRes] = await Promise.all([
    fetch(`${API_URL}/menus/navigation/footer`),
    fetch(`${API_URL}/menus/navigation/credit`),
  ]);
  if (footerRes.ok) {
    const items = await footerRes.json();
    if (Array.isArray(items)) {
      footerLinks = items.map((item: any) => ({ url: item.url || `/${item.slug}/`, title: item.title }));
    }
  }
  if (creditRes.ok) {
    const items = await creditRes.json();
    if (Array.isArray(items)) {
      creditLinks = items.map((item: any) => ({ url: item.url || `/${item.slug}/`, title: item.title }));
    }
  }
} catch {}

const hasCol1 = logoUrl || phone || phone2 || link1Url || link2Url;
const hasCol3 = footerText || schedule || socialNetworks.length > 0;

const today = new Date();
---

{customBlocBlocks && footerCustomBlocLocation === 'before' && (
  <div class="footer-custom-block footer-custom-block-before">
    <ModuleStyles blocks={customBlocBlocks}/>
    <BlockRenderer blocks={customBlocBlocks} />
  </div>
)}
<footer id="footer" class={`footer-page${footerBgImg && footerBgParallax ? ' parallax' : ''}${footerBgImg ? ' has-background-image' : ''} ${footerColor}`} role="contentinfo">
  {footerBgImg && (
    <div class="background" style={`background-image: url('${footerBgImg}'); background-size: cover; background-position: center; opacity: ${footerBgOpacity};`}></div>
  )}
  <button type="button" class="btn-scroll btn-scroll-up js_footer-btn-scroll">En haut</button>
  <div class="container">
    <div class="top">
      {hasCol1 && (
        <div class="col col-1">
          {logoUrl && (
            <div class="logo-wrapper">
              <img src={logoUrl} alt={siteName} title={siteName} class="logo" width="200" height="70" />
            </div>
          )}
          {phone && (
            <p class="phone-wrapper">Tel.
              <a href={`tel:${phone.replace(/\s/g, '')}`} class="phone">{phone}</a>
            </p>
          )}
          {phone2 && (
            <p class="phone-wrapper">Tel.
              <a href={`tel:${phone2.replace(/\s/g, '')}`} class="phone">{phone2}</a>
            </p>
          )}
          {(link1Url || link2Url) && (
            <div class="btn-wrapper">
              {link1Url && link1Text && (
                <a href={link1Url} class="btn btn-primary">{link1Text}</a>
              )}
              {link2Url && link2Text && (
                <a href={link2Url} class="btn btn-secondary">{link2Text}</a>
              )}
            </div>
          )}
        </div>
      )}

      {footerLinks.length > 0 && (
        <div class="col col-2">
          <ul class="footer-menu">
            {footerLinks.map(link => (
              <li class="footer-menu-item">
                <a href={link.url}>{link.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {hasCol3 && (
        <div class="col col-3">
          {footerText && (
            <div class="editor txt-1">
              <p set:html={footerText.replace(/\n/g, '<br />')} />
            </div>
          )}
          {schedule && (
            <div class="editor txt-2">
              <p><b>Horaires d'ouverture</b></p>
              <p set:html={schedule.replace(/\n/g, '<br />')} />
            </div>
          )}
          {socialNetworks.length > 0 && (
            <ul class="social-networks">
              {socialNetworks.map(item => (
                <li class="item-social">
                  <a href={s[item.key]} title={item.label} target="_blank" rel="noopener noreferrer" class="link">
                    <span class="icon" aria-hidden="true" set:html={socialSvgs[item.key]} />
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}

      {showNewsletter && (
        <div class="col col-4 newsletter-form">
          {newsletterTitle && <p class="title-section-4">{newsletterTitle}</p>}
          {newsletterDesc && <p class="desc">{newsletterDesc}</p>}
          <form class="newsletter-form-inner" onsubmit="return false;">
            <div class="onefield">
              <input type="email" placeholder="Votre e-mail" required />
            </div>
            <div class="newsletter-submit">
              <button type="submit">S'inscrire</button>
            </div>
          </form>
        </div>
      )}
    </div>

    <div class="bottom">
      <ul class="nav">
        <li class="item">
          Copyright &copy; {today.getFullYear()} {siteName}
        </li>
        <li class="item">
          <a href="https://nickl.fr" target="_blank" rel="noopener noreferrer" class="link">Un site web développé par Nickl / Barcelona&co</a>
        </li>
        <li class="item">
          <button type="button" class="link" data-cc="show-preferencesModal" aria-haspopup="dialog">
            <span class="icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 14.97 14.97"><path d="M7.485,0A7.485,7.485,0,1,0,14.97,7.485,7.485,7.485,0,0,0,7.485,0m2.581,2.065a.258.258,0,1,1-.258.258.258.258,0,0,1,.258-.258M1.431,5.252a.258.258,0,1,1-.484-.179A6.974,6.974,0,0,1,3.38,1.856a.258.258,0,0,1,.308.414l0,0A6.458,6.458,0,0,0,1.431,5.252M3.613,4.9a.258.258,0,1,1-.258-.258.258.258,0,0,1,.258.258m.258,6.711a.258.258,0,1,1,.258-.258.258.258,0,0,1-.258.258M3.355,8.775A1.032,1.032,0,1,1,4.388,7.743,1.032,1.032,0,0,1,3.355,8.775M4.388,1.807a.258.258,0,1,1,.258-.258.258.258,0,0,1-.258.258m2.065,10.84a.774.774,0,1,1,.774-.774.774.774,0,0,1-.774.774m0-3.871a.258.258,0,1,1,.258.258.258.258,0,0,1-.258-.258m.806-4.1c-.4.4-.874.586-1.278.183a1.032,1.032,0,0,1,0-1.46c.4-.4,1.359-.706,1.762-.3s-.082,1.177-.485,1.58m1,2.292a.258.258,0,1,1,.258-.258.258.258,0,0,1-.258.258m1.807,5.42a.258.258,0,1,1,.258-.258.258.258,0,0,1-.258.258m.258-1.807c-.57,0-.774-.72-.774-1.29s.2-1.032.774-1.032a1.032,1.032,0,0,1,1.032,1.032c0,.57-.462,1.29-1.032,1.29m1.032-4.388a.774.774,0,1,1,.774-.774.774.774,0,0,1-.774.774"/></svg>
            </span>
            <span class="cookies-link">Gestion des cookies</span>
          </button>
        </li>
      </ul>
      {creditLinks.length > 0 && (
        <ul class="nav nav-credit">
          {creditLinks.map(link => (
            <li class="item">
              <a href={link.url} class="link">{link.title}</a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</footer>
{customBlocBlocks && footerCustomBlocLocation === 'after' && (
  <div class="footer-custom-block footer-custom-block-after">
    <ModuleStyles blocks={customBlocBlocks}/>
    <BlockRenderer blocks={customBlocBlocks} />
  </div>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('.js_footer-btn-scroll');
