---
/**
 * CartIndicator — pastille flottante qui affiche le nombre d'articles dans le
 * panier et redirige vers /panier. Mise à jour live via l'event 'cart:updated'
 * (dispatché par AddToCartButton, /panier, /checkout) + check initial via getCart.
 *
 * Cachée si panier vide.
 */
---

<a id="cart-indicator" href="/panier" class="cart-indicator" hidden aria-label="Panier">
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
  </svg>
  <span id="cart-indicator-count" class="cart-indicator-count">0</span>
</a>

<script>
  import { getCart } from '../../lib/shop-api'

  const link = document.getElementById('cart-indicator') as HTMLAnchorElement | null
  const countEl = document.getElementById('cart-indicator-count')
  if (link && countEl) {
    const update = (count: number) => {
      countEl.textContent = String(count)
      link.hidden = count <= 0
    }

    window.addEventListener('cart:updated', (e: Event) => {
      const detail = (e as CustomEvent).detail
      if (detail && typeof detail.items_count === 'number') update(detail.items_count)
    })

    ;(async () => {
      try {
        const cart = await getCart()
        update(cart.items_count)
      } catch { /* silent */ }
    })()
  }
</script>

<style>
  .cart-indicator {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent, #1a1a18);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
    text-decoration: none;
    z-index: 9000;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cart-indicator:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24);
  }
  .cart-indicator-count {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 999px;
    background: #d33;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    line-height: 22px;
    text-align: center;
    border: 2px solid #fff;
  }
  @media (max-width: 600px) {
    .cart-indicator { bottom: 16px; right: 16px; width: 48px; height: 48px; }
  }
</style>
