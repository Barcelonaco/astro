---
import { formatPrice } from '../../lib/shop-api';

interface Props {
  priceCents: number;
  priceCentsMax?: number;
  compareAtCents?: number | null;
  currency?: string;
  showCompare?: boolean;
}

const { priceCents, priceCentsMax, compareAtCents, currency = 'EUR', showCompare = true } = Astro.props;
const hasRange = priceCentsMax !== undefined && priceCentsMax !== priceCents;
const onSale = showCompare && compareAtCents && compareAtCents > priceCents;
const discountPct = onSale ? Math.round(((compareAtCents! - priceCents) / compareAtCents!) * 100) : 0;
---
<div class="price-display">
  {onSale && compareAtCents && (
    <span class="price-compare" aria-label={`Prix avant réduction ${formatPrice(compareAtCents, currency)}`}>{formatPrice(compareAtCents, currency)}</span>
  )}
  <span class="price-current">
    {hasRange ? (
      <>À partir de <strong>{formatPrice(priceCents, currency)}</strong></>
    ) : (
      <strong>{formatPrice(priceCents, currency)}</strong>
    )}
  </span>
  {onSale && <span class="price-discount-badge">-{discountPct}%</span>}
</div>

<style>
  .price-display {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .price-current {
    font-size: 1.1em;
    color: var(--color-default, #224f5a);
  }
  .price-current strong {
    font-weight: 700;
  }
  .price-compare {
    color: var(--gray-500, #6b7280);
    text-decoration: line-through;
    font-size: 0.9em;
  }
  .price-discount-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--danger, #dc2626);
    color: white;
    font-size: 0.75em;
    font-weight: 600;
  }
</style>
