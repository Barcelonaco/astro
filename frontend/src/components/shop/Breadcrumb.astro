---
interface Crumb { label: string; href?: string; }
interface Props { items: Crumb[]; }
const { items } = Astro.props;
---
{items.length > 0 && (
  <nav aria-label="Fil d'ariane" class="shop-breadcrumb">
    <ol>
      {items.map((item, i) => (
        <li>
          {item.href && i < items.length - 1 ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
          {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .shop-breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    color: var(--gray-500, #6b7280);
  }
  .shop-breadcrumb li {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .shop-breadcrumb a {
    color: var(--gray-600, #4b5563);
    text-decoration: none;
  }
  .shop-breadcrumb a:hover {
    color: var(--color-primary, #0f62fe);
    text-decoration: underline;
  }
  .shop-breadcrumb .sep {
    color: var(--gray-400, #9ca3af);
  }
  .shop-breadcrumb [aria-current="page"] {
    color: var(--color-default, #224f5a);
    font-weight: 500;
  }
</style>
