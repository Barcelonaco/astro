---
/**
 * Inlines Nickl module CSS directly into the HTML at build time.
 * This eliminates render-blocking external CSS requests while keeping CLS at 0.
 * CSS files are read from public/nickl-assets/css/ during Astro's build phase.
 */
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  blocks: { type: string; data?: any }[] | null;
  /** Skip app.css when rendered outside <head> (e.g. Footer) to avoid duplicates */
  skipAppCss?: boolean;
}

const { blocks, skipAppCss = false } = Astro.props;

/** Correspondance type de bloc → nom du fichier CSS (sans extension) */
const blockToCss: Record<string, string> = {
  accordion: 'accordion',
  banner: 'banner',
  'clickable-tiles': 'clickable-tiles',
  'columns-tab': 'columns-tab',
  contact: 'contact',
  'events-slider': 'events-slider',
  featured_products: 'featured_products',
  files: 'files',
  form: 'form',
  gallery: 'gallery',
  'gallery-nickl': 'gallery',
  hero: 'hero',
  'head-text': 'head-text',
  icons: 'icons',
  'icon-logo': 'icons',
  'illus-video': 'illustration-video',
  'images-slider': 'images-slider',
  'images-videos-parallax': 'images-videos-parallax',
  'insta-feed': 'insta-slider',
  'key-figures': 'key-figures',
  link: 'link',
  'link-alone': 'link',
  'logos-slider': 'logos-slider',
  'slider-logo': 'logos-slider',
  map: 'map',
  'news-slider': 'news-slider',
  'newsletter-form': 'newsletter-form',
  ornament: 'ornament',
  plansite: 'plansite',
  'free-post': 'free-post',
  quote: 'quote',
  references: 'references',
  review: 'review',
  separator: 'separator',
  share: 'share',
  summary: 'summary',
  team: 'team',
  text: 'text',
  'text-simple': 'text',
  'text-image': 'text-image',
  'text-scrolling': 'text-scrolling',
  'text-video-slider': 'text-video-slider',
  video: 'video',
};

/**
 * Collect all block types including sub-modules nested inside ColumnsTab.
 */
function collectAllBlockTypes(blocks: { type: string; data?: any }[]): string[] {
  const types: string[] = [];
  for (const b of blocks) {
    types.push(b.type);
    if (b.type === 'columns-tab' && b.data?.columns_list) {
      for (const col of b.data.columns_list as any[]) {
        const subModules = (col.columns_module as any[]) ?? [];
        for (const sub of subModules) {
          const layout = sub.acf_fc_layout || sub.type || '';
          if (layout) types.push(layout);
        }
      }
    }
  }
  return types;
}

/** Read a CSS file from public/nickl-assets/css/ at build time */
const cssDir = path.join(process.cwd(), 'public', 'nickl-assets', 'css');
function readCss(filename: string): string {
  try {
    return fs.readFileSync(path.join(cssDir, filename), 'utf-8');
  } catch {
    return '';
  }
}

const allTypes = blocks ? collectAllBlockTypes(blocks as any) : [];

const cssFileNames = [
  ...new Set(
    allTypes
      .map((t) => blockToCss[t])
      .filter((name): name is string => !!name),
  ),
];

// Read and concatenate all module CSS at build time
const cssChunks: string[] = [];
for (const name of cssFileNames) {
  cssChunks.push(readCss(`${name}.css`));
}

const inlinedCss = cssChunks.filter(Boolean).join('\n');

/** Plugin blocks: types not in blockToCss — must stay as <link> (external) */
const pluginBlockTypes = blocks
  ? [...new Set(
      blocks
        .map((b) => b.type)
        .filter((type) => !blockToCss[type]),
    )]
  : [];
---

{/* Main CSS — external, preloaded in BaseHead for some cases but always requested here */}
{!skipAppCss && <link rel="stylesheet" href="/nickl-assets/css/app.css" />}

{/* All Nickl module CSS inlined — zero external render-blocking requests for module specifics */}
{inlinedCss && <style set:html={inlinedCss} />}

{/* Plugin CSS — external (can't inline, lives in plugins/) */}
{pluginBlockTypes.map((type) => (
  <link rel="stylesheet" href={`/plugin-assets/${type}/css/${type}.css`} />
))}
