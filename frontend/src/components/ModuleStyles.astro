---
/**
 * Loads Nickl module CSS directly (non-deferred) via <link> tags.
 * CSS files live in /nickl-assets/css/ (copied from nickl/public/css/).
 * This ensures styles are available before first paint — no FOUC.
 */

interface Props {
  blocks: { type: string }[] | null;
}

const { blocks } = Astro.props;

/** Correspondance type de bloc → nom du fichier CSS (sans extension) */
const blockToCss: Record<string, string> = {
  accordion: 'accordion',
  banner: 'banner',
  'clickable-tiles': 'clickable-tiles',
  'columns-tab': 'columns-tab',
  contact: 'contact',
  'events-slider': 'events-slider',
  featured_products: 'featured_products',
  files: 'files',
  form: 'form',
  gallery: 'gallery',
  'gallery-nickl': 'gallery',
  hero: 'hero',
  'head-text': 'head-text',
  icons: 'icons',
  'icon-logo': 'icons',
  'illus-video': 'illustration-video',
  'images-slider': 'images-slider',
  'images-videos-parallax': 'images-videos-parallax',
  'insta-feed': 'insta-slider',
  'key-figures': 'key-figures',
  link: 'link',
  'link-alone': 'link',
  'logos-slider': 'logos-slider',
  'slider-logo': 'logos-slider',
  map: 'map',
  'news-slider': 'news-slider',
  'newsletter-form': 'newsletter-form',
  ornament: 'ornament',
  plansite: 'plansite',
  'free-post': 'free-post',
  quote: 'quote',
  references: 'references',
  review: 'review',
  separator: 'separator',
  share: 'share',
  summary: 'summary',
  team: 'team',
  'text-simple': 'text',
  'text-image': 'text-image',
  'text-scrolling': 'text-scrolling',
  'text-video-slider': 'text-video-slider',
  video: 'video',
};

const cssFiles = blocks
  ? [...new Set(
      blocks
        .map((b) => blockToCss[b.type])
        .filter((name): name is string => !!name),
    )]
  : [];

/** Plugin blocks: types not in blockToCss */
const pluginBlockTypes = blocks
  ? [...new Set(
      blocks
        .map((b) => b.type)
        .filter((type) => !blockToCss[type]),
    )]
  : [];
---

{/* Base Nickl styles — loaded async to avoid render-blocking (1.4MB) */}
<link rel="stylesheet" href="/nickl-assets/css/app.css" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="/nickl-assets/css/app.css" /></noscript>

{/* Module-specific CSS — async load to avoid render-blocking */}
{cssFiles.map((name) => (
  <>
    <link rel="stylesheet" href={`/nickl-assets/css/${name}.css`} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={`/nickl-assets/css/${name}.css`} /></noscript>
  </>
))}

{/* Plugin CSS — async load */}
{pluginBlockTypes.map((type) => (
  <>
    <link rel="stylesheet" href={`/plugin-assets/${type}/css/${type}.css`} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={`/plugin-assets/${type}/css/${type}.css`} /></noscript>
  </>
))}
