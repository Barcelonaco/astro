---
import { getSiteInfo } from '../consts';
import Navigation from './Navigation.astro';
import type { NavigationItem } from '../lib/api';

interface Props {
  siteName?: string;
  navigation?: NavigationItem[];
  secondaryNavigation?: NavigationItem[];
  siteSettings?: Record<string, string>;
  styleSettings?: Record<string, string>;
}

const { siteName: propSiteName, navigation, secondaryNavigation = [], siteSettings: s = {}, styleSettings: st = {} } = Astro.props;
const hasSecondaryNav = secondaryNavigation.length > 0;
const siteName = propSiteName || (await getSiteInfo()).siteName;

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
const apiOrigin = API_URL.replace(/\/api\/?$/, '');

// Header & menu settings
const menuSeamless = s.menu_seamless === '1';
const menuStyle = s.menu_style || 'default'; // default | center | burger
const showPhone = s.show_phone === '1';
const showSearch = s.show_search === '1';
const showSocials = s.show_socials === '1';
const phone = s.phone || '';
const phone2 = s.phone_2 || '';
const email = s.email || '';
const secretMenu = s.secret_menu === '1';

// Logo
const logoHeight = st.logo_height || '70';
const logoUrl = s.logo || '';
const logoWhiteUrl = s.logo_white || '';
// Resolve relative upload URLs to absolute
function resolveUrl(url: string) {
  if (!url) return '';
  if (url.startsWith('http')) return url;
  return `${apiOrigin}${url.startsWith('/') ? '' : '/'}${url}`;
}
const logo = resolveUrl(logoUrl);
const logoWhite = resolveUrl(logoWhiteUrl);

// Social networks
const socialNetworks = [
  { key: 'instagram', label: 'Instagram' },
  { key: 'facebook', label: 'Facebook' },
  { key: 'threads', label: 'Threads' },
  { key: 'tiktok', label: 'TikTok' },
  { key: 'linkedin', label: 'LinkedIn' },
  { key: 'twitter', label: 'X / Twitter' },
  { key: 'tripadvisor', label: 'Tripadvisor' },
  { key: 'pinterest', label: 'Pinterest' },
  { key: 'youtube', label: 'YouTube' },
].filter(item => s[item.key]);

// Top links
const topLink1Url = s.link_1_url || '';
const topLink1Text = s.link_1_text || '';
const topLink2Url = s.link_2_url || '';
const topLink2Text = s.link_2_text || '';

// Determine if top menu should display
const hasTopMenu = showPhone || showSocials || topLink1Url || topLink2Url || hasSecondaryNav;

// Header classes (matching Nickl exactly)
const headerClasses = [
  'header-page',
  menuSeamless ? 'background-transparent' : '',
  menuStyle === 'burger' ? 'has-mega-menu' : '',
  menuStyle === 'center' ? 'has-center-menu' : '',
  hasTopMenu ? 'has-top-menu' : '',
].filter(Boolean).join(' ');
---

<header id="header" class={`${headerClasses} no-transition`} role="banner">

  {/* Mega menu (burger style) */}
  {menuStyle === 'burger' && (
    <div class="mega-menu-wrapper">
      <div class="mega-menu">
        <div class="mega-menu-primary">
          <Navigation navigation={navigation} menuClass="menu" depth={3} />
        </div>
        <div class="top-menu">
          {hasSecondaryNav ? (
            <Navigation navigation={secondaryNavigation} menuClass="menu menu-secondary" depth={2} />
          ) : (
            <Navigation navigation={navigation} menuClass="menu" isSecondary={true} />
          )}
          <div class="links-secondary">
            {topLink1Url && (
              <a href={topLink1Url} class="btn btn-primary color-primary">
                {topLink1Text || 'En savoir plus'}
              </a>
            )}
            {topLink2Url && (
              <a href={topLink2Url} class="btn btn-primary color-secondary">
                {topLink2Text || 'En savoir plus'}
              </a>
            )}
            {showPhone && phone && (
              <p class="phone-wrapper">
                <a href={`tel:${phone.replace(/\s/g, '')}`} class="phone">{phone}</a>
              </p>
            )}
            {showSocials && socialNetworks.length > 0 && (
              <ul class="social-networks">
                {socialNetworks.map(item => (
                  <li class="item-social">
                    <a href={s[item.key]} target="_blank" rel="noopener noreferrer" title={item.label}>
                      <span class={`icon-${item.key}`}></span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="header-wrapper">
    <div class="container-large">
      <div class="header-content">

        {/* Mobile hamburger */}
        <button type="button" title="Menu" class="hamburger mobile js_toggle-menu">
          <span class="line-wrapper">
            <span class="line line-1"></span>
            <span class="line line-2"></span>
            <span class="line line-3"></span>
          </span>
        </button>

        {/* Center menu: left navigation */}
        {menuStyle === 'center' && (
          <div class="menu-primary classic desktop">
            <Navigation navigation={navigation} menuClass="menu" depth={3} side="left" />
          </div>
        )}

        {/* Logo */}
        <a href="/" title={siteName} class="logo-wrapper">
          {logo ? (
            <>
              {logoWhite ? (
                <>
                  <img src={logo} alt={siteName} class="logo logo-dark" width="200" height={logoHeight} />
                  <img src={logoWhite} alt={siteName} class="logo logo-white" width="200" height={logoHeight} />
                </>
              ) : (
                <img src={logo} alt={siteName} class="logo" width="200" height={logoHeight} />
              )}
            </>
          ) : (
            <span class="logo-text">{siteName}</span>
          )}
        </a>

        {/* Burger style: hamburger desktop + links-primary */}
        {menuStyle === 'burger' && (
          <div class="menu-primary classic desktop">
            <div class="btn-wrapper desktop">
              {showSearch && (
                <button type="button" title="Recherche" class="btn-search js_btn-toggle-search">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </button>
              )}
              <button type="button" title="Menu" class="hamburger desktop js_toggle-mega-menu">
                <span class="line-wrapper">
                  <span class="line line-1"></span>
                  <span class="line line-2"></span>
                  <span class="line line-3"></span>
                </span>
              </button>
            </div>
          </div>
        )}

        {/* Center style: right navigation */}
        {menuStyle === 'center' && (
          <div class="menu-primary menu-primary-right classic desktop">
            <Navigation navigation={navigation} menuClass="menu" depth={3} side="right" />
          </div>
        )}

        {/* Default style: primary menu + top menu */}
        {menuStyle === 'default' && (
          <>
            <div class="menu-primary classic desktop">
              <Navigation navigation={navigation} menuClass="menu" depth={3} />
              {!hasTopMenu && showSearch && (
                <div class="btn-wrapper desktop">
                  <button type="button" title="Recherche" class="btn-search js_btn-toggle-search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                  </button>
                </div>
              )}
            </div>

            {hasTopMenu && (
              <div class="top-menu classic desktop">
                {hasSecondaryNav && (
                  <Navigation navigation={secondaryNavigation} menuClass="menu menu-secondary" depth={2} />
                )}
                <div class="links-secondary">
                  {topLink1Url && (
                    <a href={topLink1Url} class="btn btn-primary color-primary">
                      {topLink1Text || 'En savoir plus'}
                    </a>
                  )}
                  {topLink2Url && (
                    <a href={topLink2Url} class="btn btn-primary color-secondary">
                      {topLink2Text || 'En savoir plus'}
                    </a>
                  )}
                  {showPhone && phone && (
                    <p class="phone-wrapper">
                      <a href={`tel:${phone.replace(/\s/g, '')}`} class="phone">{phone}</a>
                    </p>
                  )}
                  {showSocials && socialNetworks.length > 0 && (
                    <ul class="social-networks">
                      {socialNetworks.map(item => (
                        <li class="item-social">
                          <a href={s[item.key]} target="_blank" rel="noopener noreferrer" title={item.label}>
                            <span class={`icon-${item.key}`}></span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
                {showSearch && (
                  <div class="btn-wrapper desktop">
                    <button type="button" title="Recherche" class="btn-search js_btn-toggle-search">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </button>
                  </div>
                )}
              </div>
            )}
          </>
        )}

        {/* Mobile buttons */}
        <div class="btn-wrapper mobile">
          {showSearch && (
            <button type="button" title="Recherche" class="btn-search js_btn-toggle-search">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
          )}
        </div>

      </div><!-- /.header-content -->

      {/* Mobile menu */}
      <div class="menu-mobile-wrapper">
        <div class="menu-mobile container-large">
          <div class="menu-primary mobile">
            <Navigation navigation={navigation} menuClass="menu" depth={3} mobile={true} />
          </div>
          <div class="top-menu mobile">
            {hasSecondaryNav && (
              <Navigation navigation={secondaryNavigation} menuClass="menu menu-secondary" depth={2} mobile={true} />
            )}
            <div class="links-secondary">
              {topLink1Url && (
                <a href={topLink1Url} class="btn btn-primary color-primary">
                  {topLink1Text || 'En savoir plus'}
                </a>
              )}
              {topLink2Url && (
                <a href={topLink2Url} class="btn btn-primary color-secondary">
                  {topLink2Text || 'En savoir plus'}
                </a>
              )}
              {showPhone && phone && (
                <p class="phone-wrapper">
                  <a href={`tel:${phone.replace(/\s/g, '')}`} class="phone">{phone}</a>
                </p>
              )}
              {showSocials && socialNetworks.length > 0 && (
                <ul class="social-networks">
                  {socialNetworks.map(item => (
                    <li class="item-social">
                      <a href={s[item.key]} target="_blank" rel="noopener noreferrer" title={item.label}>
                        <span class={`icon-${item.key}`}></span>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      </div><!-- /.menu-mobile-wrapper -->

    </div><!-- /.container-large -->

    {/* Secret menu (center style only) */}
    {menuStyle === 'center' && secretMenu && (
      <>
        <div class="secret-menu-trigger js_secret-menu-trigger">
          <button type="button" title="Menu" class="hamburger">
            <span class="line-wrapper">
              <span class="line line-1"></span>
              <span class="line line-2"></span>
            </span>
          </button>
        </div>
        <div class="top-menu classic desktop secret-menu">
          {hasSecondaryNav && (
            <Navigation navigation={secondaryNavigation} menuClass="menu menu-secondary" depth={2} />
          )}
          <div class="links-secondary">
            {topLink1Url && (
              <a href={topLink1Url} class="btn btn-primary color-primary">
                {topLink1Text || 'En savoir plus'}
              </a>
            )}
            {showPhone && phone && (
              <p class="phone-wrapper">
                <a href={`tel:${phone.replace(/\s/g, '')}`} class="phone">{phone}</a>
              </p>
            )}
            {showSocials && socialNetworks.length > 0 && (
              <ul class="social-networks">
                {socialNetworks.map(item => (
                  <li class="item-social">
                    <a href={s[item.key]} target="_blank" rel="noopener noreferrer" title={item.label}>
                      <span class={`icon-${item.key}`}></span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </>
    )}

  </div><!-- /.header-wrapper -->
</header>

<script>
  // Header scroll/sticky behavior — adapted from Nickl header.js
  (function() {
    const header = document.getElementById('header');
    if (!header) return;

    // Remove no-transition class after layout is stable to prevent load animations.
    // Double rAF ensures the browser has painted at least one frame with no-transition active.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        header.classList.remove('no-transition');
      });
    });

    const headerWrapper = header.querySelector('.header-wrapper');
    if (!headerWrapper) return;

    let position = window.scrollY;
    let headerSticky = 0;
    let keepHeaderVisible = false;

    // Mobile menu toggle
    document.querySelectorAll('.js_toggle-menu').forEach(btn => {
      btn.addEventListener('click', function() {
        if (window.innerWidth <= 1024) {
          this.classList.toggle('close');
          document.documentElement.classList.toggle('disable-scroll');
          document.body.classList.toggle('menu-active');
        }
      });
    });

    // Mega menu toggle (burger style)
    document.querySelectorAll('.js_toggle-mega-menu').forEach(btn => {
      btn.addEventListener('click', function() {
        if (window.innerWidth > 1024) {
          this.classList.toggle('close');
          document.body.classList.toggle('mega-menu-active');
          setTimeout(() => {
            document.documentElement.classList.toggle('disable-scroll', document.body.classList.contains('mega-menu-active'));
          }, 300);
        }
      });
    });

    // Secret menu toggle
    document.querySelectorAll('.js_secret-menu-trigger').forEach(trigger => {
      trigger.addEventListener('click', function() {
        header.classList.toggle('secret-menu-reveal');
        const el = document.querySelector('.secret-menu-trigger');
        if (!el) return;
        if (el.classList.contains('secret-menu-trigger-close')) {
          el.classList.toggle('secret-menu-trigger-close');
          el.classList.toggle('secret-menu-trigger-reverse');
        } else {
          el.classList.add('secret-menu-trigger-close');
          el.classList.remove('secret-menu-trigger-reverse');
        }
      });
    });

    // Mega menu accordion (burger style — submenu toggle on click)
    document.querySelectorAll('#header .mega-menu-primary .menu > li.menu-item-has-children > a').forEach(link => {
      link.addEventListener('click', function(e) {
        if (window.innerWidth > 1024) {
          e.preventDefault();
          const li = this.closest('li');
          if (!li) return;
          // Close siblings
          li.parentElement?.querySelectorAll(':scope > li').forEach(sibling => {
            if (sibling !== li) {
              sibling.classList.remove('active');
              const subMenu = sibling.querySelector(':scope > .sub-menu');
              if (subMenu) subMenu.style.display = 'none';
            }
          });
          // Toggle current
          li.classList.toggle('active');
          const subMenu = li.querySelector(':scope > .sub-menu');
          if (subMenu) {
            subMenu.style.display = li.classList.contains('active') ? 'block' : 'none';
          }
        }
      });
    });

    // Mobile submenu toggle
    document.querySelectorAll('.menu-primary.mobile .menu > li.menu-item-has-children > a').forEach(link => {
      link.addEventListener('click', function(e) {
        if (window.innerWidth <= 1024) {
          e.preventDefault();
          const li = this.closest('li');
          if (!li) return;
          this.classList.toggle('active');
          const subMenu = li.querySelector(':scope > .sub-menu');
          if (subMenu) {
            subMenu.style.display = subMenu.style.display === 'block' ? 'none' : 'block';
          }
        }
      });
    });

    // Scroll-based sticky header
    function posHeader() {
      const scroll = window.scrollY;
      const headerHeight = header.offsetHeight;
      const headerTop = header.offsetTop;

      if (scroll <= headerTop) {
        document.body.classList.remove('scroll-up', 'scroll-down');
      } else {
        document.body.classList.toggle('scroll-down', scroll > headerTop);
        document.body.classList.toggle('scroll-up', scroll <= headerTop);
      }

      if (document.documentElement.clientWidth > 1024) {
        if (scroll > position) {
          // Scrolling down
          if (scroll > headerHeight + headerTop) {
            headerSticky = headerHeight + headerTop;
            header.classList.add('transition');
          } else if (!keepHeaderVisible) {
            headerSticky = scroll;
            header.classList.remove('transition');
          }
        } else {
          // Scrolling up
          if (scroll > headerHeight + headerTop) {
            headerSticky = headerTop;
            header.classList.add('transition');
            keepHeaderVisible = true;
          } else if (keepHeaderVisible && scroll > headerTop) {
            headerSticky = headerTop;
            header.classList.add('transition');
          } else {
            headerSticky = scroll;
            header.classList.remove('transition');
            keepHeaderVisible = false;
          }
        }

        if (scroll <= 0) {
          headerSticky = 0;
          keepHeaderVisible = false;
        }

        (headerWrapper as HTMLElement).style.transform = `translateY(-${headerSticky}px)`;
        position = scroll;
      } else {
        (headerWrapper as HTMLElement).style.transform = '';
      }
    }

    // Set --header-height CSS variable for banner height calculations (avoids JS in banner)
    function setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', header.offsetHeight + 'px');
    }
    setHeaderHeight();
    window.addEventListener('resize', setHeaderHeight, { passive: true });

    window.addEventListener('scroll', posHeader, { passive: true });
    posHeader();
  })();
</script>

<style is:global>
  /* ── Kill all transitions on page load ── */
  #header.no-transition,
  #header.no-transition *,
  #header.no-transition *::before,
  #header.no-transition *::after {
    transition: none !important;
    animation: none !important;
  }

  /* ── Header wrapper must stay above all page content (clickable tiles, etc.) ── */
  #header .header-wrapper {
    z-index: 100;
  }

  /* ── Remove dark gradient overlay on transparent header ── */
  #header.background-transparent .header-wrapper::before {
    display: none;
  }

  /* ── Transparent header must not push content down ── */
  #header.background-transparent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 20;
  }
  /* ── Ensure header-wrapper is transparent at initial state ── */
  body:not(.scroll-down):not(.scroll-up) #header.background-transparent .header-wrapper {
    background-color: transparent !important;
    box-shadow: none !important;
  }

  /* ── Disable scroll when menu/mega-menu is open ── */
  html.disable-scroll {
    overflow: hidden;
  }

  /* ── Logo text fallback (when no image logo is uploaded) ── */
  #header .logo-text {
    font-family: var(--font-title, sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-default, #1a1a1a);
    text-decoration: none;
    white-space: nowrap;
  }
  #header .logo-wrapper {
    text-decoration: none;
  }
  #header.background-transparent:not(.transition) .logo-text {
    color: #fff;
  }
  body.scroll-down #header.background-transparent .logo-text,
  body.scroll-up #header.background-transparent .logo-text {
    color: var(--color-default, #1a1a1a);
  }

  /* ── Search button SVG fill ── */
  #header .btn-search {
    background: none;
    border: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: var(--color-default, #1a1a1a);
  }
  #header .btn-search:hover {
    color: var(--color-primary);
  }
  #header.background-transparent:not(.transition) .btn-search {
    color: #fff;
  }
  body.scroll-down #header.background-transparent .btn-search,
  body.scroll-up #header.background-transparent .btn-search {
    color: var(--color-default, #1a1a1a);
  }

  /* ── Social networks list in header ── */
  #header .social-networks {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.75rem;
  }
  #header .social-networks .item-social a {
    display: flex;
    width: 1rem;
    height: 1rem;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    text-decoration: none;
  }
  #header .social-networks .item-social a:hover {
    color: var(--color-secondary, var(--color-primary));
  }

  /* ── Secondary navigation in top-menu ── */
  #header .top-menu .menu-secondary {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
  }
  #header .top-menu .menu-secondary li {
    position: relative;
  }
  #header .top-menu .menu-secondary li a {
    font-size: 0.8125rem;
    color: var(--color-default, #1a1a1a);
    text-decoration: none;
    padding: 0 0.75rem;
    white-space: nowrap;
    transition: color 0.2s;
  }
  #header .top-menu .menu-secondary li a:hover {
    color: var(--color-primary);
  }
  #header .top-menu .menu-secondary .menu-wrapper {
    display: flex;
    align-items: center;
  }
  #header .top-menu.mobile .menu-secondary {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }
  #header .top-menu.mobile .menu-secondary li a {
    padding: 0.25rem 0;
    font-size: 0.875rem;
  }

  /* ── Phone wrapper in top-menu ── */
  #header .phone-wrapper {
    margin: 0;
  }
  #header .phone-wrapper a {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-default, #1a1a1a);
    text-decoration: none;
  }
  #header .phone-wrapper a:hover {
    color: var(--color-primary);
  }
</style>
