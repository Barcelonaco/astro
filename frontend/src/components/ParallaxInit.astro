---
/**
 * Initialise l'effet parallax sur tous les modules avec .background-parallax
 * et l'effet img-parallax sur les modules TextImage et Video.
 * Reproduit le comportement GSAP ScrollTrigger de nickl/resources/scripts/routes/modules.js
 * en JS pur (sans dépendance GSAP).
 */
---

<script>
(function initParallax() {
  if (window.__nicklParallaxInit) return;
  window.__nicklParallaxInit = true;

  var bgModules = document.querySelectorAll('.module.has-background-image.background-parallax');
  var imgParallaxWrappers = document.querySelectorAll('.module.img-parallax .illus-wrapper');
  var ornamentWrappers = document.querySelectorAll('.module-ornament .illus-wrapper');

  if (bgModules.length === 0 && imgParallaxWrappers.length === 0 && ornamentWrappers.length === 0) return;

  var ticking = false;

  function update() {
    var wh = window.innerHeight;

    // Batch all geometry reads first to avoid forced reflow
    var bgUpdates = [];
    bgModules.forEach(function(mod) {
      var rect = mod.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > wh) return;
      var bg = mod.querySelector('.background');
      if (!bg) return;
      var progress = (wh - rect.top) / (wh + rect.height);
      bgUpdates.push({ el: bg, val: 'translateY(' + (progress * 25) + '%)' });
    });

    var imgUpdates = [];
    imgParallaxWrappers.forEach(function(wrapper) {
      var rect = wrapper.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > wh) return;
      var illus = wrapper.querySelector('.illus');
      if (!illus) return;
      var progress = (wh - rect.top) / (wh + rect.height);
      imgUpdates.push({ el: illus, val: 'translateY(' + (200 * (1 - progress)) + 'px)' });
    });

    var ornUpdates = [];
    ornamentWrappers.forEach(function(wrapper) {
      var rect = wrapper.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > wh + 200) return;
      var illus = wrapper.querySelector('.illus');
      if (!illus) return;
      var progress = (wh - rect.top) / (wh + rect.height);
      ornUpdates.push({ el: illus, val: 'translateY(' + (14 * progress) + 'vh)' });
    });

    // Apply all writes after reads
    for (var i = 0; i < bgUpdates.length; i++) bgUpdates[i].el.style.transform = bgUpdates[i].val;
    for (var i = 0; i < imgUpdates.length; i++) imgUpdates[i].el.style.transform = imgUpdates[i].val;
    for (var i = 0; i < ornUpdates.length; i++) ornUpdates[i].el.style.transform = ornUpdates[i].val;

    ticking = false;
  }

  window.addEventListener('scroll', function() {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(update);
    }
  }, { passive: true });

  update();
})();
</script>
