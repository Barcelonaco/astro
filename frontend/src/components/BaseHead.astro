---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import '../styles/theme.css';

import type { ImageMetadata } from 'astro';
import fs from 'node:fs';
import path from 'node:path';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import ThemeInjector from './ThemeInjector.astro';
import CookieConsent from './CookieConsent.astro';
import AdminBar from './AdminBar.astro';
import { MEDIA_ORIGIN } from '../lib/api';

// Fix image paths in critical CSS at build time (write fixed version to public/)
const criticalCssSrc = path.join(process.cwd(), 'public', 'nickl-assets', 'css', 'app-critical.css');
try {
  const raw = fs.readFileSync(criticalCssSrc, 'utf-8');
  const fixed = raw.replaceAll('~@images/', '/nickl-assets/images/').replaceAll('../images/', '/nickl-assets/images/');
  if (fixed !== raw) fs.writeFileSync(criticalCssSrc, fixed);
} catch {}

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	styleSettings?: Record<string, string>;
	siteSettings?: Record<string, string>;
	lcpImage?: { desktop: string; mobile: string; srcset?: string; sizes?: string };
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, styleSettings, siteSettings: s = {}, lcpImage } = Astro.props;

// Cookie consent
const cookieEnabled = s.cookie_enabled || '0';

// Tracking codes
const gaCode = s.ga_code || '';
const awCode = s.aw_code || '';
const gtmCode = s.gtm_code || '';
const metaPixelCode = s.meta_pixel_code || '';

// Favicon
const apiOrigin = MEDIA_ORIGIN;
const faviconSetting = s.favicon || '';
const faviconUrl = faviconSetting
  ? (faviconSetting.startsWith('http') || faviconSetting.startsWith('/')
      ? faviconSetting
      : `/${faviconSetting}`)
  : '';
const faviconType = faviconUrl
  ? (/\.svg(\?|$)/i.test(faviconUrl) ? 'image/svg+xml'
    : /\.png(\?|$)/i.test(faviconUrl) ? 'image/png'
    : /\.ico(\?|$)/i.test(faviconUrl) ? 'image/x-icon'
    : /\.(jpg|jpeg)(\?|$)/i.test(faviconUrl) ? 'image/jpeg'
    : /\.webp(\?|$)/i.test(faviconUrl) ? 'image/webp' : '')
  : '';
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{/* Preconnect to media origin — saves ~300ms DNS+TCP+TLS on first image request */}
{apiOrigin && <link rel="preconnect" href={apiOrigin} />}
{/* LCP image preload — MUST appear before any CSS to start download immediately */}
{lcpImage?.srcset ? (
  <link rel="preload" as="image" imagesrcset={lcpImage.srcset} imagesizes={lcpImage.sizes} fetchpriority="high" />
) : (
  <>
    {lcpImage?.mobile && <link rel="preload" as="image" href={lcpImage.mobile} media="(max-width: 600px)" fetchpriority="high" />}
    {lcpImage?.desktop && <link rel="preload" as="image" href={lcpImage.desktop} media="(min-width: 601px)" fetchpriority="high" />}
  </>
)}
<style>
/* Popin overlay — needs to be ready before JS */
.popin-gallery-wrapper{position:fixed;top:0;left:0;width:100%;height:100%;visibility:hidden;opacity:0;z-index:9999;transition:all .6s ease}
.popin-gallery-wrapper.active{visibility:visible;opacity:1}
</style>
{/* Nickl CSS — external cacheable file */}
<link rel="stylesheet" href="/nickl-assets/css/app-critical.css" />
{/* Deferred CSS — non-blocking, fetched in parallel but doesn't block render */}
<link rel="stylesheet" href="/nickl-assets/css/app-deferred.css" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="/nickl-assets/css/app-deferred.css" /></noscript>
{faviconUrl ? (
  <link rel="icon" id="siteFavicon" href={faviconUrl} {...(faviconType ? { type: faviconType } : {})} />
) : (
  <link rel="icon" id="siteFavicon" type="image/svg+xml" href="/favicon.svg" />
)}
<script is:inline define:vars={{ apiBase: apiOrigin ? `${apiOrigin}/api` : '/api' }}>
  (function () {
    fetch(apiBase + '/settings/site').then(function (r) { return r.ok ? r.json() : null; }).then(function (d) {
      if (!d || !d.favicon) return;
      var el = document.getElementById('siteFavicon');
      if (!el) return;
      var href = d.favicon;
      if (href.indexOf('http') !== 0 && href.charAt(0) !== '/') href = '/' + href;
      var current = el.getAttribute('href') || '';
      if (current === href) return;
      el.setAttribute('href', href);
      var ext = (href.split('?')[0].match(/\.([a-z0-9]+)$/i) || [])[1] || '';
      var map = { svg: 'image/svg+xml', png: 'image/png', ico: 'image/x-icon', jpg: 'image/jpeg', jpeg: 'image/jpeg', webp: 'image/webp' };
      if (map[ext.toLowerCase()]) el.setAttribute('type', map[ext.toLowerCase()]);
    }).catch(function () {});
  })();
</script>
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={title}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Google Fonts self-hosted — no external preconnect needed -->
<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<ThemeInjector styleSettings={styleSettings} />
<AdminBar siteSettings={s} />

{/* Cookie Consent — when enabled, tracking scripts are loaded after consent */}
<CookieConsent
  cookieEnabled={cookieEnabled}
  cookieTitle={s.cookie_title || ''}
  cookieDescription={s.cookie_description || ''}
  cookiePrivacyUrl={s.cookie_privacy_url || ''}
  cookieAcceptText={s.cookie_accept_text || ''}
  cookieRejectText={s.cookie_reject_text || ''}
  gaCode={gaCode}
  gtmCode={gtmCode}
  awCode={awCode}
  metaPixelCode={metaPixelCode}
/>

{/* Tracking scripts — deferred to after page load to avoid impacting performance */}
{cookieEnabled !== '1' && (gtmCode || gaCode || awCode || metaPixelCode) && (
  <script set:html={`window.addEventListener('load',function(){var r=window.requestIdleCallback||function(c){setTimeout(c,200)};r(function(){${
    gtmCode ? `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmCode}');` : ''
  }${
    gaCode && !gtmCode ? `var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${gaCode}';document.head.appendChild(s);window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaCode}');` : ''
  }${
    awCode && !gtmCode ? `var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${awCode}';document.head.appendChild(s);window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${awCode}');` : ''
  }${
    metaPixelCode ? `!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${metaPixelCode}');fbq('track','PageView');` : ''
  }})});`} />
)}
