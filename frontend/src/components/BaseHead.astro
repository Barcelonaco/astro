---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import '../styles/theme.css';

import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import ThemeInjector from './ThemeInjector.astro';
import CookieConsent from './CookieConsent.astro';
import AdminBar from './AdminBar.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	styleSettings?: Record<string, string>;
	siteSettings?: Record<string, string>;
	lcpImage?: { desktop: string; mobile: string };
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, styleSettings, siteSettings: s = {}, lcpImage } = Astro.props;

// Cookie consent
const cookieEnabled = s.cookie_enabled || '0';

// Tracking codes
const gaCode = s.ga_code || '';
const awCode = s.aw_code || '';
const gtmCode = s.gtm_code || '';
const metaPixelCode = s.meta_pixel_code || '';

// Favicon
const API_URL = import.meta.env.BUILD_API_URL || import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
const apiOrigin = API_URL.replace(/\/api\/?$/, '');
const faviconSetting = s.favicon || '';
const faviconUrl = faviconSetting ? (faviconSetting.startsWith('http') ? faviconSetting : `${apiOrigin}${faviconSetting.startsWith('/') ? '' : '/'}${faviconSetting}`) : '';
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{/* LCP image preload — MUST appear before any CSS to start download immediately */}
{lcpImage?.mobile && <link rel="preload" as="image" href={lcpImage.mobile} media="(max-width: 600px)" fetchpriority="high" />}
{lcpImage?.desktop && <link rel="preload" as="image" href={lcpImage.desktop} media="(min-width: 601px)" fetchpriority="high" />}
<style>
/* Critical CSS — prevents FOUC while app.css loads async */
*,*:before,*:after{box-sizing:border-box;-webkit-font-smoothing:antialiased}
body{margin:0}
img{border-style:none;max-width:100%;height:auto}
.container{width:100%;max-width:calc(5vw*2 + 1430px);margin-right:auto;margin-left:auto;padding-right:5vw;padding-left:5vw}
.container-large{width:100%;max-width:120rem;margin-right:auto;margin-left:auto;padding-right:5vw;padding-left:5vw}
.module{position:relative;padding-top:calc(75px + 3.90625vw);padding-bottom:calc(75px + 3.90625vw)}
.has-padding-top-none{padding-top:0!important}
.has-padding-top-small{padding-top:calc(35px + 1.953125vw)!important}
.has-padding-bottom-none{padding-bottom:0!important}
.has-padding-bottom-small{padding-bottom:calc(35px + 1.953125vw)!important}
.has-background-primary{background-color:var(--color-primary,#3ee98d)}
.has-background-secondary{background-color:var(--color-secondary,#02bd9c);color:var(--color-background,#fff)}
.has-background-tertiary{background-color:var(--color-tertiary,#d6d6d6)}
.has-background-image{overflow:hidden}
.has-background-image>.background-image{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:0}
.is-fullscreen>.container,.is-fullscreen>.container-large{max-width:100%;padding-left:0;padding-right:0}
.slider-navigation{position:absolute;z-index:5;top:50%;display:none;padding:.625rem;border:0;transform:translateY(-50%);background:none;cursor:pointer}
/* Popin overlay — needs to be ready before JS */
.popin-gallery-wrapper{position:fixed;top:0;left:0;width:100%;height:100%;visibility:hidden;opacity:0;z-index:9999;transition:all .6s ease}
.popin-gallery-wrapper.active{visibility:visible;opacity:1}
</style>
{/* app.css — loaded async to unblock rendering (~3.6 MB). Critical styles inlined above. */}
<link rel="stylesheet" href="/nickl-assets/css/app.css" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="/nickl-assets/css/app.css" /></noscript>
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={title}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Google Fonts self-hosted — no external preconnect needed -->
<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<ThemeInjector styleSettings={styleSettings} />
<AdminBar siteSettings={s} />

{/* Cookie Consent — when enabled, tracking scripts are loaded after consent */}
<CookieConsent
  cookieEnabled={cookieEnabled}
  cookieTitle={s.cookie_title || ''}
  cookieDescription={s.cookie_description || ''}
  cookiePrivacyUrl={s.cookie_privacy_url || ''}
  cookieAcceptText={s.cookie_accept_text || ''}
  cookieRejectText={s.cookie_reject_text || ''}
  gaCode={gaCode}
  gtmCode={gtmCode}
  awCode={awCode}
  metaPixelCode={metaPixelCode}
/>

{/* Tracking scripts — deferred to after page load to avoid impacting performance */}
{cookieEnabled !== '1' && (gtmCode || gaCode || awCode || metaPixelCode) && (
  <script set:html={`window.addEventListener('load',function(){var r=window.requestIdleCallback||function(c){setTimeout(c,200)};r(function(){${
    gtmCode ? `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmCode}');` : ''
  }${
    gaCode && !gtmCode ? `var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${gaCode}';document.head.appendChild(s);window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaCode}');` : ''
  }${
    awCode && !gtmCode ? `var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${awCode}';document.head.appendChild(s);window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${awCode}');` : ''
  }${
    metaPixelCode ? `!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${metaPixelCode}');fbq('track','PageView');` : ''
  }})});`} />
)}
