{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", "../plugins/**/templates/*.astro"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@frontend/*": ["src/*"],
      "@plugins/*": ["../plugins/*"]
    }
  }
}
